meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode2
meVE.Stichera01.greekmelody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.greekname
meVE.Stichera01.melody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.name
meVE.Stichera01.incipit = "Clement, in accordance…"
meVE.Stichera01.text = "Clement, in accordance with your name, * you became a branch of the true vine of life, Christ the Lord. * You produced mature and spiritual fruit, like grapes, * holy father, continually distilling the saving * wine of sacred teachings, leading to the knowledge of God, * gladdening the hearts of the faithful, * who sincerely praise and extol you, * O God-bearing and all-blessed hierarch."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode2
meVE.Stichera02.melody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.name
meVE.Stichera02.incipit = "You were a disciple…"
meVE.Stichera02.text = "You were a disciple of the Rock, * namely of preeminent Peter; and on his rock of faith, * you, O father, like a precious stone, established yourself. * With your words like a wrecking ball, O Saint, you demolished * paganism’s edifice, and you erected instead * churches to the Trinity’s glory. * For your faith in God you competed * and received the medals for your martyrdom."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode2
meVE.Stichera03.melody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.name
meVE.Stichera03.incipit = "Father, having risen…"
meVE.Stichera03.text = "Father, having risen from the west * like another radiant sun, you illumine all the earth * with the brilliant splendor of your sacred teachings and wounds. * When you reached the lands of the east, O thrice-blessed Clement, * you were put to death, and thus you set; and then you arose * once again to Christ; and receiving * by participation abundant * radiance from Him, you shine unceasingly."

meVE.Stichera04.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Stichera04.greekmelody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.greekname
meVE.Stichera04.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meVE.Stichera04.incipit = "O all-blessed Saint…"
meVE.Stichera04.text = "O all-blessed Saint, you defended the homoousion: * super-essential Triad as uncreated Monad. * You proved inseparability of the Son, * who with the Father and Spirit shares * the same divinity and in whom He inheres, * and you thus refuted Arius."

meVE.Stichera05.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Stichera05.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meVE.Stichera05.incipit = "The persecutors’ ferocious…"
meVE.Stichera05.text = "Your persecutors’ ferocious and deadly rage has ceased, * and the unholy bloodshed now is over and done with, * O wise father Peter, for both have been staunched * through your all-sacred martyrdom, * as Prophet Moses experienced long ago * when Zipporah circumcised their son."

meVE.Stichera06.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Stichera06.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meVE.Stichera06.incipit = "Having excelled as a pastor…"
meVE.Stichera06.text = "Having excelled as a pastor, O hieromartyr of Christ, * you demonstrated bravery competing as a martyr. * You were decorated for winning the race * of the priesthood and martyrdom, * being awarded a single medal for both. * Now implore the Lord to save our souls."

meVE.SticGlory.poet = poets_en_US_goadedes.po.Klimentos
