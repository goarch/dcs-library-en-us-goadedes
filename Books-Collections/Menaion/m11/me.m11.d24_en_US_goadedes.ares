meVE.Aposticha1.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Aposticha1.greekmelody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.greekname
meVE.Aposticha1.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meVE.Aposticha1.incipit = "Come, all you lovers…"
meVE.Aposticha1.text = "Come, all you lovers of feast days, and let us honor with hymns * the only pure, all-holy, ever-virgin Theotokos. * You virgins, bring your glowing processional lamps * and rejoicing accompany * the all-immaculate Virgin as she is brought * to the Temple of her Maker and God."

meVE.Aposticha2.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Aposticha2.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meVE.Aposticha2.incipit = "Now let the gates…"
meVE.Aposticha2.text = "Now let the gates be thrown opened. O virgins, holding your lamps, * faithfully greet the Virgin as she comes to the Temple, * She is the immaculate girl who will be * the Theotokos, the joy of all. * So with Elizabeth cry out, “Blessed are you * among women, virgin Mother of God!”"

meVE.Aposticha3.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Aposticha3.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meVE.Aposticha3.incipit = "Higher than all…"
meVE.Aposticha3.text = "Higher than all is the virgin, all-holy Mother of God. * The world knows that she is the illustrious offspring, * the answer to the prayer and the solemn vow * that her parents had made to God. * And they fulfilled it, presenting her to be kept * by the Spirit in the house of God."

