meMA.Ode3C11.ode = miscellanea_en_US_goadedes.misc.Ode3
meMA.Ode3C11.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Ode3C11.greekmelody = he.h.m6_en_US_goadedes.heHE.OukEstinAgios.greekname
meMA.Ode3C11.melody = he.h.m6_en_US_goadedes.heHE.OukEstinAgios.name
meMA.Ode3C11.incipit = "As you were filled…"
meMA.Ode3C11.text = "As you were filled with light from both * virtue and contemplation, * O inspired St. Philip, * you were granted to become * a faithful servant Christ, * the sublime Light, * who came down to be with us."

meMA.Ode3C12.ode = miscellanea_en_US_goadedes.misc.Ode3
meMA.Ode3C12.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Ode3C12.melody = he.h.m6_en_US_goadedes.heHE.OukEstinAgios.name
meMA.Ode3C12.incipit = "Your sacred teachings…"
meMA.Ode3C12.text = "Your sacred teachings laid the ground * for the Orthodox doctrines * that believers accepted, * O Apostle; for you taught * that the Father and the Son * are united * in nature eternally."

meMA.Ode3C13.ode = miscellanea_en_US_goadedes.misc.Ode3
meMA.Ode3C13.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Ode3C13.melody = he.h.m6_en_US_goadedes.heHE.OukEstinAgios.name
meMA.Ode3C13.incipit = "O splendid Philip…"
meMA.Ode3C13.text = "O splendid Philip, you became * like a lampstand of pure gold, * for you brought to the people * the divine eternal Light, * and with the knowledge of Christ * you enlightened * believers throughout the world."

meMA.Ode3C1T.ode = miscellanea_en_US_goadedes.misc.Ode3
meMA.Ode3C1T.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Ode3C1T.melody = he.h.m6_en_US_goadedes.heHE.OukEstinAgios.name
meMA.Ode3C1T.incipit = "All-holy Virgin…"
meMA.Ode3C1T.text = "All-holy Virgin, I rely * on your strong intervention * as the merciful Mother * of our benevolent God. * Do not deny me, I pray, * but release me * from snares of the enemy."

