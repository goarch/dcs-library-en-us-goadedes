meMA.Ode3KathismaT.mode = miscellanea_en_US_goadedes.misc.Mode8
meMA.Ode3KathismaT.melody = he.a.m8_en_US_goadedes.heAU.TinSofianKaiLogon.name
meMA.Ode3KathismaT.incipit = "By conceiving the Wisdom…"
meMA.Ode3KathismaT.text = "By conceiving the Wisdom and Word of God * in your womb without burning, O Mother of God, * for the world’s sake you carried Him who has the whole world in His hand, * and in your arms you held Him who holds up the universe, * which He provides with food, as the Maker of creation all. * Therefore, O all-holy Virgin Mary, I pray you: * When I am to stand before my Creator on Judgment Day, to be justly judged by Him, * quickly come my defense, and assist me, in your great benevolence. * I, your unworthy servant, have you as my only hope."

