meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode2
meVE.Stichera01.greekmelody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.greekname
meVE.Stichera01.melody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.name
meVE.Stichera01.incipit = "Moses, that renowned…"
meVE.Stichera01.text = "Moses, that renowned seer of God, * lifted up serpent of bronze on a pole to counteract * the venomous serpents' bites. And You, my Savior, for me * had yourself lifted on the tree, thereby vivifying * all humanity by Your divine and life-giving Cross. * As it is in our time exalted, * it burns up the hordes of the demons, * and it routs attacks of foreign enemies."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode2
meVE.Stichera02.melody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.name
meVE.Stichera02.incipit = "Savior, as the Son…"
meVE.Stichera02.text = "Savior, as the Son and Word of God, * You assumed humanity's nature, mortal and perishable, * from the Theotokos, making it imperishable. * To unending delight and life eternal You led it, * bringing back all people who with faith extol You, O Christ. * Master, You equip faithful leaders * with Your holy Cross as a mighty * shield in time of war against all enemies."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode2
meVE.Stichera03.melody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.name
meVE.Stichera03.incipit = "Savior, who were carried…"
meVE.Stichera03.text = "Savior, who were carried in the pure * womb of the all chaste Theotokos and virgin Mother of God, * shine Your unapproachable and holy light on us, * for the work of Your hands are we. We pray You, O Most High, * endow faithful leaders with the mighty shield of Your grace. * Grant them to prevail in all conflict * when they have Your Cross as a mighty * fortress and impenetrable battlement."

