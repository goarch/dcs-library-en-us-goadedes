meVE.Apolytikion1ger.poet = poets_en_US_goadedes.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Apolytikion1ger.greekmelody = he.a.m1_en_US_goadedes.heAU.TisErimouPolitis.greekname
meVE.Apolytikion1ger.melody = he.a.m1_en_US_goadedes.heAU.TisErimouPolitis.name
meVE.Apolytikion1ger.incipit = "O glorious Eustathius…"
meVE.Apolytikion1ger.text = "O glorious Eustathius, from above you were hunted * by Him who through a stag appeared and called you to true faith. * Enduring many tragedies and trials, * you triumphed and received divine awards, * reunited with your holy wife and your sons, * which gladdens us who sing to you. * Glory to Christ who glorified you! * Glory to Him who has rewarded you! * Glory to Him who showed you forth to be like righteous Job!"

meMA.Kathisma11.mode = miscellanea_en_US_goadedes.misc.Mode8
meMA.Kathisma11.greekmelody = he.a.m8_en_US_goadedes.heAU.AnestisEkNekron.greekname
meMA.Kathisma11.melody = he.a.m8_en_US_goadedes.heAU.AnestisEkNekron.name
meMA.Kathisma11.incipit = "A tree once blossomed…"
meMA.Kathisma11.text = "A tree once blossomed death in the middle of Eden. * The tree in the middle of the earth has produced life. * Tasting from the former, * we the incorrupt became corruptible, * whereas with the latter * we have delighted in incorruptibility. * For Christ our God has saved the human race * by means of His divine Cross."

