meSV.Stichera1.mode = miscellanea_en_US_goadedes.misc.Mode1
meSV.Stichera1.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meSV.Stichera1.incipit = "In giving birth…"
meSV.Stichera1.text = "In giving birth to their daughter, the only Mother of God, * the start of our salvation, both Joachim and Anna * make merry. And we also today joining them * celebrate this most sacred feast, * and we extol the pure Virgin and call her blest, * who from Jesse’s root has blossomed forth."

meSV.Stichera2.mode = miscellanea_en_US_goadedes.misc.Mode1
meSV.Stichera2.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meSV.Stichera2.incipit = "The Theotokos…"
meSV.Stichera2.text = "The Theotokos has come forth today, the God-given plant * and rod, from righteous Anna. And she is the salvation * of man, for the Creator of all will be * inconceivably born from her, * and He will purify Adam from sin and shame, * in His goodness as benevolent God."

meSV.Stichera3.mode = miscellanea_en_US_goadedes.misc.Mode1
meSV.Stichera3.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meSV.Stichera3.incipit = me.m09.d07_en_US_goadedes.meVE.Stichera03.incipit
meSV.Stichera3.text = me.m09.d07_en_US_goadedes.meVE.Stichera03.text

meSV.Stichera4.mode = miscellanea_en_US_goadedes.misc.Mode1
meSV.Stichera4.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meSV.Stichera4.incipit = "The barren field…"
meSV.Stichera4.text = "The barren field, namely Anna, has borne the fruitful ground, * and from her fruitless body, the holy fruit has come forth. * She nurses her who, wonder of wonders! in time * will become the nurse of our life. * She who will one day receive in her virgin womb * the celestial bread is nursed today."

