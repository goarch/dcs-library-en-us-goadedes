meVE.Stichera06.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Stichera06.melody = miscellanea_en_US_goadedes.misc.Idiomelon
meVE.Stichera06.incipit = "Today, Anna who was barren…"
meVE.Stichera06.text = "Today, Anna who was barren mothers the Mother of God, who from all generations was forechosen for Christ God, the Creator and King of all, to inhabit and fulfill the divine plan, by which we, born on earth, were refashioned and renewed, from death and destruction to never-ending life."

