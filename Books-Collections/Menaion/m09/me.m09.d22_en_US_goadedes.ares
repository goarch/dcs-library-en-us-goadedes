meVE.Stichera04.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Stichera04.greekmelody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.greekname
meVE.Stichera04.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meVE.Stichera04.incipit = "Eradicating the folly…"
meVE.Stichera04.text = "Eradicating the folly of idol worship, O Saint, * by your inspired preaching of the word, father Phocas, * you strengthened the unstable of heart in the faith, * and to life you directed them. * Having competed according to all the rules, * you were crowned a hieromartyr of Christ."

meVE.Stichera05.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Stichera05.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meVE.Stichera05.incipit = "Your sacred vestments…"
meVE.Stichera05.text = "Your sacred vestments were dyed in your sacred body's blood, * most sacred father Phocas, as a bishop and martyr. * For both you have received glowing halos from Christ, * O all-praiseworthy man of God. * And now you join the angelic chorus on high * and implore the Lord to save our souls."

meVE.Stichera06.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Stichera06.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meVE.Stichera06.incipit = "You have been given…"
meVE.Stichera06.text = "You have been given divine grace from Christ the Lord, O Saint, * and all the earth is brightened by the rays of your wonders. * Every day you help those who travel by sea, * and you cure every malady * of soul and body, for you have been truly blest, * father Phocas, hieromartyr of Christ."

