meMA.Ode3KathismaT.melody = he.a.m4_en_US_goadedes.heAU.TachyProkatalave.name
meMA.Ode3KathismaT.incipit = "Immaculate Virgin…"
meMA.Ode3KathismaT.text = "Immaculate Virgin, you are truly Mother of God * who is most benevolent. Join all the Angels and please * entreat Him unceasingly * that He forgive our sins and that He grant the amendment * of life before the end to us who rightly extol you * with faith, love, and longing, O only all-lauded one."

