meMA.Ode3Kathisma1.mode = miscellanea_en_US_goadedes.misc.Mode8
meMA.Ode3Kathisma1.greekmelody = he.a.m8_en_US_goadedes.heAU.ToProstachthen.greekname
meMA.Ode3Kathisma1.melody = he.a.m8_en_US_goadedes.heAU.ToProstachthen.name
meMA.Ode3Kathisma1.incipit = "The tent of meeting…"
meMA.Ode3Kathisma1.text = "The tent of meeting was shown by God to Moses * who then erected it on earth in the divine plan; * and with sacrifices Solomon dedicated the temple. * Like David, let us take refuge in the new * Jerusalem, yes the Church, with belief in Christ, * and extol Him with sacred hymns, for He was crucified for us, * imploring Him to grant to us * the forgiveness of all our sins."

meMA.Ode3Kathisma2.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode3Kathisma2.greekmelody = he.a.m4_en_US_goadedes.heAU.EpefanisSimeron.greekname
meMA.Ode3Kathisma2.melody = he.a.m4_en_US_goadedes.heAU.EpefanisSimeron.name
meMA.Ode3Kathisma2.incipit = "Lord, Your Cross…"
meMA.Ode3Kathisma2.text = "Lord, Your Cross like light shines forth, * and it disperses * all the dark and wicked hosts * and it brings joy into the souls * of all the faithful who sing aloud, * “The Cross is truly the boast of the universe!”"

meMA.Ode3Kathisma3.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode3Kathisma3.greekmelody = he.a.m4_en_US_goadedes.heAU.EpefanisSimeron.greekname
meMA.Ode3Kathisma3.melody = he.a.m4_en_US_goadedes.heAU.EpefanisSimeron.name
meMA.Ode3Kathisma3.incipit = "…"
meMA.Ode3Kathisma3.text = ""

