meVE.Stichera04.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera04.greekmelody = he.a.m4_en_US_goadedes.heAU.EdokasSimeiosin.greekname
meVE.Stichera04.melody = he.a.m4_en_US_goadedes.heAU.EdokasSimeiosin.name
meVE.Stichera04.incipit = "O blessed Cornelius…"
meVE.Stichera04.text = "O blessed Cornelius, your constant prayers and good works and alms * were accepted by Christ our God. * He sent you a heavenly Angel to instruct you. * The chief of Your sacred Apostles came into your home, * and through the water and Spirit he renewed * both you and your entire household, as Evangelist Luke relates, * by divine grace inducting you into heavenly mysteries."

meVE.Stichera05.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera05.melody = he.a.m4_en_US_goadedes.heAU.EdokasSimeiosin.name
meVE.Stichera05.incipit = "O Saint, you were vested…"
meVE.Stichera05.text = "O Saint, you were vested with the grace of priesthood, and you went forth * to the places where Gentiles lived * and preached to them the divine message of salvation, * uprooting deception like thorns and planting in its place * the Spirit's unerring teaching in their souls. * O God-inspired Hierarch, we now extol you and joyfully * call you blest, O invincible, holy Martyr Cornelius."

meVE.Stichera06.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera06.melody = he.a.m4_en_US_goadedes.heAU.EdokasSimeiosin.name
meVE.Stichera06.incipit = "When those lacking…"
meVE.Stichera06.text = "When those lacking understanding imitated your virtuous * way of life, O Cornelius, * they became most sensible. When you died, succumbing * to the laws of nature and you were buried in a tomb, * you made it spring forth with many miracles. * O God-inspired Saint, by the all-holy Spirit, you drove away * evil spirits and healed the sick, curing every infirmity."

