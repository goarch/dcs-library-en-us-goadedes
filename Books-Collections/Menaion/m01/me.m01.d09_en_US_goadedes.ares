meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera01.greekmelody = he.a.m8_en_US_goadedes.heAU.KyrieEiKaiKritirio.greekname
meVE.Stichera01.melody = he.a.m8_en_US_goadedes.heAU.KyrieEiKaiKritirio.name
meVE.Stichera01.incipit = "Lord, even though…"
meVE.Stichera01.text = "Lord, even though at the Jordan You were standing * as a human with the Forerunner, * still You were seated with the Father * on the throne, from which You never left. * And being baptized for us, * in Your divine benevolence, * You freed the world from the devil’s bondage, * as our Savior most compassionate."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera02.melody = he.a.m8_en_US_goadedes.heAU.KyrieEiKaiKritirio.name
meVE.Stichera02.incipit = "Lord, even though…"
meVE.Stichera02.text = "Lord, even though as a man You were surrounded * by the water of the Jordan’s streams, * from the heights the Spirit bore witness * when He descended and stayed on You. * The Father’s voice also confirmed * that You are His beloved Son. * Please reveal yourself to us and grant us * immortality, and save our souls."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera03.melody = he.a.m8_en_US_goadedes.heAU.KyrieEiKaiKritirio.name
meVE.Stichera03.incipit = "Lord, You were from…"
meVE.Stichera03.text = "Lord, You were from the Father before the ages * truly begotten unchangingly. * Now in latter times from the Virgin * You were born, taking a servant’s form, * and as Creator You renewed * Your image that You made us in. * Being baptized You have granted * to our souls immortality. "

