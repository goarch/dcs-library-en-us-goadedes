meVE.Aposticha1.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Aposticha1.greekmelody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.greekname
meVE.Aposticha1.melody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.name
meVE.Aposticha1.incipit = "O Lord, incompressible…"
meVE.Aposticha1.text = "O Lord, incompressible, * You came to River Jordan’s streams. * To the Baptist, You the Master bowed Your head, * sanctifying creation, * releasing us from bondage, * O sinless Jesus, by Your baptism."

meVE.Aposticha2.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Aposticha2.melody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.name
meVE.Aposticha2.incipit = "The Father from on high…"
meVE.Aposticha2.text = "The Father from on high testified * that You are His beloved Son, * and the Spirit bore witness to You, O Christ, * when You were in the Jordan, * baptized. And thus revealed was * the mystery of the Trinity."

meVE.Aposticha3.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Aposticha3.melody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.name
meVE.Aposticha3.incipit = "You sanctified…"
meVE.Aposticha3.text = "You sanctified the Jordan’s streams * and all the waters everywhere, * God our Savior, by Your baptism therein. * Humanity extols You. * And we are glorifying * and celebrating Your Epiphany."

