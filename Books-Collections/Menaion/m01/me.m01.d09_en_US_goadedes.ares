meMA.Exaposteilarion2.mode = miscellanea_en_US_goadedes.misc.Mode3
meMA.Exaposteilarion2.greekmelody = he.a.m3_en_US_goadedes.heAU.EnPnevmatiToIero.greekname
meMA.Exaposteilarion2.melody = he.a.m3_en_US_goadedes.heAU.EnPnevmatiToIero.name
meMA.Exaposteilarion2.incipit = "You came to us…"
meMA.Exaposteilarion2.text = "You came to us, O Logos, * in the form of a servant, * and You the timeless One * sought baptism as human. * Heaven and earth were amazed, * as were the hosts of Angels * as well as all the waters. * John the Forerunner trembled, * and although fearful he rejoiced * performing his sacred function."

meMA.Aposticha1.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Aposticha1.greekmelody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.greekname
meMA.Aposticha1.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Aposticha1.incipit = "Who is this…"
meMA.Aposticha1.text = "Who is this who cries in the wilderness, O Prophet: * “Come and draw the waters of gladness that will cleanse you”? * Explain it, O Isaiah; who is this who recites your words. * “This John the Forerunner and Baptist, * who in the wilderness is shouting, * ‘Messiah comes.’” * Blessed are You who have appeared; glory to You, our God!"

meMA.Aposticha2.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Aposticha2.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Aposticha2.incipit = "Astounding is the great…"
meMA.Aposticha2.text = "Astounding is the great and ineffable compassion! * Look how the Creator is coming to His creature, * inclining His immaculate divine head for baptism. * Glory be to Him who has appeared in the world and gave us life eternal. * In Him we sing, * “Blessed are You who have appeared; glory to You, our God!”"

meMA.Aposticha3.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Aposticha3.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Aposticha3.incipit = "Having put away…"
meMA.Aposticha3.text = "Having put away earthly things as being harmful, * let us purify all our thoughts and our senses; * and as we visualize Christ being baptized in His flesh * by St. John the Forerunner and Baptist, * let us join him crying out our praises * to God with faith, * “Blessed are You who have appeared; glory to You, our God!”"

meMA.AposGlory.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.AposGlory.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.AposGlory.incipit = "The baptismal grace…"
meMA.AposGlory.text = "The baptismal grace is a vivifying comfort * that poured out to us from that famous River Jordan. * As we have been illumined by our baptism, let us say, * “Glory be to Him who has appeared in the world and gave us life eternal. * In Him we sing, * Blessed are You who have appeared; glory to You, our God!”"

