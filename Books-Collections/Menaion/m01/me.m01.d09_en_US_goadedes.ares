meMA.Kathisma11.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Kathisma11.greekmelody = he.a.m4_en_US_goadedes.heAU.OYpsotheisEnToStavro.greekname
meMA.Kathisma11.melody = he.a.m4_en_US_goadedes.heAU.OYpsotheisEnToStavro.name
meMA.Kathisma11.incipit = "With Your compassion…"
meMA.Kathisma11.text = "With Your compassion importuning on our behalf, * You came to seek the lost and wandering sheep, O God, * in Your tender mercies, O benevolent Lord. * So it was that You were at the renowned River Jordan * to reveal the mystery of the Holy Trinity. * We now extol You and we sing to You with faith:* You came, revealing yourself, O unapproachable Light."

meMA.Kathisma21.mode = miscellanea_en_US_goadedes.misc.Mode8
meMA.Kathisma21.greekmelody = he.a.m8_en_US_goadedes.heAU.AnestisEkNekron.greekname
meMA.Kathisma21.melody = he.a.m8_en_US_goadedes.heAU.AnestisEkNekron.name
meMA.Kathisma21.incipit = "The Master of the universe…"
meMA.Kathisma21.text = "The Master of the universe revealed himself to us * in the waters of the Jordan River mystically, * to melt down all sin, for He is supremely good and merciful. * Let all creation greatly rejoice at the baptism of Christ our Lord, * who was well pleased to save the human race, as God our only Savior."

