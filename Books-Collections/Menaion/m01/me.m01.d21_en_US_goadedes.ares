meVE.Stichera04.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera04.greekmelody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.greekname
meVE.Stichera04.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
meVE.Stichera04.incipit = "This is amazing…"
meVE.Stichera04.text = "This is amazing and marvelous! * A dove came down from on high, * and it spoke with a human voice * to Martyr Neophytos, * and it led and encouraged him * to live alone as a youth angelically * and to compete as a martyr mightily. * Great and divine indeed * was the Martyr’s fivefold contest! By his prayers * save our souls, O Christ, as You are most compassionate."

meVE.Stichera05.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera05.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
meVE.Stichera05.incipit = "This is amazing…"
meVE.Stichera05.text = "This is amazing and marvelous! * For St. Neophytos * was mature from an early age. * By the Spirit’s energy, * he performed many miracles. * He prayed, and water came gushing from a stone; * he resurrected his mother when she died. * Great and divine indeed * was the Martyr’s fivefold contest! By his prayers * save our souls, O Christ, as You are most compassionate."

meVE.Stichera06.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera06.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
meVE.Stichera06.incipit = "This is amazing…"
meVE.Stichera06.text = "This is amazing and marvelous! * As he was martyred for Christ, * brave and fearless Neophytos * astonished the enemies * with his marvelous miracles. * He doused the fire into which he was cast. * He made untamed beasts cower in fear of him. * He was invincible * and a wondrous Athlete by the might of Christ. * Hear his prayers on our behalf, O God, and save our souls."

