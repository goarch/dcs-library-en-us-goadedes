meVE.SticTheotokion.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.SticTheotokion.greekmelody = he.a.m6_en_US_goadedes.heAU.OlinApothemenoi.greekname
meVE.SticTheotokion.melody = he.a.m6_en_US_goadedes.heAU.OlinApothemenoi.name
meVE.SticTheotokion.incipit = "From the belly of the whale…"
meVE.SticTheotokion.text = "From the belly of the whale of wicked sins extricate me, * O all-holy Mother, who in your belly held Him whom nothing can contain. * Rescue me from the storm of raging temptations. * From the tempest of my trespasses * Lady, deliver me; * and dry up the sea of iniquities, * within which I am wallowing; * and obliterate the demonic hosts, * that always assault me, for you are my protection and defense, * and I will ceaselessly glorify you, all-blessed Virgin pure."

