meMA.Ode3KathismaT.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode3KathismaT.melody = he.a.m4_en_US_goadedes.heAU.OYpsotheisEnToStavro.name
meMA.Ode3KathismaT.incipit = "Second to God alone…"
meMA.Ode3KathismaT.text = "Second to God alone, to your holy shelter * I who am lowly run, O pure Theotokos. * And I beseech you earnestly: Have mercy on me, * for my sins have risen up over my head, blessed Lady, * and I fear and shudder at the thought of perdition. * I pray you make entreaties to your Son, * that He deliver * and save me from such a end."

