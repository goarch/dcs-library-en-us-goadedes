meMA.Exaposteilarion2.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Exaposteilarion2.greekmelody = he.a.m2_en_US_goadedes.heAU.ToisMathitaisSynelthomen.greekname
meMA.Exaposteilarion2.melody = he.a.m2_en_US_goadedes.heAU.ToisMathitaisSynelthomen.name
meMA.Exaposteilarion2.incipit = "Glorious St. Neophytos…"
meMA.Exaposteilarion2.text = "Glorious St. Neophytos, * you did a wondrous marvel * by resurrecting from the dead * your mother, demonstrating yourself to be a great servant * of Christ, near whom you stand now * wearing your crown, O godly Saint. * Please persist interceding on the behalf * of us who extol you and who are keeping * your illustrious memory, * O victorious Martyr."

