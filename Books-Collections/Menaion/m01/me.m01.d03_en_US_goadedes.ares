meMA.Exaposteilarion1.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Exaposteilarion1.greekmelody = he.a.m2_en_US_goadedes.heAU.GynaikesAkoutisthite.greekname
meMA.Exaposteilarion1.melody = he.a.m2_en_US_goadedes.heAU.GynaikesAkoutisthite.name
meMA.Exaposteilarion1.incipit = "…"
meMA.Exaposteilarion1.text = ""

meMA.Exaposteilarion2.mode = miscellanea_en_US_goadedes.misc.Mode3
meMA.Exaposteilarion2.greekmelody = he.a.m3_en_US_goadedes.heAU.EnPnevmatiToIero.greekname
meMA.Exaposteilarion2.melody = he.a.m3_en_US_goadedes.heAU.EnPnevmatiToIero.name
meMA.Exaposteilarion2.incipit = "Having seen in Bethlehem…"
meMA.Exaposteilarion2.text = "Having seen in Bethlehem the amazing new wonder, * with soulful ardor let us now go to the Jordan River, * and there we shall be witnesses of the awesome mystery; * for with godly dignity, my Christ has stripped himself for me, * and He has clothed me in the robe of the heavenly Kingdom."

meMA.Lauds1.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Lauds1.greekmelody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.greekname
meMA.Lauds1.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Lauds1.incipit = "Heaven is the throne…"
meMA.Lauds1.text = "Heaven is the throne that He sits upon as Master. * He came down to earth now incarnate of the Virgin. * And at the Jordan River, He requests of the Baptist John * all humanity’s purification. * Let us the tribes and all the families * of earth sing to Him, * “Blessed are You who have appeared; glory to You, our God!”"

meMA.Lauds2.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Lauds2.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Lauds2.incipit = "Christ has now arrived…"
meMA.Lauds2.text = "Christ has now arrived at the waters of the Jordan. * He who washes sins is requesting to be baptized. * Let all the earth rejoice now with the heavens exultantly. * Celebrate, O Church of the Gentiles, * for to the King you have been wedded, * and faithfully sing, * “Blessed are You who have appeared; glory to You, our God!”"

meMA.Lauds3.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Lauds3.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Lauds3.incipit = "Mountains, drip…"
meMA.Lauds3.text = "Mountains, drip your sweet wine of joy, and you, O Nations, * clap your hands, and mystically blossom, O you desert, * as holy Prophets uttered. River Jordan, now welcome Christ. * Baptist, come and joyfully assist with * the sacrament of the Redeemer. * Let all people sing, * “Blessed are You who have appeared; glory to You, our God!”"

meMA.Lauds4.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Lauds4.greekmelody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.greekname
meMA.Lauds4.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Lauds4.incipit = "Light from Light…"
meMA.Lauds4.text = "Light from Light, He shone forth before all time and ages. * He appeared to those sitting in the night and shadow, * and He has purged the darkness of our sins and has made us clean. * Adam, dance for joy, and Eve, be happy. * For Christ has come for your redemption. * O David, shout, * “Blessed are You who have appeared; glory to You, our God!”"

meMA.LaudsGlory.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.LaudsGlory.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.LaudsGlory.incipit = "Jacob’s Star…"
meMA.LaudsGlory.text = "Jacob’s Star has shone on the world with divine splendor, * taking on himself all the flaming sin of mankind; * and in the Jordan River He has mystically buried it. * Shining with the radiance of Godhead, * He gives the light of godly knowledge * to Nations all. * “Blessed are You who have appeared; glory to You, our God!”"

meMA.LaudsBoth.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.LaudsBoth.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.LaudsBoth.incipit = "Coming in the flesh…"
meMA.LaudsBoth.text = "Coming in the flesh, Christ fulfilled the Law’s commandments. * Wishing to begin to accomplish our salvation, * He comes now to the Jordan. The compassionate Lord of all, * bows His holy head before the Baptist, * who cries out as a faithful servant, * “All people, sing: * ‘Blessed are You who have appeared; glory to You, our God!’”"

meMA.Aposticha1.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Aposticha1.greekmelody = he.a.m2_en_US_goadedes.heAU.OikosTouEfratha.greekname
meMA.Aposticha1.melody = he.a.m2_en_US_goadedes.heAU.OikosTouEfratha.name
meMA.Aposticha1.incipit = "Let us from Bethlehem…"
meMA.Aposticha1.text = "Let us from Bethlehem * go to the River Jordan, * for the illumination. * On those who lay in darkness the true light has begun to shine."

meMA.Aposticha2.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Aposticha2.melody = he.a.m2_en_US_goadedes.heAU.OikosTouEfratha.name
meMA.Aposticha2.incipit = "Hear, land of Zebulun…"
meMA.Aposticha2.text = "Hear, land of Zebulun, * and you across the Jordan, * listen, for our salvation * is coming, Jesus Christ, who is light and who redeems the world."

meMA.Aposticha3.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Aposticha3.melody = he.a.m2_en_US_goadedes.heAU.OikosTouEfratha.name
meMA.Aposticha3.incipit = "Make ready…"
meMA.Aposticha3.text = "Make ready and prepare * your stream, O Jordan River, * for the One who baptizes with fire is at hand to repair His damaged masterpiece."

meMA.AposGlory.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.AposGlory.melody = he.a.m2_en_US_goadedes.heAU.OikosTouEfratha.name
meMA.AposGlory.incipit = "Now in the Jordan’s streams…"
meMA.AposGlory.text = "Now in the Jordan’s streams * has Jesus, the reflection * of God the Father’s glory, * appeared to cleanse our souls of impurity through baptism."

meLI.Kontakion1.mode = me.m01.d03_en_US_goadedes.meMA.Kontakion1.mode
meLI.Kontakion1.greekmelody = me.m01.d03_en_US_goadedes.meMA.Kontakion1.greekmelody
meLI.Kontakion1.melody = me.m01.d03_en_US_goadedes.meMA.Kontakion1.melody
