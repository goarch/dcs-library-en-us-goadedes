meVE.Aposticha1.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Aposticha1.greekmelody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.greekname
meVE.Aposticha1.melody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.name
meVE.Aposticha1.incipit = "Behold, our expiation…"
meVE.Aposticha1.text = "Behold, our expiation has come! * Behold, illumination for us * the believers! To the Jordan Jesus goes * to cleanse our human nature * of every stain of sin, and since we were damaged to refashion us."

meVE.Aposticha2.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Aposticha2.melody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.name
meVE.Aposticha2.incipit = "O Master…"
meVE.Aposticha2.text = "O Master, when Your Forerunner saw * You coming to him and he heard * You requesting that He be baptized by him, * with fear and trepidation * he said, “My God and Maker how can I baptize You, the sinless One?”"

meVE.Aposticha3.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Aposticha3.melody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.name
meVE.Aposticha3.incipit = "O faithful…"
meVE.Aposticha3.text = "O faithful, let us mentally * assemble at the Jordan’s streams * and imagine that most wondrous spectacle. * The Creator of all things * is going to be baptized, having appeared in His epiphany."

meVE.AposGlory.poet = poets_en_US_goadedes.po.Vyzantiou
meVE.AposGlory.mode = miscellanea_en_US_goadedes.misc.Mode5
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "To the River Jordan…"
meVE.AposGlory.text = "To the River Jordan Christ our God is coming to be baptized, wishing by His epiphany to cleanse us from our iniquities, as the only good and benevolent Lord."

