meCO.Ode8C21.ode = miscellanea_en_US_goadedes.misc.Ode8
meCO.Ode8C21.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode8C21.melody = he.h.m6_en_US_goadedes.heHE.StilinKakiasTouDeinou.notmetered
meCO.Ode8C21.incipit = "O believers, let us shake off …"
meCO.Ode8C21.text = "O believers, let us shake off the sleep of wickedness from the eyelids of our souls, and let us remove the evils from our hearts, and with ardent tears let us wash our minds, that we may be seen as viewers of Him who has appeared, and glorify Christ unto the ages."

meCO.Ode8C22.ode = miscellanea_en_US_goadedes.misc.Ode8
meCO.Ode8C22.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode8C22.melody = he.h.m6_en_US_goadedes.heHE.StilinKakiasTouDeinou.notmetered
meCO.Ode8C22.incipit = "Let us not quote unholy writings…"
meCO.Ode8C22.text = "Let us not quote unholy writings with their profane ideas, but only study the word of God, and with sacred hymns approach the Word, who for us appeared in flesh and enlightens those in darkness. All creation blesses Him and glorifies Him unto the ages."

meCO.Ode8C23.ode = miscellanea_en_US_goadedes.misc.Ode8
meCO.Ode8C23.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode8C23.melody = he.h.m6_en_US_goadedes.heHE.StilinKakiasTouDeinou.notmetered
meCO.Ode8C23.incipit = "To mortals now appears…"
meCO.Ode8C23.text = "To mortals now appears the hidden mystery of profound wisdom, to believers now is revealed the ocean of God’s judgements, since God appeared physically on earth, to refashion the human race. All creation blessed Him and glorifies Him unto the ages."

meCO.Ode8C24.ode = miscellanea_en_US_goadedes.misc.Ode8
meCO.Ode8C24.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode8C24.melody = he.h.m6_en_US_goadedes.heHE.StilinKakiasTouDeinou.notmetered
meCO.Ode8C24.incipit = "The Master said…"
meCO.Ode8C24.text = "The Master said to His servant, “John, you refuse to baptize me, but you will do it now out of obedience. Let it be so now; for thus it is fitting for us to fulfil all righteousness.” All creation blessed Him and glorifies Him unto the ages."

meCO.Ode8C2H.ode = miscellanea_en_US_goadedes.misc.Ode8
