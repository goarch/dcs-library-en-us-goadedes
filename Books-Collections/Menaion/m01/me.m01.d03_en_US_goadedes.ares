meCO.Ode9C21.ode = miscellanea_en_US_goadedes.misc.Ode9
meCO.Ode9C21.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode9C21.melody = he.h.m6_en_US_goadedes.heHE.TinTimioteran.notmetered
meCO.Ode9C21.incipit = "In order to remedy…"
meCO.Ode9C21.text = "In order to remedy Adam’s ruinous fall, new Adam has now appeared; and He is wondrously granting the freedom of regeneration through Baptism."

meCO.Ode9C22.ode = miscellanea_en_US_goadedes.misc.Ode9
meCO.Ode9C22.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode9C22.melody = he.h.m6_en_US_goadedes.heHE.TinTimioteran.notmetered
meCO.Ode9C22.incipit = "Fulfilling the Law…"
meCO.Ode9C22.text = "Fulfilling the Law and the Prophets, and also to fulfil all righteousness, the Savior of all is now permits His servant to lay his hand on His head, as He snatches humanity from servitude to the foe."

meCO.Ode9C23.ode = miscellanea_en_US_goadedes.misc.Ode9
meCO.Ode9C23.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode9C23.melody = he.h.m6_en_US_goadedes.heHE.TinTimioteran.notmetered
meCO.Ode9C23.incipit = "For the Gentiles…"
meCO.Ode9C23.text = "For the Gentiles a great light has shone. For those in darkness divine sunlight has emerged. Christ the Sun of glory has dawned for those who were sitting in the shadow of death."

meCO.Ode9C24.ode = miscellanea_en_US_goadedes.misc.Ode9
meCO.Ode9C24.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode9C24.melody = he.h.m6_en_US_goadedes.heHE.TinTimioteran.notmetered
meCO.Ode9C24.incipit = "The armies of Angels…"
meCO.Ode9C24.text = "The armies of Angels surrounded the Redeemer as He was being baptized in the Jordan. With trembling they extolled the great mystery of His ineffable condescension."

meCO.Ode9C2H.ode = miscellanea_en_US_goadedes.misc.Ode9
meCO.Ode9C2H.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode9C2H.melody = he.h.m6_en_US_goadedes.heHE.TinTimioteran.melody
meCO.Ode9C2H.incipit = he.h.m6_en_US_goadedes.heHE.TinTimioteran.incipit
meCO.Ode9C2H.text = he.h.m6_en_US_goadedes.heHE.TinTimioteran.text

meMA.Kathisma11.mode = miscellanea_en_US_goadedes.misc.Mode3
meMA.Kathisma11.greekmelody = he.a.m3_en_US_goadedes.heAU.TinOraiotita.greekname
meMA.Kathisma11.melody = he.a.m3_en_US_goadedes.heAU.TinOraiotita.name
meMA.Kathisma11.incipit = "Uncircumscribed is He…"
meMA.Kathisma11.text = "Uncircumscribed is He in His divinity, * yet circumscribed in His corporeality; * and He is coming to be baptized in the River Jordan. * Come, let us receive the Lord with contemplative purity, * for He wishes to effect the renewal of everyone. * To Him let us with fear therefore cry out, * “Glory to Your epiphany, O Christ!”"

meMA.Kathisma12.mode = miscellanea_en_US_goadedes.misc.Mode3
meMA.Kathisma12.greekmelody = he.a.m3_en_US_goadedes.heAU.TinOraiotita.greekname
meMA.Kathisma12.melody = he.a.m3_en_US_goadedes.heAU.TinOraiotita.name
meMA.Kathisma12.incipit = "At Your epiphany…"
meMA.Kathisma12.text = "At Your epiphany at River Jordan, O Lord, * when You were physically baptized therein by John, * the hosts of Angels were amazed, O Master of all creation, * seeing You, O Savior, stand near Your servant and speak to Him. * And the unoriginate heavenly Father bore witness to You. * And therefore with great joy we cry out to You: * Glory to Your epiphany, O Christ!"

meMA.Kathisma21.mode = miscellanea_en_US_goadedes.misc.Mode5
meMA.Kathisma21.greekmelody = he.a.m5_en_US_goadedes.heAU.TonSynanarchonLogon.greekname
meMA.Kathisma21.melody = he.a.m5_en_US_goadedes.heAU.TonSynanarchonLogon.name
meMA.Kathisma21.incipit = "As the Father…"
meMA.Kathisma21.text = "As the Father and Spirit are one in dignity, * so the Word, now incarnate and baptized for our sake. * As the hosts of Angels witnessed this, they trembled in awe. * When the Jordan River sensed its Creator enter it, * with fear and reverence it turned back, * and to heights of salvation * lifted us who fell into passions of old."

meMA.Kathisma22.mode = miscellanea_en_US_goadedes.misc.Mode5
meMA.Kathisma22.greekmelody = he.a.m5_en_US_goadedes.heAU.TonSynanarchonLogon.greekname
meMA.Kathisma22.melody = he.a.m5_en_US_goadedes.heAU.TonSynanarchonLogon.name
meMA.Kathisma22.incipit = "As the Father and Spirit…"
meMA.Kathisma22.text = "As the Father and Spirit are unoriginate, * so the Word, who with mercy assumed our human form. * He is going to the Jordan to be baptized for us. * Let us welcome Him with joy, having purified our thoughts, * and let us say, “Christ our Savior * and Benefactor, You are blessed, * for You have come to sanctify us!”"

