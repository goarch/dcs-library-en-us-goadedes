meCO.Ode5C21.ode = miscellanea_en_US_goadedes.misc.Ode5
meCO.Ode5C21.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode5C21.melody = he.h.m6_en_US_goadedes.heHE.ProsSeOrthrizoEpiphany.notmetered
meCO.Ode5C21.incipit = "Come, all believers…"
meCO.Ode5C21.text = "Come, all believers, let us first cleanse and purify our minds and hearts; then, participating in the awesome plan for our salvation, let us meet Christ as He comes to the River Jordan to purify us. "

meCO.Ode5C22.ode = miscellanea_en_US_goadedes.misc.Ode5
meCO.Ode5C22.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode5C22.melody = he.h.m6_en_US_goadedes.heHE.ProsSeOrthrizoEpiphany.notmetered
meCO.Ode5C22.incipit = "O friends, now you see him…"
meCO.Ode5C22.text = "O friends, now you see him, the voice of the Logos, the lamp of the Sun, the friend of the Bridegroom, as he cries out to the people, “Repent, and hasten to be purified before meeting the Creator.”"

