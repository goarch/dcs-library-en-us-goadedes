meCO.Ode5C2H.ode = miscellanea_en_US_goadedes.misc.Ode5
meCO.Ode5C2H.mode = miscellanea_en_US_goadedes.misc.Mode6
meCO.Ode5C2H.melody = he.h.m6_en_US_goadedes.heHE.ProsSeOrthrizoEpiphany.melody
meCO.Ode5C2H.incipit = he.h.m6_en_US_goadedes.heHE.ProsSeOrthrizoEpiphany.incipit
