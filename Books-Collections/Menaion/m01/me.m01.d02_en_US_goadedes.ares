meMA.Oikos1.text = ""

meMA.Kontakion2.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Kontakion2.greekmelody = he.a.m2_en_US_goadedes.heAU.TaAnoZiton.greekname
meMA.Kontakion2.melody = he.a.m2_en_US_goadedes.heAU.TaAnoZiton.name
meMA.Kontakion2.incipit = "Your mouth being filled…"
meMA.Kontakion2.text = "Your mouth being filled with wisdom that comes from God * you declared to us the knowledge of the Trinity. * O Silvester, you brought down the tyrants’ ungodliness, * with the sling of your God-inspired words * And now implore the Master on our behalf."

meMA.Oikos2.text = "Endowed with the episcopal seat of the paramount Apostle Peter, you were a marvelous minister of God, beautifying, strengthening, and magnifying the Church with your divine doctrines. Radiating like a star, and shining with the light of virtue, you teach that the Trinity should be worshiped as one indivisible Godhead. And you banished the heresies of the enemies. And now implore the Master on our behalf."

