meMA.Ode3Kathisma2.mode = miscellanea_en_US_goadedes.misc.Mode8
meMA.Ode3Kathisma2.greekmelody = he.a.m8_en_US_goadedes.heAU.AnestisEkNekron.greekname
meMA.Ode3Kathisma2.melody = he.a.m8_en_US_goadedes.heAU.AnestisEkNekron.notmetered
meMA.Ode3Kathisma2.incipit = "Invisible God…"
meMA.Ode3Kathisma2.text = "Invisible God, incomprehensible Logos, You were begotten of the Father in a manner passing nature and reason. Again, in later times, You were born of the Virgin, without altering what You were. Now You come to the River Jordan to be baptized in the flesh, as God who was well pleased to save the human race."

