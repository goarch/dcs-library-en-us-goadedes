meCO.Ode9C21.ode = miscellanea_en_US_goadedes.misc.Ode9
meCO.Ode9C21.mode = miscellanea_en_US_goadedes.misc.Mode2
meCO.Ode9C21.melody = he.h.m2_en_US_goadedes.heHE.ITonAchoritonTheon.notmetered
meCO.Ode9C21.incipit = "Let us cast aside…"
meCO.Ode9C21.text = "Let us cast aside the heavy stain of sin, and let us appear clean to the Master who purifies all in divine waters."

meCO.Ode9C22.ode = miscellanea_en_US_goadedes.misc.Ode9
meCO.Ode9C22.mode = miscellanea_en_US_goadedes.misc.Mode2
meCO.Ode9C22.melody = he.h.m2_en_US_goadedes.heHE.ITonAchoritonTheon.notmetered
meCO.Ode9C22.incipit = "Having purified ourselves…"
meCO.Ode9C22.text = "Having purified ourselves with streams of tears, come, let us now approach Christ, who has come to be baptized in the River Jordan."

meCO.Ode9C23.ode = miscellanea_en_US_goadedes.misc.Ode9
meCO.Ode9C23.mode = miscellanea_en_US_goadedes.misc.Mode2
meCO.Ode9C23.melody = he.h.m2_en_US_goadedes.heHE.ITonAchoritonTheon.notmetered
meCO.Ode9C23.incipit = "O Savior, we celebrated…"
meCO.Ode9C23.text = "O Savior, we celebrated Your Nativity with the Magi and the Shepherds. Accept us now, as we honor You who come to be baptized. "

meCO.Ode9C2H.ode = miscellanea_en_US_goadedes.misc.Ode9
meCO.Ode9C2H.mode = miscellanea_en_US_goadedes.misc.Mode2
meCO.Ode9C2H.melody = he.h.m2_en_US_goadedes.heHE.ITonAchoritonTheon.melody
meCO.Ode9C2H.incipit = he.h.m2_en_US_goadedes.heHE.ITonAchoritonTheon.incipit
meCO.Ode9C2H.text = he.h.m2_en_US_goadedes.heHE.ITonAchoritonTheon.text

meMA.Kathisma11.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Kathisma11.greekmelody = he.a.m1_en_US_goadedes.heAU.TonTafonSouSotir.greekname
meMA.Kathisma11.melody = he.a.m1_en_US_goadedes.heAU.TonTafonSouSotir.name
meMA.Kathisma11.incipit = "O Jesus, You put on…"
meMA.Kathisma11.text = "O Jesus, You put on my impoverished nature. * You came and lived among Your own servants, O Master, * exceedingly good, and You asked Your servant to baptize You. * When he saw You come, the Baptist John humbly uttered, * “You are free of stain, therefore how shall I baptize You, * my God most benevolent?”"

meMA.Kathisma12.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Kathisma12.greekmelody = he.a.m1_en_US_goadedes.heAU.TonTafonSouSotir.greekname
meMA.Kathisma12.melody = he.a.m1_en_US_goadedes.heAU.TonTafonSouSotir.name
meMA.Kathisma12.incipit = "Christ is about to come…"
meMA.Kathisma12.text = "Christ is about to come to the Jordan River, * within the streams of which He will truly accomplish * our nature’s refashioning, by the grace that is His as God. * Holy Forerunner, rejoice as you now receive Him, * Do as He so wills, as He commands You to wash Him, * the only benevolent Lord."

meMA.Kathisma21.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Kathisma21.greekmelody = he.a.m4_en_US_goadedes.heAU.TachyProkatalave.greekname
meMA.Kathisma21.melody = he.a.m4_en_US_goadedes.heAU.TachyProkatalave.name
meMA.Kathisma21.incipit = "Desiring to make us rich…"
meMA.Kathisma21.text = "Desiring to make us rich — for we had made ourselves poor * because of our unrestraint — our gracious Lord who is rich * has made himself poor for us. * He is going to stand in the River Jordan, requesting * publicly to be baptized there by John in its waters. * O believers, let us extol His utmost humility."

meMA.Kathisma22.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Kathisma22.greekmelody = he.a.m4_en_US_goadedes.heAU.TachyProkatalave.greekname
meMA.Kathisma22.melody = he.a.m4_en_US_goadedes.heAU.TachyProkatalave.name
meMA.Kathisma22.incipit = "The Prophet Isaiah’s words…"
meMA.Kathisma22.text = "The Prophet Isaiah’s words have come to pass today. * “A voice cries: ‘In the wilderness prepare the way of the Lord. * For God make a highway straight.’” * As he said, John the Baptist, the trumpet of the desert, * has sounded, and he is calling all the people to repentance. * Come and let us go to see this marvelous spectacle."

