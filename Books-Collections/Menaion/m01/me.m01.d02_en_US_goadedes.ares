meVE.SticGlory.poet = poets_en_US_goadedes.po.Vyzantiou
meVE.SticGlory.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.SticGlory.melody = ""
meVE.SticGlory.incipit = "Christ, the truth…"
meVE.SticGlory.text = "Christ, the truth, comes to the Jordan, to be baptized by John, who says to Him, “It is I who need to be baptized by You. And You come to me? I who am grass do not dare to touch You, the fire. Sanctify me, O Lord, in Your divine epiphany.”"

