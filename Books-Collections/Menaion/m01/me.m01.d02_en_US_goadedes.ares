meMA.Lauds3.text = ""

meMA.Lauds4.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Lauds4.greekmelody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.greekname
meMA.Lauds4.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Lauds4.incipit = "…"
meMA.Lauds4.text = ""

meMA.LaudsGlory.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.LaudsGlory.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.LaudsGlory.incipit = "Hesitant to touch You…"
meMA.LaudsGlory.text = "Hesitant to touch You was John, his hand atremble; * yet his soul rejoiced, for he understood Your purpose, * that You put on the form of a servant and bowed Your head, * as was Your good pleasure, to release us * from our servitude to the devil. * We cry out to You: * Blessed are You, the One who came; glory to You, our God!"

meMA.LaudsBoth.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.LaudsBoth.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.LaudsBoth.incipit = "Mystically rejoice…"
meMA.LaudsBoth.text = "Mystically rejoice, all the earth, as it is written! * Let the mountains skip now, as sang the Prophet David! * O River Jordan, turn back your current prophetically! * Tremble in the presence of the Master! * For God became incarnate, coming * to wash away * from all humanity the sin of Adam our ancestor."

