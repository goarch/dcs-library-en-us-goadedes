meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera01.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera01.incipit = "In preparing to celebrate…"
meVE.Stichera01.text = "In preparing to celebrate the illustrious baptism * of our God and Lord, let us sing forefestal hymns. * For now, incarnate, He makes His way as man to His Forerunner, * the all-holy Baptist John, * to request He receive from him saving baptism, * so that all who believe may be illumined and receive the Holy Spirit * and be reborn sacramentally."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera02.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera02.incipit = "Long ago, Prophet David…"
meVE.Stichera02.text = "Long ago, Prophet David said that our God will come openly * and reveal himself. And now Christ is publicly * showing himself to the world, as He approaches His servant John, * seeking baptism from him. * River Jordan, be filled with joy. Also earth and sea * and the hills and the mountains, skip and tremble. And the hearts of all believers, * exult, receiving the noetic light."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera03.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera03.incipit = "O almighty One…"
meVE.Stichera03.text = "O almighty One, You are known as the river of peace and as * the abundant water of heavenly delight. * Therefore we marvel how You went down naked into Jordan’s streams, * which accepted You, O Lord, * who have covered heaven with clouds, as the Psalmist said, * and stripped naked the foe of all his evil, and have clothed in incorruption * all those on earth who believe in You."

