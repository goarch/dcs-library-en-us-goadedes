meMA.Exaposteilarion1.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Exaposteilarion1.greekmelody = he.a.m2_en_US_goadedes.heAU.GynaikesAkoutisthite.greekname
meMA.Exaposteilarion1.melody = he.a.m2_en_US_goadedes.heAU.GynaikesAkoutisthite.name
meMA.Exaposteilarion1.incipit = "O voice of one who cries…"
meMA.Exaposteilarion1.text = "O voice of one who cries, cry out! You hills and mountains, skip like rams! * Celebrate, O human nature, for the pre-eternal Logos * has taken flesh, becoming man. He comes now seeking baptism * in River Jordan by the hands * that He himself had created, * to undo the world’s transgression."

meMA.Exaposteilarion2.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Exaposteilarion2.greekmelody = he.a.m2_en_US_goadedes.heAU.GynaikesAkoutisthite.greekname
meMA.Exaposteilarion2.melody = he.a.m2_en_US_goadedes.heAU.GynaikesAkoutisthite.name
meMA.Exaposteilarion2.incipit = "Amazing, how the river…"
meMA.Exaposteilarion2.text = "Amazing, how the river has received You in its streams, O Word, * who brought all the seas and rivers * to being from non-existence, * and also how the Forerunner has dared to lay his hand on Your * immaculate head, O Master! * Benevolent Lord, astounded, * we praise Your poverty’s grandeur."

