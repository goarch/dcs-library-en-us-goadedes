meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode2
meVE.Stichera01.greekmelody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.greekname
meVE.Stichera01.melody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.name
meVE.Stichera01.incipit = "Christians, with a pure…"
meVE.Stichera01.text = "Christians, with a pure and focused mind * let us sing our post-festal praises of the baptism of Christ. * He who with the Father and the Spirit ever exists * in His nature as God, has now as man in the body * come to River Jordan’s banks, and He is saying to John, * You, O Baptist, come and baptize Me. * For I wish to cleanse human nature * of the filth of sin, in My benevolence."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode2
meVE.Stichera02.melody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.name
meVE.Stichera02.incipit = "All the hosts of Angels…"
meVE.Stichera02.text = "“All the hosts of Angels in the heights * minister with fear and with trembling to You their King and God. * Cherubim dare not lift up their eyes to gaze at You. * O my Lord, yet You order me to touch Your divine head, * even though I am but grass; and I am gripped with fear, * lest I be consumed by the fire * of Your awesome Godhead, O Master.” * So said John the Forerunner to Christ our God."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode2
meVE.Stichera03.melody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.name
meVE.Stichera03.incipit = "Incarnate of a Virgin…"
meVE.Stichera03.text = "“Incarnate of a Virgin, I have come * to the Jordan River, today,” answered our Redeemer and God * to the Forerunner. “For I wish to refashion herein * fallen Adam. So John, now come to Me, the Messiah, * and baptize Me in the flesh, which I assumed for this * and to crush the heads of the dragons * lurking there, for I am the One who * takes away the sins of the world, as Lord.”"

meVE.Stichera04.mode = miscellanea_en_US_goadedes.misc.Mode2
meVE.Stichera04.greekmelody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.greekname
