meMA.Aposticha1.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Aposticha1.greekmelody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.greekname
meMA.Aposticha1.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Aposticha1.incipit = "Light from light are You…"
meMA.Aposticha1.text = "Light from light are You, O my Jesus, who enlightened * us all by Your ineffable illumination. * For long ago in Eden by the serpent were we made blind. * But now with You at the River Jordan, * we are seeing light in Your divine light * and faithfully sing, * “Blessed are You who have appeared; glory to You, our God!”"

meMA.Aposticha2.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Aposticha2.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Aposticha2.incipit = "Forerunner of joy…"
meMA.Aposticha2.text = "Forerunner of joy, and the steward of the myst’ries * that were shown to you, and eyewitness of the Spirit, * entreat the Logos, whose will was that He be baptized by you, * praying that He always grant forgiveness * of sins to us His faithful servants * who sing to Him, * “Blessed are You who have appeared; glory to You, our God!”"

meMA.Aposticha3.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Aposticha3.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Aposticha3.incipit = "Let us lift our hearts…"
meMA.Aposticha3.text = "Let us lift our hearts, O believers, and imagine * running to the Jordan to witness what occurred there. * And we shall see our Maker in the flesh being baptized by * John the holy Forerunner, who leads us * in glorifying God our Savior, * to whom we sing, * “Blessed are You who have appeared; glory to You, our God!”"

meMA.AposGlory.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.AposGlory.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.AposGlory.incipit = "Astounding is God’s divine plan…"
meMA.AposGlory.text = "Astounding is God’s divine plan for our salvation! * Look how the Creator is standing with His creature * and bows His head before him, demonstrating humility! * By His own example He instructs us, * whose minds and souls are being illumined. * And therefore we sing, * “Blessed are You who have appeared; glory to You, our God!”"

