meVE.Aposticha1.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Aposticha1.greekmelody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.greekname
meVE.Aposticha1.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meVE.Aposticha1.incipit = "Let us praise the Lord…"
meVE.Aposticha1.text = "Let us praise the Lord, singing words of Prophet David: * “You revealed yourself to us, O Savior and Maker. * You crushed the heads of dragons in the water, when You, O Word, * went into the Jordan, in Your mercy, * and enlightened those who had been blinded, * O Christ, with Your light. * Blessed are You who have appeared; glory to You, our God!”"

meVE.Aposticha2.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Aposticha2.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meVE.Aposticha2.incipit = "Ardently we honor…"
meVE.Aposticha2.text = "Ardently we honor Your plan for our salvation, * which You have accomplished, in Your divine good pleasure. * You freed our human nature from the curse out of Paradise, * and You made us strong against assailants * by Your holy baptism, O Logos. * And now we sing to You, * “Blessed are You who have appeared; glory to You, our God!”"

meVE.Aposticha3.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Aposticha3.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meVE.Aposticha3.incipit = "…"
meVE.Aposticha3.text = "We were clothed in garments of skin because of Adam, * in whose fall we willingly once participated. * But in the Lord’s baptism in the Jordan River today, * we have taken off that ancient garment, * and praising God, we join the Angels * and sing to Him, * Blessed are You who have appeared; glory to You, our God!”"

meVE.AposGlory.poet = poets_en_US_goadedes.po.Theofanous
meVE.AposGlory.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "Let us the faithful extol…"
meVE.AposGlory.text = "Let us the faithful extol the greatness of God’s benevolent deeds concerning us. For He became man in our transgression; and now in the Jordan, He who alone is clean and undefiled is cleansed in the cleansing that is meant for us; and He sanctifies me and the waters, and on the water He crushes the heads of the dragons. Therefore, brethren, let us draw water with gladness. For to those who draw with faith, the grace of the Spirit is invisibly given by Christ, our God and the Savior of our souls."

