meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera01.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera01.incipit = "You subdued…"
meVE.Stichera01.text = "You subdued every physical pleasure and the unruly flesh, * using self-control as a bridle and a bit. * And as an excellent soldier you defeated and overcame * all the weapons of the foe, * by the grace of Spirit of God who strengthened you. * O St. Nikon, and you became the guide of the monastics who adhered to * your wise instructions and godly words."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera02.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera02.incipit = "You shone forth…"
meVE.Stichera02.text = "You shone forth, O all-blessed Saint, from the east like a blazing sun, * and you shined the light of the Gospel on the world, * by your most radiant miracles; and you brought along a host * of disciples, who were bright * like the stars. And together you suffered martyrdom, * being tortured and finally beheaded, then delivering your spirits * into the hands of the King of all."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera03.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera03.incipit = "Neither famine…"
meVE.Stichera03.text = "Neither famine nor nakedness, peril, whippings, or violent death * separated you from the love of God in Christ, * even as Paul the Apostle said, O splendid and admirable * holy monks; and then like lambs * to the slaughter, you followed your shepherd from the west, * and you reached your unfading destination, in the kingdom of the heavens, * as medaled Athletes, O martyr Saints."

