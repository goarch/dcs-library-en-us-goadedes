meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera01.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera01.incipit = "When you witnessed…"
meVE.Stichera01.text = "When you witnessed the bravery * and the dignified suffering * of the holy Martyrs and their unyielding faith, * then voluntarily you signed up for torture courageously, * not betraying self-concern * for your body, for love of God. And you finished all * of the arduous contests resolutely, Martyr Adrian, and humbled * the haughty pride of the enemy."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera02.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera02.incipit = "Undergoing imprisonment…"
meVE.Stichera02.text = "Undergoing imprisonment, * being beaten with leather whips, * weighted down with shackles of iron on your limbs, * bearing the breaking of hands and legs, together with twenty-three * other martyrs, you received * all together the heavenly blessings from the Lord, * Valiant Martyr St. Adrian. And through it all your godly wife Natalia * was by your side and encouraged you."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera03.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera03.incipit = "Adam’s wife…"
meVE.Stichera03.text = "Adam’s wife back in Paradise * was the cause of his banishment, * through the serpent’s counsel. But now with Adrian, * his wife Natalia facilitates his entry to Paradise, * speaking wise and sacred words, * and she counsels and teaches him to endure the pain * of the tortures of martyrdom, resulting in awards bestowed from heaven, * with fame and glory that never ends."

