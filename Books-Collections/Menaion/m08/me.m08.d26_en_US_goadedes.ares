meVE.SticTheotokion.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.SticTheotokion.greekmelody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.greekname
meVE.SticTheotokion.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
meVE.SticTheotokion.incipit = "O all-immaculate Virgin…"
meVE.SticTheotokion.text = "O all-immaculate Virgin, abundant healings and cures * are given through your holy and miraculous icons, * to those who venerate them with faith. So now I * supplicate you to visit me * with love and mercy, O good Lady, and to heal * my infirmities of body and soul."

