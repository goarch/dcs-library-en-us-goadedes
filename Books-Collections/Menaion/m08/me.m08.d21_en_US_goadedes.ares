meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera01.greekmelody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.greekname
meVE.Stichera01.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
meVE.Stichera01.incipit = "Blessed Apostle…"
meVE.Stichera01.text = "Blessed Apostle St. Thaddeus, having experienced * the supreme uncreated light, * by participation now * you are truly a second light * that broke the dark night of polytheism * and brought to almighty God a host of souls. * Therefore we celebrate, * glorifying Christ our God as we observe * the resplendent feast of your distinguished memory."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera02.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
meVE.Stichera02.incipit = "Blessed Apostle…"
meVE.Stichera02.text = "Blessed Apostle St. Thaddeus, after the glorious * resurrection of Christ our God, * and His all-holy ascent * into heaven, from where He came, * you were entrusted to preach the word of God * to the Edessans. And through your miracles * and your inspired words, * you convinced city's king Abgar and all * the residents to believe the Gospel truth of Christ."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera03.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
meVE.Stichera03.incipit = "Blessed Apostle…"
meVE.Stichera03.text = "Blessed Apostle St. Thaddeus, the grace of God through your touch * granted those who were blind to see, * rendered crippled people whole, * curing those who were sick with disease; * it made the paralyzed stand and walk again; * it taught salvation to those yet unaware. * You, O all-blessed man, * had the fullness of the gifts of the divine * Spirit who can do all things. And now we honor you."

