meMA.Kathisma11.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Kathisma11.greekmelody = he.a.m4_en_US_goadedes.heAU.TachyProkatalave.greekname
meMA.Kathisma11.melody = he.a.m4_en_US_goadedes.heAU.TachyProkatalave.name
meMA.Kathisma11.incipit = "Immaculate Virgin…"
meMA.Kathisma11.text = "Immaculate Virgin, today we celebrate * your holy Dormition, when Christ our God, who became * incarnate from you, arrived * with ineffable glory to collect your spirit. * In glory you were translated, without forgetting the world. * O Mother of God, by your prayers you protect us who honor you."

meMA.Kathisma21.mode = miscellanea_en_US_goadedes.misc.Mode5
meMA.Kathisma21.greekmelody = he.a.m5_en_US_goadedes.heAU.TonSynanarchonLogon.greekname
meMA.Kathisma21.melody = he.a.m5_en_US_goadedes.heAU.TonSynanarchonLogon.name
meMA.Kathisma21.incipit = "All the hosts…"
meMA.Kathisma21.text = "All the hosts of the Angels are glorifying you, * and humanity faithfully is extolling you. * You were translated from the earth to the heavenly courts, * and to your Son and God you pray for us all who celebrate * your Assumption, O Virgin, * and you implore Him to rescue us, * who believe in Him, from dangers all."

