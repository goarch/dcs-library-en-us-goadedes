meMA.Exaposteilarion1.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Exaposteilarion1.greekmelody = he.a.m2_en_US_goadedes.heAU.GynaikesAkoutisthite.greekname
meMA.Exaposteilarion1.melody = he.a.m2_en_US_goadedes.heAU.GynaikesAkoutisthite.name
meMA.Exaposteilarion1.incipit = "All-wise Apostle…"
meMA.Exaposteilarion1.text = "All-wise Apostle Thaddeus, you are the star of Edessa, * where you proclaimed the all-holy, * divine Gospel of the Logos; * and you illumined everyone, king Abgar and his citizens, * and turned them into worshipers * of one Godhead in three persons, * O truly inspired preacher."

