meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_en_US_goadedes.heAU.EdokasSimeiosin.greekname
meVE.Stichera01.melody = he.a.m4_en_US_goadedes.heAU.EdokasSimeiosin.name
meVE.Stichera01.incipit = "Your name, Agathonicus…"
meVE.Stichera01.text = "Your name, Agathonicus, denoting goodness and victory, * you pursued the ineffable * beauty and primary good, * joyfully advancing * to the noble contests. And when you wrestled with the foe, * you threw him down to the ground valiantly. * For this you were awarded the resplendent halo of victory. * And for us who extol you now, you implore our benevolent God."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera02.melody = he.a.m4_en_US_goadedes.heAU.EdokasSimeiosin.name
meVE.Stichera02.incipit = "Endowed with the wisdom…"
meVE.Stichera02.text = "Endowed with the wisdom from on high, you poured out life-giving words; * you converted the ignorant; * you censured the governor; * you calmed the confusion * of pagan religion; you strengthened those who had believed * to persevere in the grace they had received. * And after undergoing many painful tortures, you died for Christ * and ascended to heaven’s courts, with a halo of victory."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera03.melody = he.a.m4_en_US_goadedes.heAU.EdokasSimeiosin.name
meVE.Stichera03.incipit = "Still dripping with blood…"
meVE.Stichera03.text = "Still dripping with blood after the grueling martyrdom you endured, * you presented yourself to Christ * as a fragrant sacrifice * and a pure and spotless * sacrificial victim, a sacred offering to God, * and an acceptable and well pleasing gift. * And therefore we implore you, Martyr Agathonicus, pray for us * to the Lord, to preserve the Church and her members in lasting peace."

