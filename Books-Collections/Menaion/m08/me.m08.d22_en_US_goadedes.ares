meMA.Kathisma11.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Kathisma11.greekmelody = he.a.m4_en_US_goadedes.heAU.KateplagiIosif.greekname
meMA.Kathisma11.melody = he.a.m4_en_US_goadedes.heAU.KateplagiIosif.name
meMA.Kathisma11.incipit = "Here on earth…"
meMA.Kathisma11.text = "Here on earth your body was wider than heaven above, * for you carried in your womb the Creator of all. * Now from the earth to those heavens you were translated. * The souls of righteous Saints are beholding you, * and choirs of the Angels are gazing on you, * who are the Queen of all, and they present to you * their fitting praises forevermore. * O Lady, cease not from interceding * for all of us who honor you."

meMA.Kathisma21.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Kathisma21.greekmelody = he.a.m4_en_US_goadedes.heAU.KateplagiIosif.greekname
meMA.Kathisma21.melody = he.a.m4_en_US_goadedes.heAU.KateplagiIosif.name
meMA.Kathisma21.incipit = "The Apostles had gone…"
meMA.Kathisma21.text = "The Apostles had gone out to the ends of the earth. * They assembled once again to send off from the earth, * the Theotokos, to her Son who is the Most High God. * The supermundane hosts of the heavens arrived, * preceding them and celebrating with them; * and with their spiritual voices they cried aloud, * “O heavens, rejoice, as you receive * the holy Mother of God, for she is * the Queen of the seen and unseen worlds.”"

