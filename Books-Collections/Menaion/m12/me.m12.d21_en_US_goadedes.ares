meMA.Kontakion1.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Kontakion1.greekmelody = he.a.m2_en_US_goadedes.heAU.TaAnoZiton.greekname
meMA.Kontakion1.melody = he.a.m2_en_US_goadedes.heAU.TaAnoZiton.name
meMA.Kontakion1.incipit = "As we see the Lord…"
meMA.Kontakion1.text = "As we see the Lord, who holds the whole world in His hand, * wrapped in swaddling clothes in the city of Bethlehem, * let us bring our forefestal hymns * to the Ever-Virgin who gave birth to Him. * She rejoices maternally, * as she holds in her embraces the Son of God."

meMA.Oikos1.text = "The Virgin held the Son of God in her arms, and she smothered Him with maternal kisses and said, “I conceived without having sex, and I gave birth to You and my body is intact. Even after childbirth, I am a virgin as before. So I adore Your great compassion and the ineffable miracle You have done in me, my Child. Therefore I greatly rejoice, as I hold in my embraces the Son of God.”"

