meMA.Ode6C11.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C11.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode6C11.greekmelody = he.h.m4_en_US_goadedes.heHE.IlthonEisTaVathi.greekname
meMA.Ode6C11.melody = he.h.m4_en_US_goadedes.heHE.IlthonEisTaVathi.notmetered
meMA.Ode6C11.incipit = "For us a new Child is born…"
meMA.Ode6C11.text = "For us a new Child is born on earth. He ineffably shone forth from the Father before the ages. As compassionate Savior, He has freed everyone from the primal disobedience."

meMA.Ode6C12.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C12.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode6C12.melody = he.h.m4_en_US_goadedes.heHE.IlthonEisTaVathi.notmetered
meMA.Ode6C12.incipit = "O unoriginate Logos…"
meMA.Ode6C12.text = "O unoriginate Logos, when You were born, strange and marvelous things were heard in the city of Bethlehem; for shepherds and Angels extolled You as their Master."

meMA.Ode6C13.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C13.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode6C13.melody = he.h.m4_en_US_goadedes.heHE.IlthonEisTaVathi.notmetered
meMA.Ode6C13.incipit = "The star reveals…"
meMA.Ode6C13.text = "The star reveals to the Magi the Sun of righteousness, who was born ineffably. Let us now greatly rejoice and celebrate the Forefeast of His Nativity."

