meMA.Exaposteilarion1.mode = miscellanea_en_US_goadedes.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_en_US_goadedes.heAU.TonNymfonaSouVlepo.greekname
meMA.Exaposteilarion1.melody = he.a.m3_en_US_goadedes.heAU.TonNymfonaSouVlepo.name
meMA.Exaposteilarion1.incipit = "O Word, Your holy Martyr…"
meMA.Exaposteilarion1.text = "O Word, Your holy Martyr, * longing for Your bridal chamber, * endured every kind of torture * steadfastly with Your assistance. * At her intercessions, O God, * I entreat You * show tender mercy to my soul."

meMA.Exaposteilarion2.mode = miscellanea_en_US_goadedes.misc.Mode3
meMA.Exaposteilarion2.greekmelody = he.a.m3_en_US_goadedes.heAU.TonNymfonaSouVlepo.greekname
meMA.Exaposteilarion2.melody = he.a.m3_en_US_goadedes.heAU.TonNymfonaSouVlepo.name
meMA.Exaposteilarion2.incipit = "O Bethlehem, land of Judah…"
meMA.Exaposteilarion2.text = "O Bethlehem, land of Judah, * prepare your portals of entry; * for the Virgin Theotokos * is now arriving at your gates * to give birth within a Cave * to my God and Lord, * who came as a mortal infant."

meMA.Lauds1.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Lauds1.greekmelody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.greekname
meMA.Lauds1.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Lauds1.incipit = "He who will be born…"
meMA.Lauds1.text = "He who will be born is divine creative Wisdom, * and the clouds shall open, according to the Prophets. * The grace of God is clearing, and the truth has brightly shone forth. * Finished are the riddles and the shadows. * The gate of Eden is reopened. * O Adam, exult! * Our God who fashioned us has been fashioned voluntarily!"

meMA.Lauds2.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Lauds2.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Lauds2.incipit = "Fulfilling the predictions…"
meMA.Lauds2.text = "Fulfilling the predictions and visions of the Prophets, * the Logos is born in the flesh now with a body. * When He was born, He lay in a manger of irrationals. * This is the ultimate condescension * and His awesome plan for our salvation! * And therefore we sing, * “Jesus Christ, who is the King of Israel, has come to earth.”"

meMA.Lauds3.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Lauds3.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Lauds3.incipit = "You who make…"
meMA.Lauds3.text = "You who make the world turn by Your command, O Logos, * are wrapped in swaddling clothes and are nursing as an infant, * for You became incarnate, to restore Your image in me * and purge from me the poison of corruption. * O wonder-worker, I extol You, * the Angel of * the Father’s counsel, for thereby I gain immortality."

meMA.Lauds4.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Lauds4.greekmelody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.greekname
meMA.Lauds4.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.Lauds4.incipit = "You were seen…"
meMA.Lauds4.text = "You were seen as man, never absent from the Father’s * bosom; and you rode in the belly of the Virgin. * And through a star You summoned out of Persia the magi kings, * who as King and God indeed adored You, * who destroy the rulers of the nations, * as ungodly men, * by the spirit of Your lips, and shepherd Your chosen flock."

meMA.LaudsGlory.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.LaudsGlory.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.LaudsGlory.incipit = "He who is the Word…"
meMA.LaudsGlory.text = "He who is the Word, consubstantial with the Father, * and the progeny of the pure and holy Virgin, * is fashioned and develops in her womb; in the course of time * He is born, an infant, in the Grotto. * What on earth is this! Both men and Angels * extol Him and sing, * “Jesus Christ, who is the King of Israel, has come to earth.”"

meMA.LaudsBoth.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.LaudsBoth.melody = he.a.m6_en_US_goadedes.heAU.AiAngelikai.name
meMA.LaudsBoth.incipit = "Fulfilled are the sayings…"
meMA.LaudsBoth.text = "Fulfilled are the sayings of Balaam the diviner. * For they who believed the Persian fables were enlightened * by the illumination of the extraordinary star * and followed it to Christ, the never-setting * Sun, in Bethlehem incarnate, * and by their gifts * declared Him God and King and man who would die voluntarily."

meMA.Aposticha1.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Aposticha1.greekmelody = he.a.m2_en_US_goadedes.heAU.OikosTouEfratha.greekname
meMA.Aposticha1.melody = he.a.m2_en_US_goadedes.heAU.OikosTouEfratha.name
meMA.Aposticha1.incipit = "Already is the star…"
meMA.Aposticha1.text = "Already is the star * shining above the Grotto. * With precious gifts, O Magi, * and Shepherds with the Angels, prepare to go to Bethlehem."

meMA.Aposticha2.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Aposticha2.melody = he.a.m2_en_US_goadedes.heAU.OikosTouEfratha.name
meMA.Aposticha2.incipit = "The Lord comes…"
meMA.Aposticha2.text = "The Lord comes to be born * in Bethlehem to open * Eden to the descendants * of Adam. And the Prophets’ predictions are at last fulfilled."

meMA.Aposticha3.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Aposticha3.melody = he.a.m2_en_US_goadedes.heAU.OikosTouEfratha.name
meMA.Aposticha3.incipit = "Bethlehem, deck…"
meMA.Aposticha3.text = "Bethlehem, deck the cave * and cense the holy Grotto. * In you indeed the Master * will radiantly shine forth the rays of His divinity."

meMA.AposGlory.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.AposGlory.melody = he.a.m2_en_US_goadedes.heAU.OikosTouEfratha.name
meMA.AposGlory.incipit = "Come, all you born…"
meMA.AposGlory.text = "Come, all you born earth, * and let us join in chorus, * ceaselessly praising Mary, * the Virgin Theotokos, from whom our Savior Christ is born."

