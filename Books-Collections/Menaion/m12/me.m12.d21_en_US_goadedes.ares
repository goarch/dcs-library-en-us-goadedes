meMA.Kathisma11.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Kathisma11.greekmelody = "Ὁ εὐσχήμων Ἰωσήφ."
meMA.Kathisma11.melody = "When he took down."
meMA.Kathisma11.incipit = "My unapproachable God…"
meMA.Kathisma11.text = "My unapproachable God becomes approachable to me * willingly in His mercy. * He is coming in the flesh, to be born as a human babe, * from a virgin Maiden pure, in the city of Bethlehem. * So let us eagerly make ready to welcome Him, * as we sing with devotion, “Glory to You, O Lord!”"

meMA.Kathisma21.mode = miscellanea_en_US_goadedes.misc.Mode3
meMA.Kathisma21.greekmelody = he.a.m3_en_US_goadedes.heAU.TinOraiotita.greekname
meMA.Kathisma21.melody = he.a.m3_en_US_goadedes.heAU.TinOraiotita.name
meMA.Kathisma21.incipit = "A paradoxical wonder…"
meMA.Kathisma21.text = "A paradoxical wonder is seen today. * For our salvation now our Savior urgently * comes to the grotto to be born from His Virgin Mother physically. * Magi shall arrive with gifts * and shall worship the infant King. * Shepherds and angelic hosts * will glorify and honor Him. * We join them and also cry out, * “Glory to You, who became incarnate for us!”"

