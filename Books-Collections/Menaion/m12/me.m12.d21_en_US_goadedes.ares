meMA.Ode3C11.ode = miscellanea_en_US_goadedes.misc.Ode3
meMA.Ode3C11.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode3C11.greekmelody = he.h.m4_en_US_goadedes.heHE.OtiSteiraEteken.greekname
meMA.Ode3C11.melody = he.h.m4_en_US_goadedes.heHE.OtiSteiraEteken.notmetered
meMA.Ode3C11.incipit = "O Logos, Daniel sees…"
meMA.Ode3C11.text = "O Logos, Daniel sees You as a stone cut from a virgin mountain and smashing pagan altars by Your might. We therefore glorify You with fear and awe."

meMA.Ode3C12.ode = miscellanea_en_US_goadedes.misc.Ode3
meMA.Ode3C12.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode3C12.melody = he.h.m4_en_US_goadedes.heHE.OtiSteiraEteken.notmetered
meMA.Ode3C12.incipit = "Magi from the Orient…"
meMA.Ode3C12.text = "Magi from the Orient were led by a star to You the King of all. They marvel at Your condescension, O Christ, and they offer You gifts, gold, frankincense, and myrrh."

meMA.Ode3C13.ode = miscellanea_en_US_goadedes.misc.Ode3
meMA.Ode3C13.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode3C13.melody = he.h.m4_en_US_goadedes.heHE.OtiSteiraEteken.notmetered
meMA.Ode3C13.incipit = "Mary, the land not ploughed…"
meMA.Ode3C13.text = "Mary, the land not ploughed, bears her Son, the life-bearing stalk. She comes to the city of Bethlehem to give birth to the One who feeds the souls of all who sing: “Holy are You, O Lord.”"

