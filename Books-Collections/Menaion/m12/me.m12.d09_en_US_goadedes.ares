meMA.Ode6C12.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C12.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode6C12.melody = he.h.m4_en_US_goadedes.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C12.incipit = me.m09.d13_en_US_goadedes.meMA.Ode6C22.incipit
meMA.Ode6C12.text = me.m09.d13_en_US_goadedes.meMA.Ode6C22.text

meMA.Ode6C13.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C13.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode6C13.melody = he.h.m4_en_US_goadedes.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C13.incipit = "Having her foundation…"
meMA.Ode6C13.text = "Having her foundation not on sand but the rock of Christ, the holy Church of the Gentiles * is adorned with unapproachable beauty, * with the brightness of the eternal kingdom bedecking her." //similar to me.m09.d13.meMA.Ode6C23.text

meMA.Ode6C1T.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode6C1T.melody = he.h.m4_en_US_goadedes.heHE.ThysoSoiMetaFonis.name
meMA.Ode6C1T.incipit = oc.m4.d1_en_US_goadedes.ocMA.OdeS6C1T.incipit
meMA.Ode6C1T.text = oc.m4.d1_en_US_goadedes.ocMA.OdeS6C1T.text

meMA.Ode6C21.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C21.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode6C21.greekmelody = he.h.m1_en_US_goadedes.heHE.TonProfitinIonan.greekname
meMA.Ode6C21.melody = he.h.m1_en_US_goadedes.heHE.TonProfitinIonan.name
meMA.Ode6C21.incipit = "How can she who contained God…"
meMA.Ode6C21.text = "How can she who contained God be contained within a womb? * How can she who in the flesh mothered Christ now be born? * And how can she * who nursed the Maker with milk herself be nursed?"

meMA.Ode6C22.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C22.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode6C22.melody = he.h.m1_en_US_goadedes.heHE.TonProfitinIonan.name
meMA.Ode6C22.incipit = "Having heard your ardent prayers…"
meMA.Ode6C22.text = "Having heard your ardent prayers, God has answered them today. * He has given you a most fertile fruit, who will in time * give birth to Him, * O holy Anna and righteous Joachim."

meMA.Ode6C23.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C23.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode6C23.melody = he.h.m1_en_US_goadedes.heHE.TonProfitinIonan.name
meMA.Ode6C23.incipit = "After Anna had conceived…"
meMA.Ode6C23.text = "After Anna had conceived in her womb the purest dove, * she was genuinely filled with a spiritual joy. * She worshiped God, * to whom she offered her songs of gratitude."

meMA.Ode6C2T.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C2T.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode6C2T.melody = he.h.m1_en_US_goadedes.heHE.TonProfitinIonan.name
meMA.Ode6C2T.incipit = "As the storm of sordid thoughts…"
meMA.Ode6C2T.text = "As the storm of sordid thoughts hits my sorry soul with force, * and the passions swell like waves in the ocean of my sins, * I cry to you: * O holy Lady, help me, O Mother of God."

