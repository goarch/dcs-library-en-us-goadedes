meMA.Ode9C11.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C11.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode9C11.greekmelody = he.h.m4_en_US_goadedes.heHE.LithosAcheirotmitos.greekname
meMA.Ode9C11.melody = he.h.m4_en_US_goadedes.heHE.LithosAcheirotmitos.name
meMA.Ode9C11.incipit = "Purified in heart…"
meMA.Ode9C11.text = "Purified in heart and with wakeful eyes of our intellect beholding * all the beauty and all the glory, * which is more splendid than gold, within the Church, * let us perceive the daughter of the King and magnify her evermore." //similar to me.m09.d13.meMA.Ode9C21.text

meMA.Ode9C12.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C12.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode9C12.melody = he.h.m4_en_US_goadedes.heHE.LithosAcheirotmitos.name
meMA.Ode9C12.incipit = me.m09.d13_en_US_goadedes.meMA.Ode9C22.incipit
meMA.Ode9C12.text = me.m09.d13_en_US_goadedes.meMA.Ode9C22.text

meMA.Ode9C13.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C13.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode9C13.melody = he.h.m4_en_US_goadedes.heHE.LithosAcheirotmitos.name
meMA.Ode9C13.incipit = "Grant Your Church…"
meMA.Ode9C13.text = "Grant Your Church the mighty protection that comes from heaven, O our Savior. * For she knows no other protector * except for You, who laid down Your life for her. * And knowing this, she glorifies You as the Lord who is benevolent." //similar to me.m09.d13.meMA.Ode9C23.text

meMA.Ode9C1T.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode9C1T.melody = he.h.m4_en_US_goadedes.heHE.LithosAcheirotmitos.name
meMA.Ode9C1T.incipit = "Virgin Theotokos…"
meMA.Ode9C1T.text = "Virgin Theotokos, we pray you * accept the prayers of your people. * Intercede intently with your Son * that He deliver us from adversity * and dangerous predicaments, * as we extol you our protectress and hope."

meMA.Ode9C21.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C21.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode9C21.greekmelody = he.h.m1_en_US_goadedes.heHE.TinZoodochonPigin.greekname
meMA.Ode9C21.melody = he.h.m1_en_US_goadedes.heHE.TinZoodochonPigin.name
meMA.Ode9C21.incipit = "O godly-minded St. Anna…"
meMA.Ode9C21.text = "O godly-minded St. Anna, now celebrate! * Rejoice, conceiving the spring wherein life will dwell! * Bright with light of righteousness, * you are holding in your womb * your daughter Mary, indeed the holy Temple. * And therefore magnify God the Creator of all."

meMA.Ode9C22.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C22.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode9C22.melody = he.h.m1_en_US_goadedes.heHE.TinZoodochonPigin.name
meMA.Ode9C22.incipit = "Let us extol…"
meMA.Ode9C22.text = "Let us extol that devout and all-venerable * husband and wife, who adhered to the Law of God * and became the grandparents * of the pre-eternal Son; * and let us honor them, Joachim and Anna, * for they gave birth the first-fruit of godly joy."

meMA.Ode9C23.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C23.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode9C23.melody = he.h.m1_en_US_goadedes.heHE.TinZoodochonPigin.name
meMA.Ode9C23.incipit = "What Daniel saw…"
meMA.Ode9C23.text = "What Daniel saw as a great mountain Joel called * the holy land; and Ezekiel saw the gate * that no man shall enter by; * Gideon beheld a fleece. * A fountain sealed is how Solomon described her. * And we extol her as the virgin Mother of God."

meMA.Ode9C2T.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C2T.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode9C2T.melody = he.h.m1_en_US_goadedes.heHE.TinZoodochonPigin.name
meMA.Ode9C2T.incipit = "When God the Logos…"
meMA.Ode9C2T.text = "When God the Logos became flesh ineffably, * His Mother’s blood was the purple that dyed the wool, * since He is the Lamb of God. * She fulfilled the images * of golden altar of incense and the table * which held the bread, namely Christ, and we honor her."

