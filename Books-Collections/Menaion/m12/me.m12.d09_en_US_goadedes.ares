meMA.Ode1C21.ode = miscellanea_en_US_goadedes.misc.Ode1
meMA.Ode1C21.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode1C21.greekmelody = he.h.m1_en_US_goadedes.heHE.OdinEpinikion.greekname
meMA.Ode1C21.melody = he.h.m1_en_US_goadedes.heHE.OdinEpinikion.name
meMA.Ode1C21.incipit = "Today, we are celebrating…"
meMA.Ode1C21.text = "Today, we are celebrating your conception * and freedom from barrenness. * Godly Anna, you indeed conceived the all-holy girl, * who would eventually contain our uncontainable God."

meMA.Ode1C22.ode = miscellanea_en_US_goadedes.misc.Ode1
meMA.Ode1C22.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode1C22.melody = he.h.m1_en_US_goadedes.heHE.OdinEpinikion.name
meMA.Ode1C22.incipit = "You heard the entreaties…"
meMA.Ode1C22.text = "You heard the entreaties of Your righteous forebears. * You answered the fervent prayers * of Your holy grandparents. O Lord, You gave them a child, * for they conceived and bore the Virgin who gave birth to You."

meMA.Ode1C23.ode = miscellanea_en_US_goadedes.misc.Ode1
meMA.Ode1C23.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode1C23.melody = he.h.m1_en_US_goadedes.heHE.OdinEpinikion.name
meMA.Ode1C23.incipit = "Now glorious Anna…"
meMA.Ode1C23.text = "Now glorious Anna has conceived the Virgin, * and she will give birth to her, * who in turn will in the flesh conceive the bodiless Lord * and will eventually give birth to our benevolent God."

meMA.Ode1C2T.ode = miscellanea_en_US_goadedes.misc.Ode1
meMA.Ode1C2T.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode1C2T.melody = he.h.m1_en_US_goadedes.heHE.OdinEpinikion.name
meMA.Ode1C2T.incipit = "Immaculate Virgin…"
meMA.Ode1C2T.text = "Immaculate Virgin, you fulfill the image * foreseen by the God-inspired * Prophet Daniel long ago, the holy mountain, from which * a stone was cut and crushed idolatry by might divine."

