meLI.MM.CommunionHymn.text = properties_en_US_goadedes.media.key

meLI.Megalynarion.text = "Glorious St. Anna today conceives * by the laws of nature and divine providence the one * who would supernaturally mother God the Logos. * We praise the Virgin Mary’s parents and honor them."

