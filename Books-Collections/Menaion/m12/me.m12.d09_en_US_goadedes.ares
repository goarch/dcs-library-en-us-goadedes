meMA.Ode3C21.ode = miscellanea_en_US_goadedes.misc.Ode3
meMA.Ode3C21.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode3C21.greekmelody = he.h.m1_en_US_goadedes.heHE.StereothitoIKardiaMou.greekname
meMA.Ode3C21.melody = he.h.m1_en_US_goadedes.heHE.StereothitoIKardiaMou.name
meMA.Ode3C21.incipit = "Godly St. Anna cried…"
meMA.Ode3C21.text = "Godly St. Anna cried aloud in prayer, * “If You grant me fruit of my womb, O Lord, * I will be magnified, and I vow to offer it back to You.” * Therefore she conceived the holy and immaculate Mother of God."

meMA.Ode3C22.ode = miscellanea_en_US_goadedes.misc.Ode3
meMA.Ode3C22.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode3C22.melody = he.h.m1_en_US_goadedes.heHE.StereothitoIKardiaMou.name
meMA.Ode3C22.incipit = "O godly-minded Anna…"
meMA.Ode3C22.text = "O godly-minded Anna, when you prayed * with tears in the garden, your voice was heard * by God Most High; and He gave to your womb the all-holy fruit, * namely Mary, who would open the door to the Garden of grace."

meMA.Ode3C23.ode = miscellanea_en_US_goadedes.misc.Ode3
meMA.Ode3C23.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode3C23.melody = he.h.m1_en_US_goadedes.heHE.StereothitoIKardiaMou.name
meMA.Ode3C23.incipit = "All-holy Anna…"
meMA.Ode3C23.text = "All-holy Anna, when you had obeyed * the Law and you blamelessly served the Lord, * then you conceived and bore a child, who in time would conceive and bear * God the Law-giver. And therefore we the faithful now call you blest."

meMA.Ode3C2T.ode = miscellanea_en_US_goadedes.misc.Ode3
meMA.Ode3C2T.mode = miscellanea_en_US_goadedes.misc.Mode1
meMA.Ode3C2T.melody = he.h.m1_en_US_goadedes.heHE.StereothitoIKardiaMou.name
meMA.Ode3C2T.incipit = "From my infertile intellect…"
meMA.Ode3C2T.text = "From my infertile intellect dispel * everything that makes it unfruitful, I pray; * and help my soul produce the fruits of the virtues, by grace divine, * O all-holy Theotokos, as the help of believers all."

