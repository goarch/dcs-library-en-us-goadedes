meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera01.greekmelody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera01.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera01.incipit = "When the wonderful Habakkuk…"
meVE.Stichera01.text = "When the ray of the Spirit's light entered wonderful Habakkuk, * he became a prophet, wholly inspired by God. * So when he saw the ungodliness of judges and their unjust * judgments, he became displeased, * and displaying the uprightness of the holy will * of his Master and God, within him righteous indignation was ignited * coupled with love for his Lord and God."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera02.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera02.incipit = "As he stood…"
meVE.Stichera02.text = "As he stood on his godly watch, Your revered Prophet Habakkuk * was afraid, O Lord, upon hearing the report * of Your ineffable mystery, that You would come down to us. * He foretold what You revealed: * You would go forth and preach, O Christ, and You would send out * Your Apostles, like horses, to the nations, like the sea, and they would churn them, * like many waters, to save their souls."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.Stichera03.melody = he.a.m4_en_US_goadedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera03.incipit = "You rejoice in your Lord…"
meVE.Stichera03.text = "You rejoice in your Lord and God and your Savior, exultantly, * glorious, inspired, holy Prophet Habakkuk. * You are receiving the heavenly resplendence and radiance * of the uncreated light, * and illumined noetically. We who faithfully * keep your all-sacred memory, implore you: Intercede for us and save us * from tribulations that threaten us."

