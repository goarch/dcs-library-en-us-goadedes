meVE.SticStavrotheotokion.mode = miscellanea_en_US_goadedes.misc.Mode5
meVE.SticStavrotheotokion.greekmelody = he.a.m5_en_US_goadedes.heAU.ChairoisAskitikon.greekname
meVE.SticStavrotheotokion.melody = he.a.m5_en_US_goadedes.heAU.ChairoisAskitikon.name
meVE.SticStavrotheotokion.incipit = "Seeing Your holy Passion…"
meVE.SticStavrotheotokion.text = "Seeing Your holy Passion, O Lord, * who are long-suffering, the King of the universe, * Your noble and all-immaculate Mother bitterly wept. * As she beat her breasts, she cried aloud and said, * “O Jesus, whose name denotes my salvation, O sweetest Son, * light of the whole world and divine never-setting Sun, * how am I to watch as they hang You upon a cross, * as if you were a criminal, alas! how can I endure * to see Your side, which was pierced by the soldier’s spear, and remain alive, * unless the divine light * of Your resurrection shine on me, O my Son and God?”"

