meMA.Exaposteilarion1.mode = miscellanea_en_US_goadedes.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_en_US_goadedes.heAU.EnPnevmatiToIero.greekname
meMA.Exaposteilarion1.melody = he.a.m3_en_US_goadedes.heAU.EnPnevmatiToIero.name
meMA.Exaposteilarion1.incipit = "Most marvelous father…"
meMA.Exaposteilarion1.text = "Most marvelous father Daniel, * as you stood above the ground, * you were pressed by the elements, * by both the cold and the heat, * but you were like a diamond * and you did not succumb to * necessities of your nature. * Therefore the Master granted * to you, as to a true son, * to enjoy immortal glory."

