meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera01.greekmelody = he.a.m8_en_US_goadedes.heAU.TiYmasKalesomen.greekname
meVE.Stichera01.melody = he.a.m8_en_US_goadedes.heAU.TiYmasKalesomen.name
meVE.Stichera01.incipit = "What are we to call you…"
meVE.Stichera01.text = "What are we to call you, all-blessed Saint? * An ascetic, for subordinating passions to the mind, * or an athlete, for you rigorously disciplined the flesh, * uplifted on your pillar high above the ground, * O Daniel, firmly grounded on the rock of truth, * as a combatant, inflexible; as a physician, most competent. * So pray for us, and entreat the Lord to save our souls."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera02.melody = he.a.m8_en_US_goadedes.heAU.TiYmasKalesomen.name
meVE.Stichera02.incipit = "How should we salute you…"
meVE.Stichera02.text = "How should we salute you and sing your praise? * You uprooted sinful passions, planting virtues in their stead, * interceding for offenders, working miracles indeed. * O Daniel, you expelled demons courageously. * You brightly glowed with Orthodoxy brilliantly. * The Holy Spirit abode in you, and you defended the Church of Christ. * So pray for us, and entreat the Lord to save our souls."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera03.melody = he.a.m8_en_US_goadedes.heAU.TiYmasKalesomen.name
meVE.Stichera03.incipit = "How should we extol you…"
meVE.Stichera03.text = "How should we extol you, O Saint of God? * As a trainer of monastics, you embodied self-control. * For the miracles and cures that you performed you are admired. * A beacon shining light on those once in the dark; * a fellow and coequal with the Bodiless. * O Daniel, dwelling in Paradise, you are a heavenly man indeed. * So pray for us, and entreat the Lord to save our souls."

