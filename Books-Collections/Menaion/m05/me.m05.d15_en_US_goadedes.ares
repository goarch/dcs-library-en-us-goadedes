meMA.Exaposteilarion1.greekmelody = he.a.m3_en_US_goadedes.heAU.OOuranonToisAstrois.greekname
meMA.Exaposteilarion1.melody = he.a.m3_en_US_goadedes.heAU.OOuranonToisAstrois.name
meMA.Exaposteilarion1.incipit = "You withdrew to the deserts…"
meMA.Exaposteilarion1.text = "You withdrew to the deserts * in your desire to lead a life * that was truly angelic, * subduing passions of the flesh, * O God-bearing Pachomius, * and you became like the angels."

