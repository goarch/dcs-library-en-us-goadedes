meVE.Apolytikion1.mode = miscellanea_en_US_goadedes.misc.Mode5
meVE.Apolytikion1.greekmelody = he.a.m5_en_US_goadedes.heAU.TonSynanarchonLogon.greekname
meVE.Apolytikion1.melody = he.a.m5_en_US_goadedes.heAU.TonSynanarchonLogon.name
meVE.Apolytikion1.incipit = "Like a herdsman…"
meVE.Apolytikion1.text = "Like a herdsman you guided the herds of holy monks * of the Chief Shepherd Christ, O devout Pachomius. * You corralled them to the sheepfold in heaven, from where * you were shown the holy habit appropriate for all * ascetics, to whom you gave it. * And now with them all together * you celebrate in the dwellings on high."

