meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Stichera01.greekmelody = he.a.m6_en_US_goadedes.heAU.OlinApothemenoi.greekname
meVE.Stichera01.melody = he.a.m6_en_US_goadedes.heAU.OlinApothemenoi.name
meVE.Stichera01.incipit = "Focusing entirely…"
meVE.Stichera01.text = "Focusing entirely on God with all your desire, * you gave up mundane delights * as being ephemeral, O Pachomius, * and to Christ gave yourself by your every effort * of devout ascetic discipline. * And you were purified, * demonstrating forceful and resolute * resistance to the stimuli * of the carnal passions that lead to sin. * When you had completed your martyrdom of conscience with success, * being victorious you received * the unfading crown from God."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Stichera02.melody = he.a.m6_en_US_goadedes.heAU.OlinApothemenoi.name
meVE.Stichera02.incipit = "It was granted you…"
meVE.Stichera02.text = "It was granted you to be to God united, O father, * once you rent the heavy veil * of the body and you broke your affinity * to the flesh, through action and through contemplation, * and when you were by the heavenly * graces and rays of light * illumined and when you were deified * through God’s descent in splendid light * and though your ascent into excellence. * Now that you have entered that blessedness, O godly-minded Saint, * for us with confidence pray to Christ, * asking Him to save our souls."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode6
meVE.Stichera03.melody = he.a.m6_en_US_goadedes.heAU.OlinApothemenoi.name
meVE.Stichera03.incipit = "Transcending the stimuli…"
meVE.Stichera03.text = "Transcending the stimuli of all your bodily senses, * purely you conversed with God, * as you were outside the flesh, all-honored Saint; * for you were in control over all the passions, * with your mind focused on higher things. * Father Pachomius, * you subdued and trampled the insolence * of demons. And as you are now * dwelling in heavens and close to Christ, * graciously remember the faithful, who extol you and observe * your sacred memory, when you pray * to the Lord with confidence."

