alt1.meMA.Ode1C1H.ode = miscellanea_en_US_goadedes.misc.Ode1
alt1.meMA.Ode1C1H.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode1C1H.greekmelody = he.h.m4_en_US_goadedes.heHE.AnoixoToStomaMou.greekname
alt1.meMA.Ode1C1H.melody = he.h.m4_en_US_goadedes.heHE.AnoixoToStomaMou.melody
alt1.meMA.Ode1C1H.incipit = he.h.m4_en_US_goadedes.heHE.AnoixoToStomaMou.incipit
alt1.meMA.Ode1C1H.text = he.h.m4_en_US_goadedes.heHE.AnoixoToStomaMou.text

alt1.meMA.Ode1C11.ode = miscellanea_en_US_goadedes.misc.Ode1
alt1.meMA.Ode1C11.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode1C11.greekmelody = he.h.m4_en_US_goadedes.heHE.AnoixoToStomaMou.greekname
alt1.meMA.Ode1C11.melody = he.h.m4_en_US_goadedes.heHE.AnoixoToStomaMou.name
alt1.meMA.Ode1C11.incipit = "All-holy, immaculate…"
alt1.meMA.Ode1C11.text = "All-holy, immaculate Mother of God, will you grant to me * both wisdom and eloquence, that I may festively praise * all the miracles * of your holy protection * that always protects us all who rightly honor you."

alt1.meMA.Ode1C12.ode = miscellanea_en_US_goadedes.misc.Ode1
alt1.meMA.Ode1C12.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode1C12.melody = he.h.m4_en_US_goadedes.heHE.AnoixoToStomaMou.name
alt1.meMA.Ode1C12.incipit = "From heaven above…"
alt1.meMA.Ode1C12.text = "From heaven above you have unfurled your glowing protective veil, * resembling a shining cloud. You cover and protect * not only of old, * that famous ruling city * and Greece in her time of need, * but Christians everywhere."

alt1.meMA.Ode1C13.ode = miscellanea_en_US_goadedes.misc.Ode1
alt1.meMA.Ode1C13.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode1C13.melody = he.h.m4_en_US_goadedes.heHE.AnoixoToStomaMou.name
alt1.meMA.Ode1C13.incipit = "St. Andrew the fool for Christ…"
alt1.meMA.Ode1C13.text = "St. Andrew the fool for Christ saw you of old in a mystical * vision that he had of you, * while he was praying in church. * You, O Virgin pure, * were covering the whole world * beneath your all-holy garment, which you had unfurled."

alt1.meMA.Ode1C14.ode = miscellanea_en_US_goadedes.misc.Ode1
alt1.meMA.Ode1C14.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode1C14.melody = he.h.m4_en_US_goadedes.heHE.AnoixoToStomaMou.name
alt1.meMA.Ode1C14.incipit = "The army of Greece…"
alt1.meMA.Ode1C14.text = "The army of Greece, of old, was given might unassailable * beneath your protective veil. They beat the enemy, * and the victory was famous. Now, O Lady, * remembering this, the faithful sing your mighty deeds. "

alt1.meMA.Ode1C21.ode = miscellanea_en_US_goadedes.misc.Ode1
alt1.meMA.Ode1C21.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode1C21.greekmelody = he.h.m8_en_US_goadedes.heHE.ArmatilatinFarao.greekname
alt1.meMA.Ode1C21.melody = he.h.m8_en_US_goadedes.heHE.ArmatilatinFarao.name
alt1.meMA.Ode1C21.incipit = "Lady, protection of the world…"
alt1.meMA.Ode1C21.text = "Lady, protection of the world and ardent help, O Virgin Mother pure, * to the divine Logos * you gave birth ineffably. * I pray you make me eloquent, * by the grace you have richly, * that I may songfully magnify * your extraordinary protective veil."

alt1.meMA.Ode1C22.ode = miscellanea_en_US_goadedes.misc.Ode1
alt1.meMA.Ode1C22.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode1C22.melody = he.h.m8_en_US_goadedes.heHE.ArmatilatinFarao.name
alt1.meMA.Ode1C22.incipit = "With golden tassels…"
alt1.meMA.Ode1C22.text = "With golden tassels of the Spirit’s grace adorned, you are the Queen of all, * shining even brighter * than the brilliance of the sun. * As such you were observed of old * in a vision, O Virgin, * as you unfurled your protective veil, * covering the people who hoped in you."

alt1.meMA.Ode1C23.ode = miscellanea_en_US_goadedes.misc.Ode1
alt1.meMA.Ode1C23.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode1C23.melody = he.h.m8_en_US_goadedes.heHE.ArmatilatinFarao.name
alt1.meMA.Ode1C23.incipit = "In the Old Testament…"
alt1.meMA.Ode1C23.text = "In the Old Testament, a cloud was covering the tabernacle of old. * Truly it prefigured * your holy protective veil. * For by its overshadowing, * O immaculate Virgin, * each day you cover the holy Church, * also you refresh her and care for her."

alt1.meMA.Ode1C24.ode = miscellanea_en_US_goadedes.misc.Ode1
alt1.meMA.Ode1C24.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode1C24.melody = he.h.m8_en_US_goadedes.heHE.ArmatilatinFarao.name
alt1.meMA.Ode1C24.incipit = "O Lady, mystically…"
alt1.meMA.Ode1C24.text = "O Lady, mystically appearing long ago in your preeminent church, * full of light and mercy, * you most splendidly displayed * the special grace that you possess * and your kindness towards us, * when you unfurled your protective veil. * Therefore we are duly extolling you."

alt1.meMA.Ode3C1H.ode = miscellanea_en_US_goadedes.misc.Ode3
alt1.meMA.Ode3C1H.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode3C1H.greekmelody = he.h.m4_en_US_goadedes.heHE.TousSousYmnologous.greekname
alt1.meMA.Ode3C1H.melody = he.h.m4_en_US_goadedes.heHE.TousSousYmnologous.melody
alt1.meMA.Ode3C1H.incipit = he.h.m4_en_US_goadedes.heHE.TousSousYmnologous.incipit
alt1.meMA.Ode3C1H.text = he.h.m4_en_US_goadedes.heHE.TousSousYmnologous.text

alt1.meMA.Ode3C11.ode = miscellanea_en_US_goadedes.misc.Ode3
alt1.meMA.Ode3C11.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode3C11.greekmelody = he.h.m4_en_US_goadedes.heHE.TousSousYmnologous.greekname
alt1.meMA.Ode3C11.melody = he.h.m4_en_US_goadedes.heHE.TousSousYmnologous.name
alt1.meMA.Ode3C11.incipit = "Your veil of protection…"
alt1.meMA.Ode3C11.text = "Your veil of protection is resplendent, * all-blameless one, and it is a source * of heavenly euphoria. * It always is bestowing grace * and mercy and salvation on those who contend with adversities."

alt1.meMA.Ode3C12.ode = miscellanea_en_US_goadedes.misc.Ode3
alt1.meMA.Ode3C12.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode3C12.melody = he.h.m4_en_US_goadedes.heHE.TousSousYmnologous.name
alt1.meMA.Ode3C12.incipit = "From time immemorial…"
alt1.meMA.Ode3C12.text = "From time immemorial, O Virgin, * with charity you have placed beneath * the dome of your protective veil * all Christian peoples everywhere. * And as of old, you still perform marvelous wonders, protecting us."

alt1.meMA.Ode3C13.ode = miscellanea_en_US_goadedes.misc.Ode3
alt1.meMA.Ode3C13.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode3C13.melody = he.h.m4_en_US_goadedes.heHE.TousSousYmnologous.name
alt1.meMA.Ode3C13.incipit = "When St. Epiphanius…"
alt1.meMA.Ode3C13.text = "When St. Epiphanius with rev’rence * gave heed to devout St. Andrew’s words, * O Virgin, he began to see * how you the Queen of heaven were * protecting all the Christians there beneath your holy protective veil."

alt1.meMA.Ode3C14.ode = miscellanea_en_US_goadedes.misc.Ode3
alt1.meMA.Ode3C14.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode3C14.melody = he.h.m4_en_US_goadedes.heHE.TousSousYmnologous.name
alt1.meMA.Ode3C14.incipit = "O Virgin, we see…"
alt1.meMA.Ode3C14.text = "O Virgin, we see the many wonders * and miracles that you work each day * by your divine protective veil, * in your maternal care for us. * And we the faithful offer you poetic praises in gratitude."

alt1.meMA.Ode3C21.ode = miscellanea_en_US_goadedes.misc.Ode3
alt1.meMA.Ode3C21.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode3C21.greekmelody = he.h.m8_en_US_goadedes.heHE.OStereosasKatArchas.greekname
alt1.meMA.Ode3C21.melody = he.h.m8_en_US_goadedes.heHE.OStereosasKatArchas.name
alt1.meMA.Ode3C21.incipit = "Your luminous protective veil…"
alt1.meMA.Ode3C21.text = "Your luminous protective veil, * O Theotokos, is flashing * bolts of light immaterial at all times, * thwarting dark and wicked schemes * of every hostile enemy, * and by your holy glory * illuminating believers’ minds."

alt1.meMA.Ode3C22.ode = miscellanea_en_US_goadedes.misc.Ode3
alt1.meMA.Ode3C22.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode3C22.melody = he.h.m8_en_US_goadedes.heHE.OStereosasKatArchas.name
alt1.meMA.Ode3C22.incipit = "O Virgin, you fulfilled…"
alt1.meMA.Ode3C22.text = "O Virgin, you fulfilled the Law * by your ineffable childbirth, * bearing Him who spoke in figures by Prophets, * and who showed the world your bright * protective veil fulfilling light * within the Law foreshadowed. * We praise your glory with sacred hymns."

alt1.meMA.Ode3C23.ode = miscellanea_en_US_goadedes.misc.Ode3
alt1.meMA.Ode3C23.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode3C23.melody = he.h.m8_en_US_goadedes.heHE.OStereosasKatArchas.name
alt1.meMA.Ode3C23.incipit = "We run with longing…"
alt1.meMA.Ode3C23.text = "We run with longing to be found * beneath your holy protection, * like the swallow’s young, each day, holy Virgin. * Please protect us from the darts * the serpent devil shoots at us. * We pray that you will grant us * a peaceful life with security."

alt1.meMA.Ode3C24.ode = miscellanea_en_US_goadedes.misc.Ode3
alt1.meMA.Ode3C24.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode3C24.melody = he.h.m8_en_US_goadedes.heHE.OStereosasKatArchas.name
alt1.meMA.Ode3C24.incipit = "To God the Logos…"
alt1.meMA.Ode3C24.text = "To God the Logos you gave birth, * and thus humanity knows you * as the cause of countless blessings, O Virgin. * Now from countless dire straits * and trials and adversities * you save those who extol you, * by your all-holy protective veil."

alt1.meMA.Ode3Kathisma1.mode = miscellanea_en_US_goadedes.misc.Mode3
alt1.meMA.Ode3Kathisma1.greekmelody = he.a.m3_en_US_goadedes.heAU.TheiasPisteos.greekname
alt1.meMA.Ode3Kathisma1.melody = he.a.m3_en_US_goadedes.heAU.TheiasPisteos.name
alt1.meMA.Ode3Kathisma1.incipit = "You, all-lauded one…"
alt1.meMA.Ode3Kathisma1.text = "You, all-lauded one, are the salvation, * the provisioning, and the protection * of faithful Orthodox Christians throughout the world. * Therefore, O Lady, we magnify and proclaim * your fervent patronage and your protective veil. * All-immaculate and pure Virgin, you protect our souls * from every hostile act of the demonic snake."

alt1.meMA.Ode4C1H.ode = miscellanea_en_US_goadedes.misc.Ode4
alt1.meMA.Ode4C1H.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode4C1H.greekmelody = he.h.m4_en_US_goadedes.heHE.OKathimenosEnDoxi.greekname
alt1.meMA.Ode4C1H.melody = he.h.m4_en_US_goadedes.heHE.OKathimenosEnDoxi.melody
alt1.meMA.Ode4C1H.incipit = he.h.m4_en_US_goadedes.heHE.OKathimenosEnDoxi.incipit
alt1.meMA.Ode4C1H.text = he.h.m4_en_US_goadedes.heHE.OKathimenosEnDoxi.text

alt1.meMA.Ode4C11.ode = miscellanea_en_US_goadedes.misc.Ode4
alt1.meMA.Ode4C11.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode4C11.greekmelody = he.h.m4_en_US_goadedes.heHE.OKathimenosEnDoxi.greekname
alt1.meMA.Ode4C11.melody = he.h.m4_en_US_goadedes.heHE.OKathimenosEnDoxi.name
alt1.meMA.Ode4C11.incipit = "You invisibly unfurl…"
alt1.meMA.Ode4C11.text = "You invisibly unfurl your resplendent protective veil, * holy Theotokos, * every day protecting, embracing us. * You give us comfort and rescue us from all distress, * and we sing to you: Glory to your glory, O Virgin."

alt1.meMA.Ode4C12.ode = miscellanea_en_US_goadedes.misc.Ode4
alt1.meMA.Ode4C12.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode4C12.melody = he.h.m4_en_US_goadedes.heHE.OKathimenosEnDoxi.name
alt1.meMA.Ode4C12.incipit = "The description of the greatness…"
alt1.meMA.Ode4C12.text = "The description of the greatness of the kindness you demonstrate * always to the faithful, * and the distribution of the gifts to us, * O blessed Lady, astonish every mind and thought. * Hence, O Virgin pure, we are extolling your graciousness."

alt1.meMA.Ode4C13.ode = miscellanea_en_US_goadedes.misc.Ode4
alt1.meMA.Ode4C13.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode4C13.melody = he.h.m4_en_US_goadedes.heHE.OKathimenosEnDoxi.name
alt1.meMA.Ode4C13.incipit = "You invisibly were present…"
alt1.meMA.Ode4C13.text = "You invisibly were present long ago in Byzantium. * To your humble servants * mystically you showed and revealed to them * your holy veil of protection, by which even now * you protect us all, O most benevolent Bride of God."

alt1.meMA.Ode4C14.ode = miscellanea_en_US_goadedes.misc.Ode4
alt1.meMA.Ode4C14.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode4C14.melody = he.h.m4_en_US_goadedes.heHE.OKathimenosEnDoxi.name
alt1.meMA.Ode4C14.incipit = "When in danger…"
alt1.meMA.Ode4C14.text = "When in danger you protect us; in enslavement you comfort us. * We have you, O Virgin, * guiding us, supporting us, helping us. * In every difficult circumstance of life we all * flee for refuge beneath your most resplendent protective veil."

alt1.meMA.Ode4C21.ode = miscellanea_en_US_goadedes.misc.Ode4
alt1.meMA.Ode4C21.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode4C21.greekmelody = he.h.m8_en_US_goadedes.heHE.SyMouIschys.greekname
alt1.meMA.Ode4C21.melody = he.h.m8_en_US_goadedes.heHE.SyMouIschys.name
alt1.meMA.Ode4C21.incipit = "Mother of God…"
alt1.meMA.Ode4C21.text = "Mother of God, * in your benevolence, you dispel * gloomy nighttime * of the passions from our hearts, because your veil overshadows us; * and you make the joyous and happy daylight of grace to shine * in us; and you illumine those who faithfully call out: * O rejoice! Bright protection of all the world!"

alt1.meMA.Ode4C22.ode = miscellanea_en_US_goadedes.misc.Ode4
alt1.meMA.Ode4C22.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode4C22.melody = he.h.m8_en_US_goadedes.heHE.SyMouIschys.name
alt1.meMA.Ode4C22.incipit = "From you did God appear…"
alt1.meMA.Ode4C22.text = "From you did God * appear as human within the world, * born of your most pure and virgin blood. O Lady, He made you to be for the world * a mighty protection and ardent help in adversities. * We come with love and longing to your veil of protection, * and you save us from dangers and cover us."

alt1.meMA.Ode4C23.ode = miscellanea_en_US_goadedes.misc.Ode4
alt1.meMA.Ode4C23.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode4C23.melody = he.h.m8_en_US_goadedes.heHE.SyMouIschys.name
alt1.meMA.Ode4C23.incipit = "O Bride of God…"
alt1.meMA.Ode4C23.text = "O Bride of God, * since you gave birth to the King of all, * you appeared as Queen of all the universe, and you were seen escorted by hosts * of the deified Saints. You have revealed to us mystically * the evidence, O Lady, of your holy protection * in a vision from heaven, O Virgin pure."

alt1.meMA.Ode4C24.ode = miscellanea_en_US_goadedes.misc.Ode4
alt1.meMA.Ode4C24.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode4C24.melody = he.h.m8_en_US_goadedes.heHE.SyMouIschys.name
alt1.meMA.Ode4C24.incipit = "We who are saved…"
alt1.meMA.Ode4C24.text = "We who are saved * from harsh disasters and trials of life * O all-lauded Lady, by your marvelous and glowing holy protective veil, * songfully extol it, for you deliver and save the souls * of Orthodox believers. And we faith we salute you: * Holy Virgin, the help of mankind, rejoice!"

alt1.meMA.Ode5C1H.ode = miscellanea_en_US_goadedes.misc.Ode5
alt1.meMA.Ode5C1H.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode5C1H.greekmelody = he.h.m4_en_US_goadedes.heHE.ExestiTaSympanta.greekname
alt1.meMA.Ode5C1H.melody = he.h.m4_en_US_goadedes.heHE.ExestiTaSympanta.melody
alt1.meMA.Ode5C1H.incipit = he.h.m4_en_US_goadedes.heHE.ExestiTaSympanta.incipit
alt1.meMA.Ode5C1H.text = he.h.m4_en_US_goadedes.heHE.ExestiTaSympanta.text

alt1.meMA.Ode5C11.ode = miscellanea_en_US_goadedes.misc.Ode5
alt1.meMA.Ode5C11.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode5C11.greekmelody = he.h.m4_en_US_goadedes.heHE.ExestiTaSympanta.greekname
alt1.meMA.Ode5C11.melody = he.h.m4_en_US_goadedes.heHE.ExestiTaSympanta.name
alt1.meMA.Ode5C11.incipit = "O Lady, your people…"
alt1.meMA.Ode5C11.text = "O Lady, your people now commemorate and celebrate * your all-holy veil of protection. * For long ago, you were seen in church mystically * covering the people who were there * faithfully extolling you, O immaculate Bride of God."

alt1.meMA.Ode5C12.ode = miscellanea_en_US_goadedes.misc.Ode5
alt1.meMA.Ode5C12.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode5C12.melody = he.h.m4_en_US_goadedes.heHE.ExestiTaSympanta.name
alt1.meMA.Ode5C12.incipit = "Immaculate Maid…"
alt1.meMA.Ode5C12.text = "Immaculate Maid, each day the spiritual lions roar, * seeking to devour us your people * who were allotted to you, O Virgin pure. * By your visitation, crush their heads. * Humble and humiliate all their arrogant insolence."

alt1.meMA.Ode5C13.ode = miscellanea_en_US_goadedes.misc.Ode5
alt1.meMA.Ode5C13.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode5C13.melody = he.h.m4_en_US_goadedes.heHE.ExestiTaSympanta.name
alt1.meMA.Ode5C13.incipit = "As we now commemorate…"
alt1.meMA.Ode5C13.text = "As we now commemorate your luminous protective veil, * thanking you we sing to you, O Virgin. * From bitter bondage and occupation of old * you saved us, and recently you trounced * the arrogant enemy who attempted to conquer us."

alt1.meMA.Ode5C14.ode = miscellanea_en_US_goadedes.misc.Ode5
alt1.meMA.Ode5C14.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode5C14.melody = he.h.m4_en_US_goadedes.heHE.ExestiTaSympanta.name
alt1.meMA.Ode5C14.incipit = "O Mother of God…"
alt1.meMA.Ode5C14.text = "O Mother of God who are the precious vessel that contained * riches of Divinity, I pray you: * Make me a vessel of grace divine, as I praise * your glory, O Maiden full of grace. * Under your protective veil I seek shelter with trust in you."

alt1.meMA.Ode5C21.ode = miscellanea_en_US_goadedes.misc.Ode5
alt1.meMA.Ode5C21.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode5C21.greekmelody = he.h.m8_en_US_goadedes.heHE.InaTiMeAposo.greekname
alt1.meMA.Ode5C21.melody = he.h.m8_en_US_goadedes.heHE.InaTiMeAposo.name
alt1.meMA.Ode5C21.incipit = "When your veil of protection…"
alt1.meMA.Ode5C21.text = "When your veil of protection, * which is like a shining cloud, O Virgin, is unfurled * over all your servants, * then, as Prophet Isaiah said long ago, * from the heat of Belial and his abuse of us it saves us; * by the grace that you have it refreshes us."

alt1.meMA.Ode5C22.ode = miscellanea_en_US_goadedes.misc.Ode5
alt1.meMA.Ode5C22.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode5C22.melody = he.h.m8_en_US_goadedes.heHE.InaTiMeAposo.name
alt1.meMA.Ode5C22.incipit = "In a mystical vision…"
alt1.meMA.Ode5C22.text = "In a mystical vision, * St. Andrew the fool for Christ beheld you as a Queen, * solemnly attended * by an escort of Saints, and he was amazed, * when he saw you, Lady, as you unfurled your holy garment, * and you covered the prayerful believers there."

alt1.meMA.Ode5C23.ode = miscellanea_en_US_goadedes.misc.Ode5
alt1.meMA.Ode5C23.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode5C23.melody = he.h.m8_en_US_goadedes.heHE.InaTiMeAposo.name
alt1.meMA.Ode5C23.incipit = "You displayed a great wonder…"
alt1.meMA.Ode5C23.text = "You displayed a great wonder * manifestly in a vision, showing how you care * for your faithful people. * You, O Lady, invisibly covered them * with your holy garment that you unfurled with your divine hands. * Therefore we all extol you and celebrate."

alt1.meMA.Ode5C24.ode = miscellanea_en_US_goadedes.misc.Ode5
alt1.meMA.Ode5C24.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode5C24.melody = he.h.m8_en_US_goadedes.heHE.InaTiMeAposo.name
alt1.meMA.Ode5C24.incipit = "Long ago in the desert…"
alt1.meMA.Ode5C24.text = "Long ago in the desert, * the people of Israel were covered by a cloud * that was bright, O Lady. * Now for us is your glowing protective veil * covering and guiding us to the light of the commandments * of your Son and protecting us every day."

alt1.meMA.Ode6C1H.ode = miscellanea_en_US_goadedes.misc.Ode6
alt1.meMA.Ode6C1H.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode6C1H.greekmelody = he.h.m4_en_US_goadedes.heHE.TinTheianTaftin.greekname
alt1.meMA.Ode6C1H.melody = he.h.m4_en_US_goadedes.heHE.TinTheianTaftin.melody
alt1.meMA.Ode6C1H.incipit = he.h.m4_en_US_goadedes.heHE.TinTheianTaftin.incipit
alt1.meMA.Ode6C1H.text = he.h.m4_en_US_goadedes.heHE.TinTheianTaftin.text

alt1.meMA.Ode6C11.ode = miscellanea_en_US_goadedes.misc.Ode6
alt1.meMA.Ode6C11.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode6C11.greekmelody = he.h.m4_en_US_goadedes.heHE.TinTheianTaftin.greekname
alt1.meMA.Ode6C11.melody = he.h.m4_en_US_goadedes.heHE.TinTheianTaftin.name
alt1.meMA.Ode6C11.incipit = "The fiery pillar…"
alt1.meMA.Ode6C11.text = "The fiery pillar in Exodus * of old guided the people of Israel. * Now your protective veil, * flashing like lightning, is guiding us * forever to salvation, all-holy Virgin pure."

alt1.meMA.Ode6C12.ode = miscellanea_en_US_goadedes.misc.Ode6
alt1.meMA.Ode6C12.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode6C12.melody = he.h.m4_en_US_goadedes.heHE.TinTheianTaftin.name
alt1.meMA.Ode6C12.incipit = "Each day unfurling…"
alt1.meMA.Ode6C12.text = "Each day unfurling your luminous * protective veil, O Virgin immaculate, * you screen us all around, * as we have frequently realized. * So what can we give back for the grace you give to us?"

alt1.meMA.Ode6C13.ode = miscellanea_en_US_goadedes.misc.Ode6
alt1.meMA.Ode6C13.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode6C13.melody = he.h.m4_en_US_goadedes.heHE.TinTheianTaftin.name
alt1.meMA.Ode6C13.incipit = "O Virgin, now even as of old…"
alt1.meMA.Ode6C13.text = "O Virgin, now even as of old, * you demonstrate in action that we indeed are your inheritance, * your special people assigned you. * Therefore all faithful Christians extol you festively."

alt1.meMA.Ode6C14.ode = miscellanea_en_US_goadedes.misc.Ode6
alt1.meMA.Ode6C14.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode6C14.melody = he.h.m4_en_US_goadedes.heHE.TinTheianTaftin.name
alt1.meMA.Ode6C14.incipit = "Your faithful people…"
alt1.meMA.Ode6C14.text = "Your faithful people who worship God * proclaim the grace He gave you to share with us. * We sing in gratitude * praising your holy protective veil. * From dangers and disaster you have delivered us."

alt1.meMA.Ode6C21.ode = miscellanea_en_US_goadedes.misc.Ode6
alt1.meMA.Ode6C21.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode6C21.greekmelody = he.h.m8_en_US_goadedes.heHE.IlasthitiMoiSotir.greekname
alt1.meMA.Ode6C21.melody = he.h.m8_en_US_goadedes.heHE.IlasthitiMoiSotir.name
alt1.meMA.Ode6C21.incipit = "You came to us…"
alt1.meMA.Ode6C21.text = "You came to us, Queen of all, * and you appeared truly luminous; * and wondrously you spread out * your most pure protective veil, * and thus you protected us. * We your servants praise you * for your generous benevolence."

alt1.meMA.Ode6C22.ode = miscellanea_en_US_goadedes.misc.Ode6
alt1.meMA.Ode6C22.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode6C22.melody = he.h.m8_en_US_goadedes.heHE.IlasthitiMoiSotir.name
alt1.meMA.Ode6C22.incipit = "The gold cherubim of old…"
alt1.meMA.Ode6C22.text = "The gold cherubim of old * covered the Ark of the Covenant; * and now your protective veil, * the all-holy Church of Christ, * O all-blessed Virgin pure, * for it overshadows * the believers, granting gifts of grace."

alt1.meMA.Ode6C23.ode = miscellanea_en_US_goadedes.misc.Ode6
alt1.meMA.Ode6C23.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode6C23.melody = he.h.m8_en_US_goadedes.heHE.IlasthitiMoiSotir.name
alt1.meMA.Ode6C23.incipit = "The ancient Israelites…"
alt1.meMA.Ode6C23.text = "The ancient Israelites * of old were led to the promised land * by a most luminous cloud. * The new Israel, the Church, * beneath your protective veil, * O all-holy Virgin, * now is guided to eternal life."

alt1.meMA.Ode6C24.ode = miscellanea_en_US_goadedes.misc.Ode6
alt1.meMA.Ode6C24.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode6C24.melody = he.h.m8_en_US_goadedes.heHE.IlasthitiMoiSotir.name
alt1.meMA.Ode6C24.incipit = "Immaculate Queen…"
alt1.meMA.Ode6C24.text = "Immaculate Queen, you set * about your people your luminous * protective veil like a fire * consuming our senseless foes; * and you save and rescue us * from their brutal madness. * Hence we glorify you gratefully."

alt1.meMA.Kontakion1.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Kontakion1.greekmelody = he.a.m8_en_US_goadedes.heAU.TiYpermacho.greekname
alt1.meMA.Kontakion1.melody = he.a.m8_en_US_goadedes.heAU.TiYpermacho.name
alt1.meMA.Kontakion1.incipit = "You were observed…"
alt1.meMA.Kontakion1.text = "You were observed to be a cloud that, glowing splendidly, * was overshadowing the Church’s people, long ago * in the imperial city, O all-pure Virgin. * Inasmuch as you protect us as our champion, * from all kinds of tribulations keep us safe and sound, * as we cry aloud: Rejoice, luminous protective veil!"

alt1.meMA.Oikos1.text = "All-holy Theotokos Virgin Mary, from heaven you lay your holy veil of protection on your people, whom you protect and save, O pure one, as we invoke your name hourly. Now as we sing with gratitude extolling your wonders, we cry out:"
alt1.meMA.Oikos12.text = "Rejoice! You are the world’s salvation. Rejoice! You protect all Christian nations!"
alt1.meMA.Oikos13.text = "Rejoice! Unusual sight for angelic hosts. Rejoice! Immovable prop of the human race."
alt1.meMA.Oikos14.text = "Rejoice! Ever-virgin Mother of Christ the Ruler over all. Rejoice! Helper and protector of all your people who believe."
alt1.meMA.Oikos15.text = "Rejoice! You have appeared when protecting Christian nations. Rejoice! You have secured victories on fields of battle."
alt1.meMA.Oikos16.text = "Rejoice! O fount of rich generosity! Rejoice! O lamp of divine humanity!"
alt1.meMA.Oikos17.text = "Rejoice! Through you we defeat adversaries. Rejoice! To you every day we sing loudly:"
alt1.meMA.Oikos18.text = "Rejoice, luminous protective veil!"

alt1.meMA.Ode7C1H.ode = miscellanea_en_US_goadedes.misc.Ode7
alt1.meMA.Ode7C1H.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode7C1H.greekmelody = he.h.m4_en_US_goadedes.heHE.OukElatrefsan.greekname
alt1.meMA.Ode7C1H.melody = he.h.m4_en_US_goadedes.heHE.OukElatrefsan.melody
alt1.meMA.Ode7C1H.incipit = he.h.m4_en_US_goadedes.heHE.OukElatrefsan.incipit
alt1.meMA.Ode7C1H.text = he.h.m4_en_US_goadedes.heHE.OukElatrefsan.text

alt1.meMA.Ode7C11.ode = miscellanea_en_US_goadedes.misc.Ode7
alt1.meMA.Ode7C11.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode7C11.greekmelody = he.h.m4_en_US_goadedes.heHE.OukElatrefsan.greekname
alt1.meMA.Ode7C11.melody = he.h.m4_en_US_goadedes.heHE.OukElatrefsan.name
alt1.meMA.Ode7C11.incipit = "Lady, Queen of all…"
alt1.meMA.Ode7C11.text = "Lady, Queen of all, * you placed us in your care and under your protective veil, * always protecting us * from malice and harsh abuse and enemy attacks * and adversity. * With songs that echo far and wide, * we extol you to the ages."

alt1.meMA.Ode7C12.ode = miscellanea_en_US_goadedes.misc.Ode7
alt1.meMA.Ode7C12.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode7C12.melody = he.h.m4_en_US_goadedes.heHE.OukElatrefsan.name
alt1.meMA.Ode7C12.incipit = "Long ago, you kept…"
alt1.meMA.Ode7C12.text = "Long ago, you kept * the capital of Constantine in your protection, for it * was dedicated to you. * O pure and all-blameless Lady, likewise you protect * by your glory now * the faithful who rely on you * and your tireless protection."

alt1.meMA.Ode7C13.ode = miscellanea_en_US_goadedes.misc.Ode7
alt1.meMA.Ode7C13.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode7C13.melody = he.h.m4_en_US_goadedes.heHE.OukElatrefsan.name
alt1.meMA.Ode7C13.incipit = "The remarkable protection…"
alt1.meMA.Ode7C13.text = "The remarkable * protection you provide to us beneath your holy veil * so clearly demonstrates * the care that you have for us, and Christians everywhere. * O immaculate, * pure Virgin, to our souls you give * surpassing peace and godly gladness."

alt1.meMA.Ode7C14.ode = miscellanea_en_US_goadedes.misc.Ode7
alt1.meMA.Ode7C14.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode7C14.melody = he.h.m4_en_US_goadedes.heHE.OukElatrefsan.name
alt1.meMA.Ode7C14.incipit = "You remained untilled…"
alt1.meMA.Ode7C14.text = "You remained untilled * and yet you tilled the Master Christ, who is the Tiller of life, * O Virgin, blameless and pure. * And you are the cause of joy for us saluting you, * singing, “Lady, rejoice! * O savior of the human race * and our sweet and caring helper!”"

alt1.meMA.Ode7C21.ode = miscellanea_en_US_goadedes.misc.Ode7
alt1.meMA.Ode7C21.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode7C21.greekmelody = he.h.m8_en_US_goadedes.heHE.TheouSynkatavasin.greekname
alt1.meMA.Ode7C21.melody = he.h.m8_en_US_goadedes.heHE.TheouSynkatavasin.name
alt1.meMA.Ode7C21.incipit = "The superessential God…"
alt1.meMA.Ode7C21.text = "The superessential God * made His abode in a living house, the womb * of the pure Theotokos. * And she was seen in her famous house of old. * She unfolded her garment and protective veil * and wondrously covered all those who rely on her."

alt1.meMA.Ode7C22.ode = miscellanea_en_US_goadedes.misc.Ode7
alt1.meMA.Ode7C22.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode7C22.melody = he.h.m8_en_US_goadedes.heHE.TheouSynkatavasin.name
alt1.meMA.Ode7C22.incipit = "Unable are we to grasp…"
alt1.meMA.Ode7C22.text = "Unable are we to grasp * the scope and magnitude of your kindness to us, * O immaculate Virgin. * As a tender and loving mother indeed * each day you feed us, protect us, and care for us. * Therefore we sing hymns in praise of your protective veil."

alt1.meMA.Ode7C23.ode = miscellanea_en_US_goadedes.misc.Ode7
alt1.meMA.Ode7C23.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode7C23.melody = he.h.m8_en_US_goadedes.heHE.TheouSynkatavasin.name
alt1.meMA.Ode7C23.incipit = "St. Andrew experienced…"
alt1.meMA.Ode7C23.text = "St. Andrew experienced * an immaterial vision, seeing you, * O immaculate Virgin, * as you unfurled your glowing protective veil * and with it covered the people who prayed to you; * and he extolled your unfathomable mighty deeds."

alt1.meMA.Ode7C24.ode = miscellanea_en_US_goadedes.misc.Ode7
alt1.meMA.Ode7C24.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode7C24.melody = he.h.m8_en_US_goadedes.heHE.TheouSynkatavasin.name
alt1.meMA.Ode7C24.incipit = "A bright cloud…"
alt1.meMA.Ode7C24.text = "A bright cloud was covering * the tabernacle of the Old Testament. * Now, immaculate Virgin, * it is your wondrous glowing protective veil * that covers over the all-holy Church of Christ, * both day and night, like the mountain of God long ago."

alt1.meMA.Ode8C1H.ode = miscellanea_en_US_goadedes.misc.Ode8
alt1.meMA.Ode8C1H.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode8C1H.greekmelody = he.h.m4_en_US_goadedes.heHE.PaidasEvageis.greekname
alt1.meMA.Ode8C1H.melody = he.h.m4_en_US_goadedes.heHE.PaidasEvageis.melody
alt1.meMA.Ode8C1H.incipit = he.h.m4_en_US_goadedes.heHE.PaidasEvageis.incipit
alt1.meMA.Ode8C1H.text = he.h.m4_en_US_goadedes.heHE.PaidasEvageis.text

alt1.meMA.Ode8C11.ode = miscellanea_en_US_goadedes.misc.Ode8
alt1.meMA.Ode8C11.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode8C11.greekmelody = he.h.m4_en_US_goadedes.heHE.PaidasEvageis.greekname
alt1.meMA.Ode8C11.melody = he.h.m4_en_US_goadedes.heHE.PaidasEvageis.name
alt1.meMA.Ode8C11.incipit = "Manifoldly, Lady Theotokos…"
alt1.meMA.Ode8C11.text = "Manifoldly, Lady Theotokos, * you showed the activity of your protective veil, * long ago with miracles, * signs, and many mighty deeds, * fighting on our behalf each day, all-holy Virgin pure. * And we, today, are in earnest extolling * your holy protection’s miracles that have saved us."

alt1.meMA.Ode8C12.ode = miscellanea_en_US_goadedes.misc.Ode8
alt1.meMA.Ode8C12.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode8C12.melody = he.h.m4_en_US_goadedes.heHE.PaidasEvageis.name
alt1.meMA.Ode8C12.incipit = "Faithfully receiving strength…"
alt1.meMA.Ode8C12.text = "Faithfully receiving strength and power, * O Lady, from your divine protective veil, * we your special people prevail * evermore and overcome * the troubles that may come and hostile foes, and we remain * uninjured by all riotous mayhem, * under your protection, all-holy Theotokos."

alt1.meMA.Ode8C13.ode = miscellanea_en_US_goadedes.misc.Ode8
alt1.meMA.Ode8C13.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode8C13.melody = he.h.m4_en_US_goadedes.heHE.PaidasEvageis.name
alt1.meMA.Ode8C13.incipit = "Virgin, from on high…"
alt1.meMA.Ode8C13.text = "Virgin, from on high will you unfurl * your holy and very radiant protective veil; * and as you did long ago, * so also now cover us. * Protect us from the imminence of war and hostile foes, * and save us from their evil intentions * and treachery, O Lady, for we are your own people."

alt1.meMA.Ode8C14.ode = miscellanea_en_US_goadedes.misc.Ode8
alt1.meMA.Ode8C14.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode8C14.melody = he.h.m4_en_US_goadedes.heHE.PaidasEvageis.name
alt1.meMA.Ode8C14.incipit = "Ever-virgin Lady Theotokos…"
alt1.meMA.Ode8C14.text = "Ever-virgin Lady Theotokos, * unfurling the veil that covered your immaculate * body, you were seen by St. * Andrew the devout fool for Christ * and godly Epiphanuis, and they were both amazed. * You covered all the people, O Maiden, * with light immaterial and heavenly glory."

alt1.meMA.Ode8C21.ode = miscellanea_en_US_goadedes.misc.Ode8
alt1.meMA.Ode8C21.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode8C21.greekmelody = he.h.m8_en_US_goadedes.heHE.TonEnOreiAgio.greekname
alt1.meMA.Ode8C21.melody = he.h.m8_en_US_goadedes.heHE.TonEnOreiAgio.name
alt1.meMA.Ode8C21.incipit = "Your all-holy protection…"
alt1.meMA.Ode8C21.text = "Your all-holy protection is providing * strength from God, light divine, * O Virgin, and salvation, * to us who walk in nighttime of the present life, * unerringly guiding us all to our final repose in life eternal."

alt1.meMA.Ode8C22.ode = miscellanea_en_US_goadedes.misc.Ode8
alt1.meMA.Ode8C22.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode8C22.melody = he.h.m8_en_US_goadedes.heHE.TonEnOreiAgio.name
alt1.meMA.Ode8C22.incipit = "When the choirs of Saints…"
alt1.meMA.Ode8C22.text = "When the choirs of Saints and Angels saw you * in your most sacred church, * O immaculate Virgin, * when you unfolded your sacred protective veil * and covered the people, they sang hymns extolling the fountain of your mercy."

alt1.meMA.Ode8C23.ode = miscellanea_en_US_goadedes.misc.Ode8
alt1.meMA.Ode8C23.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode8C23.melody = he.h.m8_en_US_goadedes.heHE.TonEnOreiAgio.name
alt1.meMA.Ode8C23.incipit = "O pure Virgin…"
alt1.meMA.Ode8C23.text = "O pure Virgin, you are the world’s protection, * even wider than that cloud * of old, and our salvation. * O Theotokos, lovingly we celebrate * the feast of your holy protection and extol your innumerable wonders."

alt1.meMA.Ode8C24.ode = miscellanea_en_US_goadedes.misc.Ode8
alt1.meMA.Ode8C24.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode8C24.melody = he.h.m8_en_US_goadedes.heHE.TonEnOreiAgio.name
alt1.meMA.Ode8C24.incipit = "In our life…"
alt1.meMA.Ode8C24.text = "In our life, we have you, all-holy Virgin, * as our well grounded hope * and mighty consolation; * and we take refuge under your protective veil, * where we are delivered from the devil’s scandals, as we extol your kindness."

alt1.meMA.Ode9C1M01.incipit = "Angels sing and magnify the Theotokos…"
alt1.meMA.Ode9C1M01.text = "Angels sing and magnify the Theotokos, * extolling her protective veil, * for she protects the congregations * of believers the world over."
alt1.meMA.Ode9C1M02.incipit = "Angels saw the veil of the Theotokos…"
alt1.meMA.Ode9C1M02.text = "Angels saw the veil of the Theotokos; * they were amazed exceedingly, * how she protects and delivers * those who rely on her assistance."
alt1.meMA.Ode9C1M03.incipit = "Angels and we humans beings honor …"
alt1.meMA.Ode9C1M03.text = "Angels and we humans beings honor * your luminous protective veil; * for you, O Lady, are protecting * all who faithfully extol you."
alt1.meMA.Ode9C1M04.incipit = "Angels and humans are magnifying…"
alt1.meMA.Ode9C1M04.text = "Angels and humans are magnifying * your luminous protective veil; * for it protects and delivers * all who honor it, O Virgin."
alt1.meMA.Ode9C1M05.incipit = "Immaculate Virgin and Theotokos…"
alt1.meMA.Ode9C1M05.text = "Immaculate Virgin and Theotokos, * deliver us, your chosen flock; * keep us beneath your protection, * and provide for us in all things."

alt1.meMA.Ode9C2M01.incipit = "O my soul, magnify the holy protection…"
alt1.meMA.Ode9C2M01.text = "O my soul, magnify the holy protection of the immaculate Virgin."
alt1.meMA.Ode9C2M02.incipit = "O my soul, magnify the glowing protection…"
alt1.meMA.Ode9C2M02.text = "O my soul, magnify the glowing protection of the only Theotokos."
alt1.meMA.Ode9C2M03.incipit = "O my soul, magnify the unoriginate…"
alt1.meMA.Ode9C2M03.text = "O my soul, magnify the unoriginate Godhead in three persons."
alt1.meMA.Ode9C2M04.incipit = "O my soul, magnify the marvelous…"
alt1.meMA.Ode9C2M04.text = "O my soul, magnify the marvelous and great deeds of the immaculate Virgin."

alt1.meMA.Ode9C1H.ode = miscellanea_en_US_goadedes.misc.Ode9
alt1.meMA.Ode9C1H.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode9C1H.greekmelody = he.h.m4_en_US_goadedes.heHE.ApasGigenis.greekname
alt1.meMA.Ode9C1H.melody = he.h.m4_en_US_goadedes.heHE.ApasGigenis.melody
alt1.meMA.Ode9C1H.incipit = he.h.m4_en_US_goadedes.heHE.ApasGigenis.incipit
alt1.meMA.Ode9C1H.text = he.h.m4_en_US_goadedes.heHE.ApasGigenis.text

alt1.meMA.Ode9C11.ode = miscellanea_en_US_goadedes.misc.Ode9
alt1.meMA.Ode9C11.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode9C11.greekmelody = he.h.m4_en_US_goadedes.heHE.ApasGigenis.greekname
alt1.meMA.Ode9C11.melody = he.h.m4_en_US_goadedes.heHE.ApasGigenis.name
alt1.meMA.Ode9C11.incipit = "Healing for our souls…"
alt1.meMA.Ode9C11.text = "Healing for our souls, * immaculate Lady, is the grace that drips like dew * from your bright protective veil * as from a cloud that is immaterial. * It cures the ills of soul and body of the faithful who sing: * Ever-Virgin, we salute you, O rejoice! * You are comfort and joy for believers all."

alt1.meMA.Ode9C12.ode = miscellanea_en_US_goadedes.misc.Ode9
alt1.meMA.Ode9C12.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode9C12.melody = he.h.m4_en_US_goadedes.heHE.ApasGigenis.name
alt1.meMA.Ode9C12.incipit = "People everywhere…"
alt1.meMA.Ode9C12.text = "People everywhere * rejoice as they keep this festive memory today, * to praise and to glorify * your many miracles, O all-blameless one. * And seeking shelter under your holy protection with faith, * O all-lauded Lady, they cry out to you: * “Please protect us, we pray, till the end of time.”"

alt1.meMA.Ode9C13.ode = miscellanea_en_US_goadedes.misc.Ode9
alt1.meMA.Ode9C13.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode9C13.melody = he.h.m4_en_US_goadedes.heHE.ApasGigenis.name
alt1.meMA.Ode9C13.incipit = "We have come today…"
alt1.meMA.Ode9C13.text = "We have come today * wholeheartedly offering with earnest gratitude * hymns expressing praise and thanks, * O all-pure Virgin, for you your protective veil. * For you have chosen us believers to provide for us. * As our Lady, you take care of everything, * and you save us from every adversity."

alt1.meMA.Ode9C14.ode = miscellanea_en_US_goadedes.misc.Ode9
alt1.meMA.Ode9C14.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meMA.Ode9C14.melody = he.h.m4_en_US_goadedes.heHE.ApasGigenis.name
alt1.meMA.Ode9C14.incipit = "Virgin, from on high…"
alt1.meMA.Ode9C14.text = "Virgin, from on high * surround us, we pray, with your divine protective veil, * as if with a mighty wall, * in the abundance of your benevolence. * And as for me who translated these hymns for you, I pray * for forgiveness of sins, Lady, and that I * be enlightened in mind and illumined in soul."

alt1.meMA.Ode9C21.ode = miscellanea_en_US_goadedes.misc.Ode9
alt1.meMA.Ode9C21.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode9C21.greekmelody = he.h.m8_en_US_goadedes.heHE.ExestiEpiTouto.greekname
alt1.meMA.Ode9C21.melody = he.h.m8_en_US_goadedes.heHE.ExestiEpiTouto.name
alt1.meMA.Ode9C21.incipit = "O Lady, being moved…"
alt1.meMA.Ode9C21.text = "O Lady, being moved by maternal love *and compassion for people who fervently rely on you, * mystically and wondrously you unfurled * over them your protective veil, * which was like that luminous cloud of old. * And we now magnify you, * proclaiming the abundance * of your concern for us, O Mother of God."

alt1.meMA.Ode9C22.ode = miscellanea_en_US_goadedes.misc.Ode9
alt1.meMA.Ode9C22.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode9C22.melody = he.h.m8_en_US_goadedes.heHE.ExestiEpiTouto.name
alt1.meMA.Ode9C22.incipit = "Your Son, who with a pillar…"
alt1.meMA.Ode9C22.text = "Your Son, who with a pillar of cloud of old * led an ungrateful people to freedom, has shown you to be * a cloud that is rational and alive, * O Virgin all-immaculate. * In your ardent care for us you protect * and save your special people, * and wondrously you guide us * into the land of immortality."

alt1.meMA.Ode9C23.ode = miscellanea_en_US_goadedes.misc.Ode9
alt1.meMA.Ode9C23.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode9C23.melody = he.h.m8_en_US_goadedes.heHE.ExestiEpiTouto.name
alt1.meMA.Ode9C23.incipit = "You raised your hands…"
alt1.meMA.Ode9C23.text = "You raised your hands in prayer to your Son and God * for your people, O Virgin, and then you mystically unfurled * over them your glowing protective veil * and covered the believers all * long ago, all-holy Mother of God. * We magnify you, Lady, * as we commemorate this * each year and celebrate it festively."

alt1.meMA.Ode9C24.ode = miscellanea_en_US_goadedes.misc.Ode9
alt1.meMA.Ode9C24.mode = miscellanea_en_US_goadedes.misc.Mode8
alt1.meMA.Ode9C24.melody = he.h.m8_en_US_goadedes.heHE.ExestiEpiTouto.name
alt1.meMA.Ode9C24.incipit = "We sing our hymns…"
alt1.meMA.Ode9C24.text = "We sing our hymns in praise of the many gifts * of your veil of protection and also its abundant grace * that we all continually enjoy. * Wholeheartedly we say to you: * As you would protect your people of old, * so now protect us also * and cover us and save us, * all-holy Virgin, till the end of our life."

alt1.meMA.Exaposteilarion1.mode = miscellanea_en_US_goadedes.misc.Mode3
alt1.meMA.Exaposteilarion1.greekmelody = he.a.m3_en_US_goadedes.heAU.OOuranonToisAstrois.greekname
alt1.meMA.Exaposteilarion1.melody = he.a.m3_en_US_goadedes.heAU.OOuranonToisAstrois.name
alt1.meMA.Exaposteilarion1.incipit = "Lady, your holy protection…"
alt1.meMA.Exaposteilarion1.text = "Lady, your holy protection * holds us beneath it like a veil; * and it protects all believers, * leading in battles to defend * your people, O Theotokos, * and guard them from any danger."

alt1.meMA.Exaposteilarion2.mode = miscellanea_en_US_goadedes.misc.Mode3
alt1.meMA.Exaposteilarion2.greekmelody = he.a.m3_en_US_goadedes.heAU.OOuranonToisAstrois.greekname
alt1.meMA.Exaposteilarion2.melody = he.a.m3_en_US_goadedes.heAU.OOuranonToisAstrois.name
alt1.meMA.Exaposteilarion2.incipit = "We who have you…"
alt1.meMA.Exaposteilarion2.text = "We who have you for protection * and for shelter in time of need * pray that you guard our nation * beneath your bright protective veil * from foes, domestic and foreign, * O Lady, by your unceasing prayers."

alt1.meMA.Lauds1.mode = miscellanea_en_US_goadedes.misc.Mode1
alt1.meMA.Lauds1.greekmelody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.greekname
alt1.meMA.Lauds1.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
alt1.meMA.Lauds1.incipit = "In every country…"
alt1.meMA.Lauds1.text = "In every country, O Christians, let us extol and praise * the pure and ever-virgin * Theotokos, our Lady. * The ally of beleaguered believers is she, * their protection and ready aid. * She offers safety and shelter to those in need. * So we honor her protective veil."

alt1.meMA.Lauds2.mode = miscellanea_en_US_goadedes.misc.Mode1
alt1.meMA.Lauds2.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
alt1.meMA.Lauds2.incipit = "Your holy veil…"
alt1.meMA.Lauds2.text = "Your holy veil of protection flashes like lightning bolts. * And like a cloud of bright light, * everyday you unfold it, * visibly protecting and guarding us all, * as we know from experience. * Whether in good times or tragedies, we have you. * So we celebrate and call you blessed."

alt1.meMA.Lauds3.mode = miscellanea_en_US_goadedes.misc.Mode1
alt1.meMA.Lauds3.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
alt1.meMA.Lauds3.incipit = "Constantinople was rescued…"
alt1.meMA.Lauds3.text = "Constantinople was rescued from perils long ago * by your divine protection * working wonders, O Virgin. * Later on the country of Greece, by your grace, * was delivered from its complete * annihilation. And Christians throughout the world * in adversity rely on you."

alt1.meMA.Lauds4.mode = miscellanea_en_US_goadedes.misc.Mode1
alt1.meMA.Lauds4.melody = he.a.m1_en_US_goadedes.heAU.TonOuranionTagmaton.name
alt1.meMA.Lauds4.incipit = "Truly amazing, O Virgin…"
alt1.meMA.Lauds4.text = "Truly amazing, O Virgin, is the concern and care * that you have shown at all times * to Christians the world over. * And that is why we seek cover every day * beneath your holy protective veil, * where we are rescued from every malignant scheme * and experience the blessings of God."

alt1.meMA.LaudsGlory.mode = miscellanea_en_US_goadedes.misc.Mode5
alt1.meMA.LaudsGlory.melody = ""
alt1.meMA.LaudsGlory.incipit = "The bounties of your protection…"
alt1.meMA.LaudsGlory.text = "The bounties of your protection, extending everywhere like the sunbeams, benefit us in many ways, O Theotokos. They expel the mistiness of disease, they repel enemy forces, they dispel the gloominess of unexpected disasters, and they bring us lasting peace. Now we entreat you, O Virgin full of grace, accept our hymns of gratitude, and be our ally, defending us till the end of time."

alt1.meMA.MM.Lauds1234as5678.text = properties_en_US_goadedes.media.key

alt1.meLI.Kontakion1.mode = me.m10.d28_en_US_goadedes.alt1.meMA.Kontakion1.mode
alt1.meLI.Kontakion1.melody = me.m10.d28_en_US_goadedes.alt1.meMA.Kontakion1.melody
alt1.meLI.Kontakion1.incipit = me.m10.d28_en_US_goadedes.alt1.meMA.Kontakion1.incipit
alt1.meLI.Kontakion1.text = me.m10.d28_en_US_goadedes.alt1.meMA.Kontakion1.text

alt1.meLI.TheotokosHymn.mode = miscellanea_en_US_goadedes.misc.Mode4
alt1.meLI.TheotokosHymnVerse.text = me.m10.d28_en_US_goadedes.alt1.meMA.Ode9C1M01.text
alt1.meLI.TheotokosHymn.text = me.m10.d28_en_US_goadedes.alt1.meMA.Ode9C1H.text

alt1.meLI.MM.CommunionHymn.text = properties_en_US_goadedes.media.key

alt1.meLI.Megalynarion.text = "You protect the believers throughout the world. * Thus Orthodox Christians celebrate your protective veil. * Everywhere the faithful rely on your protection * and magnify you, Virgin, for your defense of them. "
alt1.meLI.Megalynarion2.text = ""
