meVE.SticTheotokion.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.SticTheotokion.greekmelody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.greekname
meVE.SticTheotokion.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
meVE.SticTheotokion.incipit = "Save me, O all-pure…"
meVE.SticTheotokion.text = "Save me, O all-pure and blameless one, who have mysteriously * given birth to the Savior Christ. * First of all, I run to you, my defense and impregnable * fortress, protection, and source of holy joy, * divine refreshment and comfort of my soul. * Mother of Christ our God, * from the worm that never sleeps and from the fire * of that everlasting hell, I pray you rescue me." //similar to me.m01.d29.meVE.SticTheotokion.text

