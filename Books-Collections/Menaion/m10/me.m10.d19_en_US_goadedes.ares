meMA.Ode3Kathisma1.mode = miscellanea_en_US_goadedes.misc.Mode4
meMA.Ode3Kathisma1.greekmelody = he.a.m4_en_US_goadedes.heAU.OYpsotheisEnToStavro.greekname
meMA.Ode3Kathisma1.melody = he.a.m4_en_US_goadedes.heAU.OYpsotheisEnToStavro.notmetered
meMA.Ode3Kathisma1.incipit = "Once your heart…"
meMA.Ode3Kathisma1.text = "Once your heart was cleansed of all impurity, O Prophet Joel, you became a pure vessel of the all-holy Spirit. You demonstrated knowledge of the truth, and you fortold that in latter days the Savior and Creator would come in the flesh to earth and be revealed to the Gentiles."

