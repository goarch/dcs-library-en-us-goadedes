meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera01.greekmelody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.greekname
meVE.Stichera01.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
meVE.Stichera01.incipit = "The Holy Spirit…"
meVE.Stichera01.text = "The Holy Spirit indeed has been poured out on us who believe, * in accordance with what the Lord's * holy prophet Joel said, * when the Spirit inspired him. * Again, the Spirit reveals to us divine * and hidden mysteries. And they prophesy, * who have by grace divine * been illumined with the holy light of God * and who have received His uncreated energy."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera02.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
meVE.Stichera02.incipit = "Wondrous prophet Joel…"
meVE.Stichera02.text = "Wondrous prophet Joel, being full of words divinely inspired, * like a fountain is gushing forth * from Your holy house, O Lord, * and he waters our thirsty souls. * And he is dripping with sweetness from on high, * with which he sweetens our intellects and hearts. * When, through his virtuous * way of life, he floated high above the earth, * he was lifted up into Your holy heights, O God. "

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode8
meVE.Stichera03.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
meVE.Stichera03.incipit = "Joel, with prophetic…"
meVE.Stichera03.text = "Joel, with prophetic confidence you have in speaking to God, * as a spiritual intimate * who was given to behold * what there is to perceive on high, * implore the Master for us who faithfully * are celebrating your sacred memory, * to pardon all our sins * and bestow great mercy on our sorry souls * and allow us to partake of His divine delights."

