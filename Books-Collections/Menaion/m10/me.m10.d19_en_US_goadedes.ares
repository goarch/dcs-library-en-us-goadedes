meMA.Ode7C11.ode = miscellanea_en_US_goadedes.misc.Ode7
meMA.Ode7C11.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode7C11.greekmelody = he.h.m2_en_US_goadedes.heHE.OTinKaminonPalai.greekname
meMA.Ode7C11.melody = he.h.m2_en_US_goadedes.heHE.OTinKaminonPalai.notmetered
meMA.Ode7C11.incipit = "All-venerable Prophet…"
meMA.Ode7C11.text = "All-venerable Prophet, as you prophesied, the fountain that issues from the house of the Lord and gives drink to all has indeed come forth."

meMA.Ode7C12.ode = miscellanea_en_US_goadedes.misc.Ode7
meMA.Ode7C12.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode7C12.melody = he.h.m2_en_US_goadedes.heHE.OTinKaminonPalai.notmetered
meMA.Ode7C12.incipit = "…"
meMA.Ode7C12.text = "As Joel prophesied, You, the torrent of delight, made the torrent of rushes to bear wheat. O Lord, the God of our fathers, You are blessed!"

meMA.Ode7C1T.ode = miscellanea_en_US_goadedes.misc.Ode7
meMA.Ode7C1T.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode7C1T.melody = he.h.m2_en_US_goadedes.heHE.OTinKaminonPalai.notmetered
meMA.Ode7C1T.incipit = "…"
meMA.Ode7C1T.text = "When the Creator of all was born of a Virgin, He saved the world, which is now piously singing, “O Lord, the God of our fathers, You are blessed!”"

meMA.Ode7C21.ode = miscellanea_en_US_goadedes.misc.Ode7
meMA.Ode7C21.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Ode7C21.greekmelody = he.h.m6_en_US_goadedes.heHE.DrosovolonMenTinKaminon.greekname
