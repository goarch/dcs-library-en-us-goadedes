meMA.Ode8C11.ode = miscellanea_en_US_goadedes.misc.Ode8
meMA.Ode8C11.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode8C11.greekmelody = he.h.m2_en_US_goadedes.heHE.TonPalaiDrosisanta.greekname
meMA.Ode8C11.melody = he.h.m2_en_US_goadedes.heHE.TonPalaiDrosisanta.notmetered
meMA.Ode8C11.incipit = "Glorious Prophet…"
meMA.Ode8C11.text = "Glorious Prophet, you clearly described the ways of repentance, guaranteed by the compassionate Lord to all who come to Him in faith and sing, “Bless God and exalt Him beyond measure, unto the ages!”"

meMA.Ode8C12.ode = miscellanea_en_US_goadedes.misc.Ode8
meMA.Ode8C12.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode8C12.melody = he.h.m2_en_US_goadedes.heHE.TonPalaiDrosisanta.notmetered
meMA.Ode8C12.incipit = "…"
meMA.Ode8C12.text = "O Prophet Joel, as the servant of the Lord, you were entrusted with His mysteries. You prophesied to the people, who extol Him and say, “Bless God and exalt Him beyond measure, unto the ages!”"

meMA.Ode8C13.ode = miscellanea_en_US_goadedes.misc.Ode8
meMA.Ode8C13.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode8C13.melody = he.h.m2_en_US_goadedes.heHE.TonPalaiDrosisanta.notmetered
meMA.Ode8C13.incipit = "…"
meMA.Ode8C13.text = "AS Joel prophesied, the rivers of Judah, namely the Lord's glorious Apostles, pour out fountains of miracles, watering all who sing, “Bless God and exalt Him beyond measure, unto the ages!”"

meMA.Ode8C1T.ode = miscellanea_en_US_goadedes.misc.Ode8
meMA.Ode8C1T.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode8C1T.melody = he.h.m2_en_US_goadedes.heHE.TonPalaiDrosisanta.notmetered
meMA.Ode8C1T.incipit = "…"
meMA.Ode8C1T.text = "O all-blameless Lady, you gave birth to Christ in one composite hypostasis of two essences, and you remained a pure virgin. We extol Him sing, “Bless Christ and exalt Him beyond measure, unto the ages!”"

