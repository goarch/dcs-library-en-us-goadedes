meMA.Ode6C11.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C11.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode6C11.greekmelody = he.h.m2_en_US_goadedes.heHE.AvyssosAmartimaton.greekname
meMA.Ode6C11.melody = he.h.m2_en_US_goadedes.heHE.AvyssosAmartimaton.notmetered
meMA.Ode6C11.incipit = "Glorious Joel…"
meMA.Ode6C11.text = "Glorious Joel, the rivers of your prophecies flow and water us, dripping sweetness that feeds the souls of us who faithfully honor you."

meMA.Ode6C12.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C12.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode6C12.melody = he.h.m2_en_US_goadedes.heHE.AvyssosAmartimaton.notmetered
meMA.Ode6C12.incipit = "…"
meMA.Ode6C12.text = "O Prophet and divine herald Joel, you are an allegorical mountain of prophecy, dripping sweetness, as all-wise preacher of godliness."

meMA.Ode6C13.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C13.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode6C13.melody = he.h.m2_en_US_goadedes.heHE.AvyssosAmartimaton.notmetered
meMA.Ode6C13.incipit = "…"
meMA.Ode6C13.text = "O Prophet of God, since you have confidence towards God, pray for us and protect us who celebrate your glorious, solemn memory with love."

meMA.Ode6C1T.ode = miscellanea_en_US_goadedes.misc.Ode6
meMA.Ode6C1T.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode6C1T.melody = he.h.m2_en_US_goadedes.heHE.AvyssosAmartimaton.notmetered
meMA.Ode6C1T.incipit = "…"
meMA.Ode6C1T.text = "O immaculate Lady, Mother of the the never-setting Light, illumine our hearts, as we faithfully glorify you and your Son who was ineffably born of you."

