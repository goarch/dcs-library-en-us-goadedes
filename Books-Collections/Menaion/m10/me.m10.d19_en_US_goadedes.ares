meMA.Ode9C11.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C11.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode9C11.greekmelody = he.h.m2_en_US_goadedes.heHE.IEnOuranois.greekname
meMA.Ode9C11.melody = he.h.m2_en_US_goadedes.heHE.IEnOuranois.notmetered
meMA.Ode9C11.incipit = "As an expounder…"
meMA.Ode9C11.text = "As an expounder of God's oracles, together with the other Prophets you now rejoice with gladness in the heavenly tabernacles."

meMA.Ode9C12.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C12.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode9C12.melody = he.h.m2_en_US_goadedes.heHE.IEnOuranois.notmetered
meMA.Ode9C12.incipit = "…"
meMA.Ode9C12.text = "O all-blessed Joel, Prophet of God, from heaven watch over us who reverently glorify you."

meMA.Ode9C13.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C13.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode9C13.melody = he.h.m2_en_US_goadedes.heHE.IEnOuranois.notmetered
meMA.Ode9C13.incipit = "…"
meMA.Ode9C13.text = "Instructed by God, Joel has shown us the short way to salvation, namely through repentance."

meMA.Ode9C1T.ode = miscellanea_en_US_goadedes.misc.Ode9
meMA.Ode9C1T.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode9C1T.melody = he.h.m2_en_US_goadedes.heHE.IEnOuranois.notmetered
meMA.Ode9C1T.incipit = "…"
meMA.Ode9C1T.text = "O Mother of God, by giving birth to our compassionate Lord and Savior, you lifted us who were fallen."

