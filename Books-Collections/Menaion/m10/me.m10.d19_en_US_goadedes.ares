meMA.Ode5C11.ode = miscellanea_en_US_goadedes.misc.Ode5
meMA.Ode5C11.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode5C11.greekmelody = he.h.m2_en_US_goadedes.heHE.TisNyktosDielthousis.greekname
meMA.Ode5C11.melody = he.h.m2_en_US_goadedes.heHE.TisNyktosDielthousis.notmetered
meMA.Ode5C11.incipit = "Joel, the prophet…"
meMA.Ode5C11.text = "Joel, the prophet of God, expressly foretold the coming of Christ, and that He would come and save the human race from the wickedness of idols."

meMA.Ode5C12.ode = miscellanea_en_US_goadedes.misc.Ode5
meMA.Ode5C12.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode5C12.melody = he.h.m2_en_US_goadedes.heHE.TisNyktosDielthousis.notmetered
meMA.Ode5C12.incipit = "…"
meMA.Ode5C12.text = "O Prophet, with all your being you sought what is incomprehensible, from where you drew the grace of prophecy, and you proclaimed righteousness."

meMA.Ode5C13.ode = miscellanea_en_US_goadedes.misc.Ode5
meMA.Ode5C13.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode5C13.melody = he.h.m2_en_US_goadedes.heHE.TisNyktosDielthousis.notmetered
meMA.Ode5C13.incipit = "…"
meMA.Ode5C13.text = "All-blessed Joel, pray that we who extol you be saved from every assault and may receive divine grace and light, by your intercessions."

meMA.Ode5C1T.ode = miscellanea_en_US_goadedes.misc.Ode5
meMA.Ode5C1T.mode = miscellanea_en_US_goadedes.misc.Mode2
meMA.Ode5C1T.melody = he.h.m2_en_US_goadedes.heHE.TisNyktosDielthousis.notmetered
meMA.Ode5C1T.incipit = "…"
meMA.Ode5C1T.text = "O Lady of the world, all-holy Virgin, pray that we who proclaim you to be Theotokos be rescued from our countless sins and from life's calamities, by your intercessions."

meMA.Ode5C21.ode = miscellanea_en_US_goadedes.misc.Ode5
meMA.Ode5C21.mode = miscellanea_en_US_goadedes.misc.Mode6
meMA.Ode5C21.greekmelody = he.h.m6_en_US_goadedes.heHE.ToTheioFengeiSou.greekname
meMA.Ode5C21.melody = he.h.m6_en_US_goadedes.heHE.ToTheioFengeiSou.name
meMA.Ode5C21.incipit = "…"
meMA.Ode5C21.text = ""

