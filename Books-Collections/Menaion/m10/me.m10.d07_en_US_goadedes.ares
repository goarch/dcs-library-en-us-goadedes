meVE.SticTheotokion.mode = miscellanea_en_US_goadedes.misc.Mode4
meVE.SticTheotokion.greekmelody = he.a.m4_en_US_goadedes.heAU.EdokasSimeiosin.greekname
meVE.SticTheotokion.melody = he.a.m4_en_US_goadedes.heAU.EdokasSimeiosin.name
meVE.SticTheotokion.incipit = "Since you bore the Sun…"
meVE.SticTheotokion.text = "Since you bore the Sun of Righteousness, I pray you, all-blameless one, * to dispel the all the darkness of the passions afflicting me. * And repel the serpent * that deceives my soul, tempting me to ponder and assent * to sinful pleasures and foolish vanity; * and drive it far away from me, your sorry servant, O Virgin pure, * and assist me to reach the goal of dispassion’s tranquility."

