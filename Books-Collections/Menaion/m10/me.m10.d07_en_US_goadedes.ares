meVE.Stichera01.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Stichera01.greekmelody = he.a.m1_en_US_goadedes.heAU.PaneffimoiMartyres.greekname
meVE.Stichera01.melody = he.a.m1_en_US_goadedes.heAU.PaneffimoiMartyres.name
meVE.Stichera01.incipit = "Bacchus and Sergius, the Lord…"
meVE.Stichera01.text = "Bacchus and Sergius, the Lord * of glory adorned you with the gifts of healing and miracles. He showed you forth to be * glorious and famous * wonder-workers in the world. * Through you He heals the sick. Therefore intercede with Him on our behalf, * to bestow His peace upon our souls * and implore Him to give us the great mercy."

meVE.Stichera02.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Stichera02.melody = he.a.m1_en_US_goadedes.heAU.PaneffimoiMartyres.name
meVE.Stichera02.incipit = "Bacchus and Sergius, on earth…"
meVE.Stichera02.text = "Bacchus and Sergius, on earth * you competed valiantly; and now in heaven you celebrate together, as you stand * with the hosts Angels * near the Holy Trinity, * in glory and delight. Therefore intercede with Christ on our behalf, * to bestow His peace upon our souls * and implore Him to give us the great mercy."

meVE.Stichera03.mode = miscellanea_en_US_goadedes.misc.Mode1
meVE.Stichera03.melody = he.a.m1_en_US_goadedes.heAU.PaneffimoiMartyres.name
meVE.Stichera03.incipit = "Bacchus and Sergius, we know…"
meVE.Stichera03.text = "Bacchus and Sergius, we know * that you both courageously destroyed the force of the enemy. You drove away the grave * error of the idols, * and with God-inspired words * you preached that Christ is King. Therefore intercede with Him on our behalf, * to bestow His peace upon our souls * and implore Him to give us the great mercy."

