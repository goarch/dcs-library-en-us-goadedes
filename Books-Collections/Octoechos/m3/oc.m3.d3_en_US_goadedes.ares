ocVE.Stichera1.mode = miscellanea_en_US_goadedes.misc.Mode3
ocVE.Stichera1.greekmelody = he.a.m3_en_US_goadedes.heAU.MegaliTouStavrouSou.greekname
ocVE.Stichera1.melody = he.a.m3_en_US_goadedes.heAU.MegaliTouStavrouSou.name
ocVE.Stichera1.incipit = "…"
ocVE.Stichera1.text = ""

ocVE.Stichera2.mode = miscellanea_en_US_goadedes.misc.Mode3
ocVE.Stichera2.melody = he.a.m3_en_US_goadedes.heAU.MegaliTouStavrouSou.name
ocVE.Stichera2.incipit = "Now I who am condemned…"
ocVE.Stichera2.text = "Now I who am condemned no longer have the confidence * to lift my eyes and look up into the heights of heaven, * as the multitude of my offences drags me down. * I pray to You, O Savior, as did the publican, * “Have mercy on me, the sinner.”"

ocVE.Stichera3.mode = miscellanea_en_US_goadedes.misc.Mode3
ocVE.Stichera3.melody = he.a.m3_en_US_goadedes.heAU.MegaliTouStavrouSou.name
ocVE.Stichera3.incipit = "…"
ocVE.Stichera3.text = ""

ocVE.Stichera4.mode = miscellanea_en_US_goadedes.misc.Mode3
ocVE.Stichera4.greekmelody = he.a.m3_en_US_goadedes.heAU.MegaliTouStavrouSou.greekname
ocVE.Stichera4.melody = he.a.m3_en_US_goadedes.heAU.MegaliTouStavrouSou.name
ocVE.Stichera4.incipit = "O Baptist of the Savior…"
ocVE.Stichera4.text = "O Baptist of the Savior, you have shined like morning light * throughout the world, illumining hearts of the believers * who honor you as the glorious Forerunner. * We pray that you illumine both our minds and souls, * so that we may extol you."

ocVE.Stichera5.mode = miscellanea_en_US_goadedes.misc.Mode3
ocVE.Stichera5.melody = he.a.m3_en_US_goadedes.heAU.MegaliTouStavrouSou.name
