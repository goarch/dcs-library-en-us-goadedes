ocMA.Kathisma22.mode = miscellanea_en_US_goadedes.misc.Mode5
ocMA.Kathisma22.melody = ""
ocMA.Kathisma22.incipit = "O Savior, let Your servants repose…"
ocMA.Kathisma22.text = "O Savior, let Your servants repose with the righteous, and let them dwell in Your courts, according to the Scriptures. Overlook their voluntary and involuntary offenses, every sin committed knowingly or unknowingly, benevolent Lord."

ocMA.Kathisma23.mode = miscellanea_en_US_goadedes.misc.Mode5
ocMA.Kathisma23.greekmelody = he.a.m5_en_US_goadedes.heAU.TonSynanarchonLogon.greekname
ocMA.Kathisma23.melody = he.a.m5_en_US_goadedes.heAU.TonSynanarchonLogon.name
ocMA.Kathisma23.incipit = "You conceived and you carried…"
ocMA.Kathisma23.text = "You conceived and you carried the Savior of the world, * born in two perfect natures in one hypostasis, * O all-holy, ever-virgin Mother of God. * Pray to Him as do the Prophets, the Martyrs, and devout * monastic Saints, and implore Him * for lasting peace in the whole world, * and entreat Him to save our souls."

