ocMA.Aposticha1.mode = miscellanea_en_US_goadedes.misc.Mode5
ocMA.Aposticha1.greekmelody = he.a.m5_en_US_goadedes.heAU.ChairoisAskitikon.greekname
ocMA.Aposticha1.melody = he.a.m5_en_US_goadedes.heAU.ChairoisAskitikon.name
ocMA.Aposticha1.incipit = "Settle the souls…"
ocMA.Aposticha1.text = "Settle the souls of those who have passed * where the resplendence of Your countenance shines on them, * to lie down in greenest pastures, O most compassionate Christ, * beside the still waters of divine delight. * And grant them to be at rest in the bosom of Abraham, * there where Your light is most especially visible, * and the fountains of Your benevolence overflow, * there where the choirs of the just continually celebrate, * ever extolling Your goodness, in exultation and songs of joy. * We pray You have mercy * on Your servants and You grant them to dwell with all Your saints."

