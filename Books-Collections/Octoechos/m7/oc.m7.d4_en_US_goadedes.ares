ocBK.ModeNaked = miscellanea_en_US_goadedes.misc.Mode7.naked

ocVE.Stichera1.mode = miscellanea_en_US_goadedes.misc.Mode7
ocVE.Stichera1.greekmelody = he.a.m7_en_US_goadedes.heAU.OukEtiKolyometha.greekname
ocVE.Stichera1.melody = he.a.m7_en_US_goadedes.heAU.OukEtiKolyometha.name
ocVE.Stichera1.incipit = "O Savior, You were nailed…"
ocVE.Stichera1.text = "O Savior, You were nailed to a tree by villains. * You were able thus by a tree to stay death. * Glory to You, O Lord."

ocVE.Stichera2.mode = miscellanea_en_US_goadedes.misc.Mode7
ocVE.Stichera2.melody = he.a.m7_en_US_goadedes.heAU.OukEtiKolyometha.name
ocVE.Stichera2.incipit = "You willingly endured…"
ocVE.Stichera2.text = "You willingly endured being struck, O Master, * so that You might free humanity from bondage. * Glory to You, O Lord!"

ocVE.Stichera3.mode = miscellanea_en_US_goadedes.misc.Mode7
ocVE.Stichera3.melody = he.a.m7_en_US_goadedes.heAU.OukEtiKolyometha.name
