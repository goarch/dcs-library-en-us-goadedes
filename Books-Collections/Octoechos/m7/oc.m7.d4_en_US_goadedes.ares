ocVE.Stichera3.text = ""

ocVE.Stichera4.mode = miscellanea_en_US_goadedes.misc.Mode7
ocVE.Stichera4.greekmelody = he.a.m7_en_US_goadedes.heAU.OukEtiKolyometha.greekname
ocVE.Stichera4.melody = he.a.m7_en_US_goadedes.heAU.OukEtiKolyometha.name
ocVE.Stichera4.incipit = "Let us salute…"
ocVE.Stichera4.text = "Let us salute the Mother of God and cry out, * as did the Archangel, “Rejoice! You are blessed * and all pure! Glory to you!”"

