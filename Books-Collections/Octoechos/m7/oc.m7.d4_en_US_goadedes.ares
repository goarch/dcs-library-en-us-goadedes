ocMA.Kathisma21.mode = miscellanea_en_US_goadedes.misc.Mode7
ocMA.Kathisma21.greekmelody = he.a.m7_en_US_goadedes.heAU.PyrosFoteinoteron.greekname
ocMA.Kathisma21.melody = he.a.m7_en_US_goadedes.heAU.PyrosFoteinoteron.name
ocMA.Kathisma21.incipit = "O Christ, You gave power…"
ocMA.Kathisma21.text = "O Christ, You gave power to the wood of Your holy Cross, * for it is more luminous than flames of fire and more caustic; * for it burns away the sins of those in illness, * and it illumines the hearts of those extolling * Your voluntary crucifixion. O Christ our God, glory to You! "

ocMA.Kathisma22.mode = miscellanea_en_US_goadedes.misc.Mode7
ocMA.Kathisma22.melody = ""
ocMA.Kathisma22.incipit = "The Church worships You…"
ocMA.Kathisma22.text = "The Church worships You, O Christ God, and venerates the cedar, pine, and cypress. And she prays to You, “Grant success to our government, through the Theotokos, and have mercy on us.”"

