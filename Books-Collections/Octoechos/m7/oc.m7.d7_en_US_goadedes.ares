ocMA.Aposticha1.mode = miscellanea_en_US_goadedes.misc.Mode7
ocMA.Aposticha1.greekmelody = he.a.m7_en_US_goadedes.heAU.KatafronisantesPanton.greekname
ocMA.Aposticha1.melody = he.a.m7_en_US_goadedes.heAU.KatafronisantesPanton.name
ocMA.Aposticha1.incipit = "You who alone are immortal…"
ocMA.Aposticha1.text = "You who alone are immortal were seen as dead on the Cross, O Lord, * and as mortal You were buried inside a sepulcher; * and from death and decay and destruction You saved humanity. * We entreat You, who are a limitless ocean of tender love * and a well of benevolence, for the souls of Your servants * who have departed from us, that You grant them repose."

ocMA.Aposticha2.mode = miscellanea_en_US_goadedes.misc.Mode7
ocMA.Aposticha2.greekmelody = he.a.m7_en_US_goadedes.heAU.KatafronisantesPanton.greekname
ocMA.Aposticha2.melody = he.a.m7_en_US_goadedes.heAU.KatafronisantesPanton.name
ocMA.Aposticha2.incipit = "We now implore You…"
ocMA.Aposticha2.text = "We now implore You, O Good One, to shine the rays of Your divine light * on those who passed away to You, that they might experience * the impeccable sweetness of Your beauty and handsomeness * and behold Your shining appearance in the uncreated light. * May they join the angelic hosts in the chorus around You, * the King of glory and Master and Lord of all."

ocMA.Aposticha3.mode = miscellanea_en_US_goadedes.misc.Mode7
ocMA.Aposticha3.greekmelody = he.a.m7_en_US_goadedes.heAU.KatafronisantesPanton.greekname
ocMA.Aposticha3.melody = he.a.m7_en_US_goadedes.heAU.KatafronisantesPanton.name
ocMA.Aposticha3.incipit = "You are a generous treasure…"
ocMA.Aposticha3.text = "You are a generous treasure of lavish kindness and benevolence; * and the abundance of Your gifts is truly magnificent. * So we pray that You settle those departed to You, O God, * in the land wherein Your elect are, to dwell in a place of rest, * in the comforts of Paradise, in the house of Your glory, * and in the prudent and wise virgins’ bridal hall."

ocMA.AposTheotokion.mode = miscellanea_en_US_goadedes.misc.Mode7
ocMA.AposTheotokion.greekmelody = he.a.m7_en_US_goadedes.heAU.KatafronisantesPanton.greekname
ocMA.AposTheotokion.melody = he.a.m7_en_US_goadedes.heAU.KatafronisantesPanton.name
ocMA.AposTheotokion.incipit = "When the Redeemer…"
ocMA.AposTheotokion.text = "When the Redeemer became flesh from you, His Mother, He fulfilled the Law. * Before this, no one by the Law could ever be justified. * But now Christ justified us, since for us He was crucified. * Holy Virgin, since you have intimate access to Him who is * your compassionate Son, we pray that You ask Him to grant rest * to the departed who passed on with faith in God."

