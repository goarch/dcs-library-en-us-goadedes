ocMA.Kathisma31.mode = miscellanea_en_US_goadedes.misc.Mode6
ocMA.Kathisma31.greekmelody = he.a.m6_en_US_goadedes.heAU.ElpisTouKosmouAgathi.greekname
ocMA.Kathisma31.melody = he.a.m6_en_US_goadedes.heAU.ElpisTouKosmouAgathi.name
ocMA.Kathisma31.incipit = "O Cross, all-holy…"
ocMA.Kathisma31.text = "O Cross, all-holy and all-blest, * the destroyer of demons, * and the physician of the sick, * mighty guard of the faithful, * the victory of pious emperors of old, * we Orthodox believers ever boast of you, * the strength of the Church of Christ. * Become for us a force * that protects and defends us."

