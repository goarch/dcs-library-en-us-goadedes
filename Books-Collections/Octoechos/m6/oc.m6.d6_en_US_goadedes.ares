A_Resource_Whose_Name = oc.m6.d6_en_US_goadedes

ocBK.ModeNaked = miscellanea_en_US_goadedes.misc.Mode6.naked

ocVE.Stichera1.mode = miscellanea_en_US_goadedes.misc.Mode6
ocVE.Stichera1.greekmelody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.greekname
ocVE.Stichera1.melody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.name
ocVE.Stichera1.incipit = "Longsuffering, benevolent…"
ocVE.Stichera1.text = "Longsuffering, benevolent, * all-merciful, compassionate * God my Savior, * for the human race You bore * slaughter and crucifixion! * We marvel at Your patience * and glorify Your tender mercies, O Lord."

ocVE.Stichera2.mode = miscellanea_en_US_goadedes.misc.Mode6
ocVE.Stichera2.melody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.name
ocVE.Stichera2.incipit = "Forbearing Lord…"
ocVE.Stichera2.text = "Forbearing Lord, You patiently * bore slaps and jeers and finally * crucifixion, * in Your wish to rescue all * from the hands of the deceiver, * for us enduring all things, * O most benevolent Giver of life."

ocVE.Stichera3.mode = miscellanea_en_US_goadedes.misc.Mode6
ocVE.Stichera3.melody = he.a.m6_en_US_goadedes.heAU.TriimerosAnestis.name
ocVE.Stichera3.incipit = "…"
ocVE.Stichera3.text = ""

ocVE.Stichera4.mode = miscellanea_en_US_goadedes.misc.Mode6
ocVE.Stichera4.greekmelody = he.a.m6_en_US_goadedes.heAU.IApegnosmeni.greekname
ocVE.Stichera4.melody = he.a.m6_en_US_goadedes.heAU.IApegnosmeni.name
ocVE.Stichera4.incipit = "Virgin, I implore you…"
ocVE.Stichera4.text = "Virgin, I implore you that you will straighten * my soul that is bent over, as it carries * the difficult burden of my many offences; * for you are the mother of the Savior * who lifted up the fallen, * and you can easily convince Him * when you speak as His mother. * I implore you, that in your great mercy * and by your holy intercession on my behalf, * tear up the record of all my sins."

ocVE.Stichera5.mode = miscellanea_en_US_goadedes.misc.Mode6
ocVE.Stichera5.melody = he.a.m6_en_US_goadedes.heAU.IApegnosmeni.name
