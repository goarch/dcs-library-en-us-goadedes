ocVE.Stichera2.mode = miscellanea_en_US_goadedes.misc.Mode2
ocVE.Stichera2.melody = he.a.m2_en_US_goadedes.heAU.OteEkTouXylou.name
ocVE.Stichera2.incipit = "Christ, You are the eminently good…"
ocVE.Stichera2.text = "Christ, You are the eminently good, * singularly placable Logos, supremely tolerant. * Tender-loving Lord, I come to You and fervently pray * and cry out to You: I have sinned. * I beg You to save me. * Save me who am prodigal, in Your compassion, O God, * so that I may gratefully cry out: * Please forgive me, and I shall go on * living by Your goodness and benevolence."

