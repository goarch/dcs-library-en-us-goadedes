ocMA.Kathisma11.mode = miscellanea_en_US_goadedes.misc.Mode2
ocMA.Kathisma11.melody = ""
ocMA.Kathisma11.incipit = "My transgressions are like waves…"
ocMA.Kathisma11.text = "My transgressions are like waves that crash against me, and my many offences agitate me, as if I were alone in a boat on the high seas. I pray You lead me through repentance to a tranquil harbor, O Lord, and save me."

ocMA.Kathisma12.mode = miscellanea_en_US_goadedes.misc.Mode2
ocMA.Kathisma12.melody = ""
ocMA.Kathisma12.incipit = "O Lord, I am like that fig tree…"
ocMA.Kathisma12.text = "O Lord, I am like that fig tree, on which there was no fruit, for I have not produced any fruits of compunction. I am fearful that I will be cut down, and I am terrified by the unquenchable fire. So I implore You, before that fateful torment, to allow me time for repentance and to save me."

ocMA.Kathisma13.mode = miscellanea_en_US_goadedes.misc.Mode2
ocMA.Kathisma13.greekmelody = he.a.m2_en_US_goadedes.heAU.EfsplagchniasYparchousa.greekname
ocMA.Kathisma13.melody = he.a.m2_en_US_goadedes.heAU.EfsplagchniasYparchousa.melody
ocMA.Kathisma13.incipit = he.a.m2_en_US_goadedes.heAU.EfsplagchniasYparchousa.incipit
ocMA.Kathisma13.text = he.a.m2_en_US_goadedes.heAU.EfsplagchniasYparchousa.text

ocMA.Kathisma21.mode = miscellanea_en_US_goadedes.misc.Mode2
ocMA.Kathisma21.melody = ""
ocMA.Kathisma21.incipit = "David said, Have mercy…"
ocMA.Kathisma21.text = "David said, “Have mercy on me.” And likewise I cry out, “I have sinned, O Savior. I pray You blot out my sins, through my repentance, and have mercy on me.”"

ocMA.Kathisma22.mode = miscellanea_en_US_goadedes.misc.Mode2
ocMA.Kathisma22.melody = ""
ocMA.Kathisma22.incipit = "For the two sins he committed…"
ocMA.Kathisma22.text = "For the two sins he committed, David grieved and cried, “Have mercy on me, O God; have mercy on me!” And I, for my countless transgressions, pray to You. He wet his couch with many tears, and I cannot produce a single teardrop. I am lost! So I entreat You: “Have mercy on me, O God, according to Your great mercy!”"

ocMA.Kathisma23.mode = miscellanea_en_US_goadedes.misc.Mode2
ocMA.Kathisma23.melody = ""
ocMA.Kathisma23.incipit = "…"
ocMA.Kathisma23.text = ""

ocMA.Kathisma31.mode = miscellanea_en_US_goadedes.misc.Mode2
ocMA.Kathisma31.greekmelody = he.a.m2_en_US_goadedes.heAU.EfsplagchniasYparchousa.greekname
ocMA.Kathisma31.melody = he.a.m2_en_US_goadedes.heAU.EfsplagchniasYparchousa.name
ocMA.Kathisma31.incipit = "O all-holy incorporeal hosts…"
ocMA.Kathisma31.text = "O all-holy incorporeal hosts, * we implore you to pray for us to our good God and Master, * that He spare us in that hour on Judgment Day, * and release us from the bitter punishment. * We earnestly run to you * for protection from the every threat * of demons and from all * the sinful passions that darken our souls."

ocMA.Kathisma32.mode = miscellanea_en_US_goadedes.misc.Mode2
ocMA.Kathisma32.melody = ""
ocMA.Kathisma32.incipit = "The holy Martyrs had You…"
ocMA.Kathisma32.text = "The holy Martyrs had You, who covers heaven with clouds, as a cover in the world, and thus they endured when the villains tortured them, and they negated idolatry. By their intercessions for us, O Savior, free us from the unseen enemy and save us."

ocMA.Kathisma33.mode = miscellanea_en_US_goadedes.misc.Mode2
ocMA.Kathisma33.melody = ""
ocMA.Kathisma33.incipit = "Who ever heard of a mother…"
ocMA.Kathisma33.text = "Who ever heard of a mother who was virgin? Who ever knew of a virgin who was a mother? Everything about you is extraordinary, O Theotokos. Therefore with faith we magnify you."

