ocMA.Kathisma11.mode = miscellanea_en_US_goadedes.misc.Mode8
ocMA.Kathisma11.melody = ""
ocMA.Kathisma11.incipit = "O Lord, I beg You look…"
ocMA.Kathisma11.text = "O Lord, I beg You look at my low condition with a compassionate expression. For my life is passing little by little, and I have not done anything to merit salvation. Therefore I implore You: O Lord, look at my low condition with a compassionate expression, and save me."

ocMA.Kathisma12.mode = miscellanea_en_US_goadedes.misc.Mode8
ocMA.Kathisma12.greekmelody = he.a.m8_en_US_goadedes.heAU.TinSofianKaiLogon.greekname
ocMA.Kathisma12.melody = he.a.m8_en_US_goadedes.heAU.TinSofianKaiLogon.name
ocMA.Kathisma12.incipit = "O my soul, keep the thought…"
ocMA.Kathisma12.text = "O my soul, keep the thought of that fearful day * in the front of your mind, and be vigilant; * and trimming your oil lamp, keep it lit with the virtues. * For you know not the day nor the hour the cry will come * to you specifically, saying, “Behold, your Bridegroom is here!” * Therefore, O my soul, always watch lest you slumber * and be left outside knocking like those five foolish maidens. * But continue in vigilance, * so that you may meet Christ God with abundant oil, and He give to you * the heavenly bridal room of His glory divine."

ocMA.Kathisma13.mode = miscellanea_en_US_goadedes.misc.Mode8
ocMA.Kathisma13.greekmelody = he.a.m8_en_US_goadedes.heAU.TinSofianKaiLogon.greekname
ocMA.Kathisma13.melody = he.a.m8_en_US_goadedes.heAU.TinSofianKaiLogon.name
ocMA.Kathisma13.incipit = "The Creator and Master of all…"
ocMA.Kathisma13.text = "The Creator and Master of all the world, * who took flesh from your all-pure and holy womb, * made you, the all-blameless Maid, * the protectress of humanity. * For this reason all we faithful now have recourse to you, * and we ask you, O Lady, to be forgiven our offenses, * and to be delivered from eternal perdition * We pray you to rescue us from all punishments that are there. * And with faith we cry out to you: * Intercede with Christ our God * that He grant forgiveness of offenses * to those who faithfully run to you for shelter, O Bride of God"

ocMA.Kathisma21.mode = miscellanea_en_US_goadedes.misc.Mode8
ocMA.Kathisma21.melody = ""
ocMA.Kathisma21.incipit = "As if the Judge were present…"
ocMA.Kathisma21.text = "As if the Judge were present, be anxious, O my soul, and keep in mind the thought of the hour of that fearful day. For the judgment is merciless to those who showed no mercy. So before the end cry aloud, “Spare me, O my Savior, for You are supremely benevolent.”"

ocMA.Kathisma22.mode = miscellanea_en_US_goadedes.misc.Mode8
ocMA.Kathisma22.melody = ""
ocMA.Kathisma22.incipit = "Like the sinful woman…"
ocMA.Kathisma22.text = "Like the sinful woman, I come to You to be forgiven, and instead of perfume, I offer You my heartfelt tears, O Christ God, so that You will pity me, as You did her, O Savior, and grant to me forgiveness of sins. For like her, I cry to You, “Free me from the mud of my sinful deeds!”"

ocMA.Kathisma23.mode = miscellanea_en_US_goadedes.misc.Mode8
ocMA.Kathisma23.greekmelody = he.a.m8_en_US_goadedes.heAU.ToProstachthen.greekname
ocMA.Kathisma23.melody = he.a.m8_en_US_goadedes.heAU.ToProstachthen.name
ocMA.Kathisma23.incipit = "…"
ocMA.Kathisma23.text = ""

ocMA.Kathisma31.mode = miscellanea_en_US_goadedes.misc.Mode8
ocMA.Kathisma31.greekmelody = he.a.m8_en_US_goadedes.heAU.TinSofianKaiLogon.greekname
ocMA.Kathisma31.melody = he.a.m8_en_US_goadedes.heAU.TinSofianKaiLogon.name
ocMA.Kathisma31.incipit = "For how long…"
ocMA.Kathisma31.text = "For how long will you rashly insist to live * with indifference and laziness, O my soul? * Wake up from your apathy as from sleep, O pathetic fool. * Recollect your sinful deeds and moan with anxiety, * and shudder at the thought of the verdict the Judge will pronounce. * What kind of defense will you have in that hour? * And how do you expect to be saved from the future fire, if you refuse to correct yourself? * Before the end, cry out to the Judge, * “O Savior, forgive my offenses, * for You are supremely long-suffering.”"

