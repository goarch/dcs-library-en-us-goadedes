A_Resource_Whose_Name = oc.m8.d2_en_US_goadedes

ocBK.ModeNaked = miscellanea_en_US_goadedes.misc.Mode8.naked

ocVE.Stichera1.mode = miscellanea_en_US_goadedes.misc.Mode8
ocVE.Stichera1.greekmelody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.greekname
ocVE.Stichera1.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
ocVE.Stichera1.incipit = "I carry on so indifferently…"
ocVE.Stichera1.text = "I carry on so indifferently! Alas! I squander the time * of my life in uncertainty, * for I have not taken stock * of my sins, which are numerous, * nor have I pondered the terrifying threat * of death and judgment impartial in the end. * Who will deliver me * from the condemnation to eternal fire, * unless You, O God supremely good, take pity on me."

ocVE.Stichera2.mode = miscellanea_en_US_goadedes.misc.Mode8
ocVE.Stichera2.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
ocVE.Stichera2.incipit = "Woe be to you, sorry soul…"
ocVE.Stichera2.text = "Woe be to you, sorry soul of mine, for you will surely lament * at the judgment, when you recall * all your deeds, when righteous souls * are invited to enter God’s * eternal Kingdom, and you have been condemned * to endless fire on account of your misdeeds! * Sigh, weep, and run to Christ * the Redeemer, being on this side of death. * Wash away the multitude of your iniquities."

ocVE.Stichera3.mode = miscellanea_en_US_goadedes.misc.Mode8
ocVE.Stichera3.melody = he.a.m8_en_US_goadedes.heAU.OTouParadoxou.name
ocVE.Stichera3.incipit = "…"
ocVE.Stichera3.text = ""

ocVE.Stichera4.mode = miscellanea_en_US_goadedes.misc.Mode8
ocVE.Stichera4.greekmelody = he.a.m8_en_US_goadedes.heAU.KyrieEiKaiKritirio.greekname
ocVE.Stichera4.melody = he.a.m8_en_US_goadedes.heAU.KyrieEiKaiKritirio.name
ocVE.Stichera4.incipit = "…"
ocVE.Stichera4.text = "Lord our God, hosts of incorporeals praise You and glorify You unceasingly, * as they are enjoying the beauty of Your ineffable loveliness, * and as Your tri-solar light abundantly illumines them. * Now through their guardianship, O Savior, * and their intercessions, save our souls."

