euPL.Key0600.title = "VESPERAL PSALMS – CENSING"
euPL.Key0601.rubric = "After the Priest’s exclamation, the curtain of the Beautiful Gate is opened. The Choirs, in concise manner and subdued voice, antiphonally sing the Psalms of “Lord I have cried,” in the mode of the first Idiomelon of the Triodion, till the verse, “Bring my soul out of prison…” As the Psalms and hymns are being sung, the Deacon censes around the altar Table, the Prothesis on which sit the holy Gifts, and the entire church in the usual manner."
euPL.Key0602.rubric = ""
euPL.Key0603.title = "ENTRANCE"
euPL.Key0604.rubric = "As the “Glory; both now” is sung, the doors of the Beautiful Gate are opened. Preceded by an acolyte with a candle, the Deacon with censer (or the Gospel, if it is a feast) and the Priest exit from the north door and do the entrance. They stop at the usual place, and the Deacon says:"
euPL.Key0605.rubric = ""
euPL.Key0606.rubric = "The Priest bows his head and quietly says the prayer:"
euPL.Key0607.title = "ENTRANCE PRAYER"
euPL.Key0608.rubric = "After the end of the prayer, the Deacon addresses the Priest softly and says:"
euPL.Key0609.rubric = "The Priest blesses with his hand crosswise towards the east and says in low voice:"
euPL.Key0610.rubric = "The Deacon, from where he is standing, censes the bishop’s throne and the principal icons three times each."
euPL.Key0611.rubric = "If the entrance is done with the holy Gospel, the Deacon offers it to the Priest to kiss it. Then he faces east in front of the Priest and exclaims:"
euPL.Key0612.rubric = "The Hierarch or the Reader reads, “Gladsome light.” The Deacon, censing, immediately enters the holy Alter through the Beautiful Gate and stands inside on the left. The Priest nods towards the bishop’s throne and also enters the holy Altar through the Beautiful Gate, as the Deacon censes him, and he takes his own place before the holy Table."

euPL.Key0620.title = "READINGS – “LET MY PRAYER”"
euPL.Key0621.rubric = "After the reading of “Gladsome light,” the Deacon, holding his stole with his right hand slightly raised, steps close to the entrance of the Beautiful Gate, faces the people, and exclaims:"
euPL.Key0621a.rubric = "The Reader: “Prokeimenon. Mode (name). Psalm (number). The Reading is from the book of Genesis (or Exodus).”"
euPL.Key0622.rubric = "The Reader reads the lesson from Genesis or Exodus."
euPL.Key0623.rubric = "At the end of the first reading, the Reader again says, “Prokeimenon. Mode (name). Psalm (number)”; and then he sings: “Command!”"
euPL.Key0624.rubric = "The Priest holds a lit candle in his right hand with the censer hanging below it, stands before the holy Table, gestures crosswise and says:"
euPL.Key0625.rubric = "Then he turns to face the people, blesses them crosswise with the candle, and says:"
euPL.Key0626.text = ""

euPL.Key0701.text = "The light of Christ"
euPL.Key0701a.text = ""
euPL.Key0702.text = "shines on all."
euPL.Key0703.rubric = "Then he hands the candle and the censer to the acolyte."
euPL.Key0703a.rubric = "The Reader: “The reading is from the book of Proverbs (or Job).”"
euPL.Key0704.rubric = "The Reader reads the lesson from Proverbs or Job."
euPL.Key0705.rubric = "The Priest blesses the Reader and says:"
euPL.Key0706.rubric = "Then he takes the censer in his right hand and a candle in his left, stands before the holy Table, censes it, and sings solemnly and with compunction:"

euPL.MM.Key0800.text = properties_en_US_goadedes.media.key
