euPL.Key0204.title = "INTRODUCTORY PSALM – PRAYERS"
euPL.Key0205.rubric = "The Hierarch or the Reader reads the Introductory Psalm. The Priest, during the reading of the Introductory Psalm, stands reverently before the altar table and reads the last three Vesperal Prayers, i.e. Prayers 5, 6, and 7."
euPL.Key0205a.rubric = "The Priest, during the reading of the Introductory Psalm, stands reverently before the altar table and reads the last three Vesperal Prayers, i.e. Prayers 5, 6, and 7. (Find these below after the Psalm.)"
