peMA.Lauds8.mode = miscellanea_en_US_goadedes.misc.Mode8
peMA.Lauds8.melody = miscellanea_en_US_goadedes.misc.Idiomelon
peMA.Lauds8.incipit = "In Your tender mercy…"
peMA.Lauds8.text = "In Your tender mercy, You became incarnate, O Christ our God. And thus, in Your ineffable compassion, You granted divine luster to the man who from his mother’s womb was deprived of sight, when using Your creative fingers You anointed his eyes with clay. We entreat You, O Giver of light, to also illumine the senses of our souls, for You are the ultimate source of abundant blessings."

