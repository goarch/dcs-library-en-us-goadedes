peMA.Ode6C11.incipit = "Among the robbers…"
peMA.Ode6C11.text = "Among the robbers You were crucified, O loving Lord. * O Master, You saved from evil robbers and passions that destroy the soul * all who in unison extol Your crucifixion and Your resurrection."

