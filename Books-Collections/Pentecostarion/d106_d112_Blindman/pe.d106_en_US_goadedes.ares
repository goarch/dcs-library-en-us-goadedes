peMA.Ode6C1F1.melody = he.h.m5_en_US_goadedes.heHE.OsTonProfitinTouThiros.name
peMA.Ode6C1F1.incipit = "O Lord, You spat…"
peMA.Ode6C1F1.text = "O Lord, You spat upon the ground, with spittle making clay, * anointed the eyes of someone blind from his birth, and gave him the gift of sight. * And he extolled Your immaculate might, by which You saved the world, O Logos."

peMA.Ode6C1Tr.ode = miscellanea_en_US_goadedes.misc.Ode6
peMA.Ode6C1Tr.mode = miscellanea_en_US_goadedes.misc.Mode5
peMA.Ode6C1Tr.melody = he.h.m5_en_US_goadedes.heHE.OsTonProfitinTouThiros.name
peMA.Ode6C1Tr.incipit = "Thrice-holy Lord…"
peMA.Ode6C1Tr.text = "Thrice-holy Lord, the single God in three hypostases, * O unbegotten Father and begotten Son and Spirit who proceeds, * one in essence and omnipotence: we pray You save all Your people."

peMA.Ode6C1T.ode = miscellanea_en_US_goadedes.misc.Ode6
peMA.Ode6C1T.mode = miscellanea_en_US_goadedes.misc.Mode5
peMA.Ode6C1T.melody = he.h.m5_en_US_goadedes.heHE.OsTonProfitinTouThiros.name
peMA.Ode6C1T.incipit = "All-blameless Virgin…"
peMA.Ode6C1T.text = "All-blameless Virgin, who can speak of your magnificence? * Ineffably you gave birth to God in the flesh; and through you He saved the world, * and He released it from every sin, O all-immaculate Lady."

peMA.Kontakion1.mode = miscellanea_en_US_goadedes.misc.Mode4
peMA.Kontakion1.greekmelody = he.a.m4_en_US_goadedes.heAU.EpefanisSimeron.greekname
peMA.Kontakion1.melody = he.a.m4_en_US_goadedes.heAU.EpefanisSimeron.name
peMA.Kontakion1.incipit = "…"
peMA.Kontakion1.text = ""

peMA.Oikos1.text = "Grant me a stream of ineffable wisdom and knowledge from on high, O Christ, the light for those in darkness and guide for those who are lost, and I will relate what the holy book of the Gospel of peace has taught, namely the miracle You performed on the Blindman: a man, who was blind from his birth, obtained the use of his physical eyes, and also the eyes of his soul, and he believed in You and cried out, “For those in darkness You are the most resplendent light.”"

