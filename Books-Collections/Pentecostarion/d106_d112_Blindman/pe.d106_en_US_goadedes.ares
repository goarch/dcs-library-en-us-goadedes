peMA.Ode3C1H.incipit = he.h.m5_en_US_goadedes.heHE.SalevomeninTinKardian.incipit
peMA.Ode3C1H.text = he.h.m5_en_US_goadedes.heHE.SalevomeninTinKardian.text

peMA.Ode3C11.ode = miscellanea_en_US_goadedes.misc.Ode3
peMA.Ode3C11.mode = miscellanea_en_US_goadedes.misc.Mode5
peMA.Ode3C11.greekmelody = he.h.m5_en_US_goadedes.heHE.SalevomeninTinKardian.greekname
peMA.Ode3C11.melody = he.h.m5_en_US_goadedes.heHE.SalevomeninTinKardian.name
peMA.Ode3C11.incipit = "Forbearing Lord…"
peMA.Ode3C11.text = "Forbearing Lord, You shook the earth at the time of Your all-holy crucifixion, which You endured * in the flesh, and strengthened Your disciples’ shaken hearts."

peMA.Ode3C12.ode = miscellanea_en_US_goadedes.misc.Ode3
peMA.Ode3C12.mode = miscellanea_en_US_goadedes.misc.Mode5
peMA.Ode3C12.melody = he.h.m5_en_US_goadedes.heHE.SalevomeninTinKardian.name
peMA.Ode3C12.incipit = "Respected Joseph…"
peMA.Ode3C12.text = "Respected Joseph took Your body and laid it in a sepulcher, from which on the third day * You arose, O merciful Lord, after renewing us."

peMA.Ode3C13.ode = miscellanea_en_US_goadedes.misc.Ode3
peMA.Ode3C13.mode = miscellanea_en_US_goadedes.misc.Mode5
peMA.Ode3C13.melody = he.h.m5_en_US_goadedes.heHE.SalevomeninTinKardian.name
peMA.Ode3C13.incipit = "…"
peMA.Ode3C13.text = ""

peMA.Ode3C1F1.ode = miscellanea_en_US_goadedes.misc.Ode3
peMA.Ode3C1F1.mode = miscellanea_en_US_goadedes.misc.Mode5
peMA.Ode3C1F1.greekmelody = he.h.m5_en_US_goadedes.heHE.SalevomeninTinKardian.greekname
peMA.Ode3C1F1.melody = he.h.m5_en_US_goadedes.heHE.SalevomeninTinKardian.name
peMA.Ode3C1F1.incipit = "You healed the man…"
peMA.Ode3C1F1.text = "You healed the man who had been blind from his birth, O Lord. * He worshiped You with faith, and he glorified *Your amazing miracles, O all-compassionate God."

peMA.Ode3C1Tr.ode = miscellanea_en_US_goadedes.misc.Ode3
peMA.Ode3C1Tr.mode = miscellanea_en_US_goadedes.misc.Mode5
peMA.Ode3C1Tr.melody = he.h.m5_en_US_goadedes.heHE.SalevomeninTinKardian.name
peMA.Ode3C1Tr.incipit = "…"
peMA.Ode3C1Tr.text = ""

peMA.Ode3C1T.ode = miscellanea_en_US_goadedes.misc.Ode3
peMA.Ode3C1T.mode = miscellanea_en_US_goadedes.misc.Mode5
peMA.Ode3C1T.melody = he.h.m5_en_US_goadedes.heHE.SalevomeninTinKardian.name
peMA.Ode3C1T.incipit = "O virgin Mother…"
peMA.Ode3C1T.text = "O virgin Mother, from your womb you gave birth to God, when He became incarnate. And now to Him, * O all-holy Lady, pray that He take pity on us."

peMA.Ode3Kathisma1.mode = miscellanea_en_US_goadedes.misc.Mode8
peMA.Ode3Kathisma1.greekmelody = he.a.m8_en_US_goadedes.heAU.TinSofianKaiLogon.greekname
peMA.Ode3Kathisma1.melody = he.a.m8_en_US_goadedes.heAU.TinSofianKaiLogon.name
peMA.Ode3Kathisma1.incipit = "The Creator and Master…"
peMA.Ode3Kathisma1.text = "The Creator and Master of all the world, * passing by, saw a man who was blind from birth, * who sat on the road and begged * and lamented and said to Him, * “All my life I have never been able to see the sun * that illumines the day, nor the moon that lights up the night. * So I now implore You, who were born of of Virgin, * to give light to all the world, that you also give sight to me, * and with cries I will worship You. * Lord and Savior, Christ my God, I entreat You for forgiveness of my sins, * in Your plentiful mercy and love for humanity.”"

